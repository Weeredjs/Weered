{
  "name": "weered",
  "private": true,
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "infra:up": "docker compose up -d postgres redis livekit",
    "infra:down": "docker compose down",
    "desktop": "pnpm --filter @weered/desktop dev",
    "desktop:build": "pnpm --filter @weered/desktop build",
    "mobile": "pnpm --filter @weered/mobile start:go",
    "web": "pnpm --filter @weered/web dev"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "25.2.3",
    "@types/ws": "^8.18.1"
  },
  "dependencies": {
    "@expo/ngrok": "^4.1.3"
  },
  "pnpm": {
    "overrides": {
      "fast-uri": ">=3.1.2",
      "ws": ">=8.20.1",
      "shell-quote": ">=1.8.4",
      "esbuild": ">=0.28.1",
      "postcss": ">=8.5.10",
      "uuid": ">=11.1.1"
    }
  }
}
