{
  "name": "weered",
  "private": true,
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "infra:up": "docker compose up -d postgres redis livekit",
    "infra:down": "docker compose down",
    "desktop": "pnpm --filter @weered/desktop dev",
    "desktop:build": "pnpm --filter @weered/desktop build",
    "mobile": "pnpm --filter @weered/mobile start:go",
    "web": "pnpm --filter @weered/web dev",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "bash scripts/check.sh",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@next/eslint-plugin-next": "^15.5.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "25.2.3",
    "@types/ws": "^8.18.1",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.0.0",
    "typescript-eslint": "^8.0.0"
  },
  "dependencies": {
    "@expo/ngrok": "^4.1.3"
  },
  "pnpm": {
    "overrides": {
      "fast-uri": ">=3.1.2",
      "ws": ">=8.20.1",
      "shell-quote": ">=1.8.4",
      "esbuild": ">=0.28.1",
      "postcss": ">=8.5.10",
      "uuid": ">=11.1.1",
      "brace-expansion@1": "1.1.15",
      "brace-expansion@2": "2.1.1"
    }
  },
  "license": "UNLICENSED",
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,yml,yaml,html}": [
      "prettier --write"
    ]
  }
}
