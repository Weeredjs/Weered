# Hoist Babel/React-Native/React-Refresh transitives into root node_modules
# so Metro/Babel can resolve plugin names by require during eas update,
# eas build, and expo export. Without these, bundling fails with
# 'Cannot find module @babel/plugin-...' even though the plugin IS installed
# under .pnpm/ — Babel doesn't know how to traverse pnpm's virtual store.
public-hoist-pattern[]=*babel*
public-hoist-pattern[]=*react-refresh*
public-hoist-pattern[]=*react-native*
