app.get("/rooms/:roomId/state", async (req, reply) => {
  const userId = verifyToken(getBearer(req));
  if (!userId) return reply.code(401).send({ error: "unauthorized" });

  const roomId = String((req.params as any)?.roomId ?? "");
  if (!roomId) return reply.code(400).send({ error: "roomId required" });

  const room = await prisma.room.findUnique({ where: { id: roomId } });
  if (!room) return reply.code(404).send({ error: "room not found" });

  const mem = await prisma.membership.findFirst({ where: { userId, spaceId: room.spaceId } });
  if (!mem) return reply.code(403).send({ error: "forbidden" });

  const rs = await prisma.roomState.findUnique({ where: { roomId } });
  const state = (rs?.stateJson as any) ?? {};
  return { roomId, state };
});

app.put("/rooms/:roomId/state", async (req, reply) => {
  const userId = verifyToken(getBearer(req));
  if (!userId) return reply.code(401).send({ error: "unauthorized" });

  const roomId = String((req.params as any)?.roomId ?? "");
  if (!roomId) return reply.code(400).send({ error: "roomId required" });

  const room = await prisma.room.findUnique({ where: { id: roomId } });
  if (!room) return reply.code(404).send({ error: "room not found" });

  const mem = await prisma.membership.findFirst({ where: { userId, spaceId: room.spaceId } });
  if (!mem) return reply.code(403).send({ error: "forbidden" });

  const body = (req.body as any) ?? {};
  const patch = body.patch;

  if (patch && (typeof patch !== "object" || Array.isArray(patch))) {
    return reply.code(400).send({ error: "patch must be an object" });
  }

  const prev = await prisma.roomState.findUnique({ where: { roomId } });
  const prevState = (prev?.stateJson as any) ?? {};
  const nextState = patch ? { ...prevState, ...patch } : prevState;

  await prisma.roomState.upsert({
    where: { roomId },
    create: { roomId, stateJson: nextState },
    update: { stateJson: nextState }
  });

  return { ok: true, roomId, state: nextState };
});
app.register(roomsStateRoutes)
await app.listen({ port: PORT, host: "0.0.0.0" });


// -------------------- WS (presence + room-scoped chat) --------------------
type Conn = {
  ws: any;
  userId?: string;
  displayName?: string;
  roomId?: string;
};

const conns = new Set<Conn>();
const rooms = new Map<string, Set<Conn>>();

function roomSet(roomId: string) {
  if (!rooms.has(roomId)) rooms.set(roomId, new Set());
  return rooms.get(roomId)!;
}

function broadcastRoom(roomId: string, msg: any) {
  const set = rooms.get(roomId);
  if (!set) return;
  const data = JSON.stringify(msg);
  for (const c of set) c.ws.send(data);
}

async function buildUserCard(userId: string, roomId?: string) {
  const user = await prisma.user.findUnique({ where: { id: userId } });
  let spaceRole: string | null = null;

  if (roomId) {
    const room = await prisma.room.findUnique({ where: { id: roomId } });
    if (room) {
      const mem = await prisma.membership.findFirst({ where: { userId, spaceId: room.spaceId } });
      spaceRole = mem?.role ?? null;
    }
  }

  const globalRole = user?.globalRole ?? "user";
  const subscriptionTier = user?.subscriptionTier ?? "free";

  const pinRank =
    spaceRole === "owner" ? 1000 :
    globalRole === "god" ? 900 :
    globalRole === "mod_supervisor" ? 800 :
    globalRole === "global_mod" ? 700 :
    globalRole === "support" ? 600 :
    subscriptionTier === "plus" ? 200 : 100;

  return {
    userId,
    displayName: user?.displayName ?? "User",
    globalRole,
    subscriptionTier,
    spaceRole,
    pinRank
  };
}

async function roster(roomId: string) {
  const set = rooms.get(roomId) ?? new Set();
  const cards = await Promise.all(
    Array.from(set)
      .filter(c => c.userId)
      .map(c => buildUserCard(c.userId!, roomId))
  );
  cards.sort((a, b) => b.pinRank - a.pinRank || a.displayName.localeCompare(b.displayName));
  return cards;
}

const wss = new WebSocketServer({ port: WS_PORT });
wss.on("connection", (ws) => {
  const conn: Conn = { ws };
  conns.add(conn);

  ws.on("message", async (raw: Buffer) => {
    let msg: any;
    try { msg = JSON.parse(raw.toString("utf8")); } catch { return; }
    const { type, payload } = msg;

    if (type === "auth:hello") {
      const userId = verifyToken(String(payload?.token ?? ""));
      if (!userId) { ws.send(JSON.stringify({ type: "auth:fail" })); return; }
      conn.userId = userId;

      const u = await prisma.user.findUnique({ where: { id: userId } });
      conn.displayName = u?.displayName ?? "User";

      ws.send(JSON.stringify({ type: "auth:ok", payload: { userId, displayName: conn.displayName } }));
      return;
    }

    if (!conn.userId) return;

    if (type === "presence:join") {
      const roomId = String(payload?.roomId ?? "");
      if (!roomId) return;

      if (conn.roomId) {
        const prev = conn.roomId;
        roomSet(prev).delete(conn);
        broadcastRoom(prev, { type: "presence:leave", payload: { roomId: prev, userId: conn.userId } });
        broadcastRoom(prev, { type: "presence:state", payload: { roomId: prev, users: await roster(prev) } });
      }

      conn.roomId = roomId;
      roomSet(roomId).add(conn);

      const card = await buildUserCard(conn.userId, roomId);
      broadcastRoom(roomId, { type: "presence:join", payload: { roomId, user: card } });
      broadcastRoom(roomId, { type: "presence:state", payload: { roomId, users: await roster(roomId) } });
      return;
    }

    if (type === "presence:leave") {
      const roomId = conn.roomId;
      if (!roomId) return;

      roomSet(roomId).delete(conn);
      conn.roomId = undefined;

      broadcastRoom(roomId, { type: "presence:leave", payload: { roomId, userId: conn.userId } });
      broadcastRoom(roomId, { type: "presence:state", payload: { roomId, users: await roster(roomId) } });
      return;
    }

    if (type === "chat:send") {
      const roomId = String(payload?.roomId ?? conn.roomId ?? "");
      const body = String(payload?.body ?? "").trim();
      if (!roomId || !body) return;

      const saved = await prisma.message.create({
        data: {
          scope: MessageScope.room,
          roomId,
          dmKey: null,
          fromUserId: conn.userId,
          body
        }
      });

      broadcastRoom(roomId, {
        type: "chat:new",
        payload: {
          id: saved.id,
          roomId,
          fromUserId: conn.userId,
          body,
          createdAt: saved.createdAt.toISOString()
        }
      });
      return;
    }
  });

  ws.on("close", async () => {
    conns.delete(conn);
    if (conn.roomId && conn.userId) {
      const roomId = conn.roomId;
      roomSet(roomId).delete(conn);
      broadcastRoom(roomId, { type: "presence:leave", payload: { roomId, userId: conn.userId } });
      broadcastRoom(roomId, { type: "presence:state", payload: { roomId, users: await roster(roomId) } });
    }
  });
});

