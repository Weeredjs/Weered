import "dotenv/config";
import Fastify from "fastify";
import cors from "@fastify/cors";
import jwt from "jsonwebtoken";
import { WebSocketServer } from "ws";
import { PrismaClient, SpaceType, SpaceRole, RoomType, PrivacyMode, MessageScope } from "@prisma/client";
import { AccessToken } from "livekit-server-sdk";
import { roomsStateRoutes } from './routes/roomsState'

const prisma = new PrismaClient();
const app = Fastify({ logger: true });
await app.register(cors, { origin: true });

const PORT = Number(process.env.PORT ?? 4000);
const WS_PORT = Number(process.env.WS_PORT ?? 4001);

const JWT_SECRET = process.env.JWT_SECRET!;
const LIVEKIT_URL = process.env.LIVEKIT_URL!;
const LIVEKIT_API_KEY = process.env.LIVEKIT_API_KEY!;
const LIVEKIT_API_SECRET = process.env.LIVEKIT_API_SECRET!;

function signToken(userId: string) {
  return jwt.sign({ sub: userId }, JWT_SECRET, { expiresIn: "30d" });
}
function verifyToken(token: string): string | null {
  try {
    const payload = jwt.verify(token, JWT_SECRET) as any;
    return payload?.sub ?? null;
  } catch {
    return null;
  }
}

async function ensureHomeSpace(userId: string) {
  const existing = await prisma.space.findFirst({ where: { ownerUserId: userId, type: SpaceType.home } });
  if (existing) return existing;

  const space = await prisma.space.create({
    data: { ownerUserId: userId, type: SpaceType.home, name: "Home" }
  });

  await prisma.membership.create({
    data: { userId, spaceId: space.id, role: SpaceRole.owner }
  });

  const rooms = [
    { name: "Gaming", roomType: RoomType.gaming, privacyMode: PrivacyMode.public },
    { name: "Office", roomType: RoomType.office, privacyMode: PrivacyMode.knock },
    { name: "Watch", roomType: RoomType.watch, privacyMode: PrivacyMode.public },
    { name: "Chill", roomType: RoomType.table, privacyMode: PrivacyMode.public }
  ];

  for (const r of rooms) {
    const room = await prisma.room.create({ data: { spaceId: space.id, ...r } });
    await prisma.roomState.create({ data: { roomId: room.id, stateJson: {} } });
  }

  return space;
}

function getBearer(req: any): string {
  const auth = String(req.headers.authorization ?? "");
  return auth.startsWith("Bearer ") ? auth.slice(7) : "";
}

app.get("/health", async () => ({ ok: true }));

// Day-1 dev login: POST { displayName } => token + user + auto Home Lobby
app.post("/auth/dev-login", async (req, reply) => {
  const body = req.body as any;
  const displayName = String(body?.displayName ?? "").trim();
  if (!displayName) return reply.code(400).send({ error: "displayName required" });

  let user = await prisma.user.findFirst({ where: { displayName } });
  if (!user) user = await prisma.user.create({ data: { displayName } });

  await ensureHomeSpace(user.id);

  const token = signToken(user.id);
  return {
    token,
    user: {
      id: user.id,
      displayName: user.displayName,
      globalRole: user.globalRole,
      subscriptionTier: user.subscriptionTier
    }
  };
});

app.get("/spaces", async (req, reply) => {
  const userId = verifyToken(getBearer(req));
  if (!userId) return reply.code(401).send({ error: "unauthorized" });

  const memberships = await prisma.membership.findMany({
    where: { userId },
    include: { space: true }
  });

  return memberships.map(m => ({
    id: m.space.id,
    name: m.space.name,
    type: m.space.type,
    role: m.role,
    ownerUserId: m.space.ownerUserId
  }));
});

app.get("/spaces/:spaceId/rooms", async (req, reply) => {
  const userId = verifyToken(getBearer(req));
  if (!userId) return reply.code(401).send({ error: "unauthorized" });

  const spaceId = (req.params as any).spaceId as string;

  const mem = await prisma.membership.findFirst({ where: { userId, spaceId } });
  if (!mem) return reply.code(403).send({ error: "forbidden" });

  const rooms = await prisma.room.findMany({ where: { spaceId }, orderBy: { createdAt: "asc" } });
  return rooms.map(r => ({ id: r.id, name: r.name, roomType: r.roomType, privacyMode: r.privacyMode }));
});

app.post("/voice/token", async (req, reply) => {
  const userId = verifyToken(getBearer(req));
  if (!userId) return reply.code(401).send({ error: "unauthorized" });

  const body = req.body as any;
  const roomId = String(body?.roomId ?? "");
  if (!roomId) return reply.code(400).send({ error: "roomId required" });

  const room = await prisma.room.findUnique({ where: { id: roomId } });
  if (!room) return reply.code(404).send({ error: "room not found" });

  const mem = await prisma.membership.findFirst({ where: { userId, spaceId: room.spaceId } });
  if (!mem) return reply.code(403).send({ error: "forbidden" });

  const livekitRoom = `space_${room.spaceId}__room_${room.id}`;

  const at = new AccessToken(LIVEKIT_API_KEY, LIVEKIT_API_SECRET, {
    identity: userId,
    name: userId
  });
  at.addGrant({ room: livekitRoom, roomJoin: true, canPublish: true, canSubscribe: true });

  return { wsUrl: LIVEKIT_URL, token: await at.toJwt(), livekitRoom };
});

 
// -------------------- HTTP: room message history --------------------
app.get("/rooms/:roomId/messages", async (req, reply) => {
  const userId = verifyToken(getBearer(req));
  if (!userId) return reply.code(401).send({ error: "unauthorized" });

  const roomId = String((req.params as any)?.roomId ?? "");
  if (!roomId) return reply.code(400).send({ error: "roomId required" });

  const q: any = (req as any).query ?? {};
  let limit = parseInt(String(q.limit ?? "50"), 10);
  if (!Number.isFinite(limit) || limit <= 0) limit = 50;
  if (limit > 200) limit = 200;

  const room = await prisma.room.findUnique({ where: { id: roomId } });
  if (!room) return reply.code(404).send({ error: "room not found" });

  const mem = await prisma.membership.findFirst({ where: { userId, spaceId: room.spaceId } });
  if (!mem) return reply.code(403).send({ error: "forbidden" });

  const msgs = await prisma.message.findMany({
    where: { scope: MessageScope.room, roomId },
    orderBy: { createdAt: "desc" },
    take: limit
  });

  msgs.reverse();
  return msgs.map(m => ({
    id: m.id,
    roomId: roomId,
    fromUserId: m.fromUserId,
    body: m.body,
    createdAt: m.createdAt.toISOString()
  }));
});
