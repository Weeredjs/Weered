type UserLite = { id: string; name: string };
type ClientCtx = { ws: any; user?: UserLite; roomId?: string; pendingRoomId?: string };

type Knock = { userId: string; userName?: string; message?: string; createdAt: string };

const clients = new Set<ClientCtx>();
const roomClients = new Map<string, Set<ClientCtx>>();
const knocksByRoom = new Map<string, Knock[]>();

function _send(ws: any, obj: any) { try { ws.send(JSON.stringify(obj)); } catch (e) {} }

function send(ws: any, obj: any) {
  try { ws.send(JSON.stringify(obj)); } catch (e) {}
}

function broadcast(roomId: string, obj: any) {
  const set = roomClients.get(roomId);
  if (!set) return;
  for (const c of set) send(c.ws, obj);
}

function shortId6(): string {
  // 6-ish chars, url-safe
  return crypto.randomBytes(4).toString('base64url').slice(0, 6);
}

async function ensureUser(name: string): Promise<UserLite> {
  const u = await prisma.user.create({ data: { name } });
  return { id: u.id, name: u.name };
}

async function ensureRoom(roomId: string, owner?: UserLite) {
  const rid = roomId.trim();
  if (!rid) throw new Error('bad_room_id');

  const existing = await prisma.room.findUnique({ where: { id: rid } });
  if (existing) return existing;

  const created = await prisma.room.create({
    data: {
      id: rid,
      name: null,
      locked: false,
      ownerId: owner?.id || null,
    },
  });

  if (owner?.id) {
;(async () => {
    await prisma.roomMember.upsert({
      where: { roomId_userId: { roomId: rid, userId: owner.id } },
      update: { role: 'owner' },
      create: { roomId: rid, userId: owner.id, role: 'owner' },
    });
  });
  return created;
}

async function getRole(roomId: string, userId: string): Promise<Role> {
  const m = await prisma.roomMember.findUnique({
    where: { roomId_userId: { roomId, userId } },
    select: { role: true },
  });
  if (!m?.role) return 'guest';
  const r = String(m.role) as Role;
  return (r === 'owner' || r === 'admin' || r === 'mod' || r === 'member') ? r : 'guest';
}

function removeFromRoom(ctx: ClientCtx) {
  const rid = ctx.roomId;
  if (!rid) return;
  const set = roomClients.get(rid);
  if (set) {
    set.delete(ctx);
    if (set.size === 0) roomClients.delete(rid);
  }
  ctx.roomId = undefined;
}

async function emitPresenceState(roomId: string) {
  const set = roomClients.get(roomId);
  if (!set) return;

  const ids: string[] = [];
  const nameById = new Map<string, string>();
  for (const c of set) {
    if (c.user?.id) {
      ids.push(c.user.id);
      nameById.set(c.user.id, c.user.name);
    }
  }

  const members = await prisma.roomMember.findMany({
    where: { roomId, userId: { in: ids } },
    select: { userId: true, role: true },
  });
  const roleById = new Map<string, Role>();
  for (const m of members) roleById.set(m.userId, (m.role as Role) || 'guest');

  const payloadMembers = ids.map((id) => ({
    id,
    name: nameById.get(id) || id,
    role: roleById.get(id) || 'guest',
  }));

  for (const c of set) {
    send(c.ws, { type: 'presence:state', payload: { roomId, members: payloadMembers } });
  }
}

function getKnocks(roomId: string): Knock[] {
  return knocksByRoom.get(roomId) || [];
}

function upsertKnock(roomId: string, k: Knock) {
  const cur = getKnocks(roomId).filter((x) => x.userId !== k.userId);
  cur.push(k);
  knocksByRoom.set(roomId, cur);
}

function removeKnock(roomId: string, userId: string) {
  const cur = getKnocks(roomId).filter((x) => x.userId !== userId);
  knocksByRoom.set(roomId, cur);
}

function isPriv(r: Role) { return r === 'owner' || r === 'admin' || r === 'mod'; }
function canLock(r: Role) { return r === 'owner' || r === 'admin'; }
function canManageRoles(r: Role) { return r === 'owner' || r === 'admin'; }

async function joinRoom(ctx: ClientCtx, roomId: string) {
  if (!ctx.user) {
    send(ctx.ws, { type: 'server:error', error: 'unauthorized' });
    return;
  }

  const room = await ensureRoom(roomId, ctx.user);

  // must be a member if locked
  let role = await getRole(roomId, ctx.user.id);

  if (role === 'guest') {
    if (room.locked) {
      ctx.pendingRoomId = roomId;
      send(ctx.ws, { type: 'room:locked', payload: { roomId } });
      return;
    }
    // auto-enroll into unlocked rooms
    await prisma.roomMember.upsert({
      where: { roomId_userId: { roomId, userId: ctx.user.id } },
      update: { role: 'member' },
      create: { roomId, userId: ctx.user.id, role: 'member' },
    });
    role = 'member';
  }

  // move room
  removeFromRoom(ctx);
  ctx.roomId = roomId;
  ctx.pendingRoomId = undefined;

  let set = roomClients.get(roomId);
  if (!set) { set = new Set<ClientCtx>(); roomClients.set(roomId, set); }
  set.add(ctx);

  await emitPresenceState(roomId);
  broadcast(roomId, { type: 'presence:join', payload: { roomId, member: { id: ctx.user.id, name: ctx.user.name, role } } });

  // send knocks to privileged users
  if (isPriv(role)) {
    send(ctx.ws, { type: 'room:knocks', payload: { roomId, knocks: getKnocks(roomId) } });
  }
}

async function requireRoomRole(ctx: ClientCtx, roomId: string): Promise<Role> {
  if (!ctx.user) return 'guest';
  return await getRole(roomId, ctx.user.id);
}

