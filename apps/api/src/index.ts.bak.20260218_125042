    if (!type || typeof type !== 'string') return;

    // AUTH
    if (type === 'auth:hello') {
      const token = String((msg?.payload?.token ?? msg?.token ?? '') || '');
      if (!token) { send(ws, { type: 'auth:fail' }); return; }

      try {
        const dec: any = jwt.verify(token, JWT_SECRET);
