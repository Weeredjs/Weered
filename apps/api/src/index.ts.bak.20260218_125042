    if (type === 'room:set_role') {
      const roomId = String(msg?.payload?.roomId || '').trim();
      const userId = String(msg?.payload?.userId || '').trim();
      const newRole = String(msg?.payload?.role || '').trim().toLowerCase() as Role;
      if (!roomId || !userId || !newRole) { send(ws, { type: 'server:error', error: 'bad_request' }); return; }

