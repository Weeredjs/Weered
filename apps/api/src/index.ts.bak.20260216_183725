import Fastify from 'fastify';
import jwt from 'jsonwebtoken';
import { WebSocketServer } from 'ws';
import { PrismaClient } from '@prisma/client';
import { randomUUID } from 'crypto';

const HTTP_PORT = Number(process.env.PORT ?? 4000);
const WS_PORT = Number(process.env.WS_PORT ?? 4001);
const JWT_SECRET = process.env.JWT_SECRET ?? 'weered-dev-secret';

const prisma = new PrismaClient();
const app = Fastify({ logger: true });

// CORS (dev)
app.addHook('onRequest', async (req, reply) => {
  const origin = (req.headers.origin as string) ?? '*';
  reply.header('Access-Control-Allow-Origin', origin);
  reply.header('Vary', 'Origin');
  reply.header('Access-Control-Allow-Credentials', 'true');
  reply.header('Access-Control-Allow-Headers', 'content-type,authorization');
  reply.header('Access-Control-Allow-Methods', 'GET,POST,PUT,PATCH,DELETE,OPTIONS');
  if (req.method === 'OPTIONS') {
    reply.code(204);
    return reply.send();
  }
});

app.get('/health', async () => ({ ok: true, name: 'weered-api' }));

function authFromReq(req: any): { id: string; name: string } | null {
  const h = String(req.headers?.authorization ?? '');
  const m = h.match(/^Bearer\s+(.+)$/i);
  if (!m) return null;
  try {
    const decoded = jwt.verify(m[1], JWT_SECRET) as any;
    const id = String(decoded.sub ?? '').trim();
    const name = String(decoded.name ?? '').trim();
    if (!id) return null;
    return { id, name: name || 'User' };
  } catch {
    return null;
  }
}

app.post('/dev-login', async (req, reply) => {
  const body = (req.body ?? {}) as any;
  const name = String(body.name ?? '').trim() || 'Dev User';
  const userId = 'dev-' + randomUUID().slice(0, 8);

  const token = jwt.sign({ sub: userId, name }, JWT_SECRET, { expiresIn: '7d' });
  return reply.send({ token, user: { id: userId, name } });
});

app.get('/rooms', async () => {
  const rooms = await prisma.room.findMany({
    orderBy: { updatedAt: 'desc' },
    take: 100,
    select: { id: true, name: true, locked: true, ownerId: true, ownerName: true, updatedAt: true, createdAt: true },
  });
  return { rooms };
});

// Create room requires auth (owner assigned)
app.post('/rooms', async (req, reply) => {
  const user = authFromReq(req);
  if (!user) return reply.code(401).send({ error: 'unauthorized' });

  const body = (req.body ?? {}) as any;
  const name = String(body.name ?? '').trim() || null;

  const id = randomUUID().slice(0, 8);
  const room = await prisma.room.create({
    data: { id, name, ownerId: user.id, ownerName: user.name },
    select: { id: true, name: true, locked: true, ownerId: true, ownerName: true, createdAt: true, updatedAt: true },
  });

  await prisma.roomMember.create({
    data: { roomId: id, userId: user.id, userName: user.name, role: 'owner' },
  });

  return reply.send({ room });
});

