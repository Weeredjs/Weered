        const actorId = String((ctx as any)?.user?.id ?? '').trim();

        console.log('[ws][role_v2] set_role', { roomId, actorId, targetId, newRole });

        const allowedRoles = new Set(['guest','member','mod','admin']);
        if (!roomId || !actorId || !targetId || !allowedRoles.has(newRole)) {
          _send(ws, { type: 'server:error', error: 'bad_request' });
          return;
        }

        // only owner/admin can change roles (mods cannot)
        let ownerId: string | null = null;
        try {
          const r = await prisma.room.findUnique({ where: { id: roomId }, select: { ownerId: true } });
          ownerId = (r?.ownerId ?? null) as any;
        } catch (e) {}

        let actorRole = 'guest';
        if (ownerId && ownerId === actorId) actorRole = 'owner';
        else {
          try {
            const m: any = await (prisma as any).roomMember?.findUnique?.({
              where: { roomId_userId: { roomId, userId: actorId } },
              select: { role: true }
            });
            actorRole = String(m?.role ?? 'guest').toLowerCase();
          }
          catch (err) {
            console.error('[weered/api] swallowed try error', err);
          }
        }

        const can = (actorRole === 'owner' || actorRole === 'admin');
        if (!can) {
          _send(ws, { type: 'server:error', error: 'forbidden' });
          return;
        }

        // never allow changing the room owner via set_role
        if (ownerId && targetId === ownerId) {
          _send(ws, { type: 'server:error', error: 'cannot_change_owner' });
          return;
        }

        // Persist role (INCLUDING guest). This prevents "guest" from meaning "delete membership => kick".
        try {
          await (prisma as any).roomMember.upsert({
            where: { roomId_userId: { roomId, userId: targetId } },
            update: { role: newRole },
            create: { roomId, userId: targetId, role: newRole }
          });
        } catch (e: any) {
          console.warn('[ws][role_v2] roomMember upsert error:', e?.message || e);
          _send(ws, { type: 'server:error', error: 'db_error' });
          return;
        }
        catch (err) {
          console.error('[weered/api] swallowed try error', err);
        }

        // Broadcast presence:state with roles
        try {
          const set = roomClients.get(roomId);
          if (set) {
            let roleMap = new Map<string,string>();
            try {
              const rows: any[] = await (prisma as any).roomMember.findMany({
                where: { roomId },
                select: { userId: true, role: true }
              });
              for (const r of rows) roleMap.set(String(r.userId), String(r.role).toLowerCase());
            } catch (e) {}

            const members = Array.from(set).map((c: any) => {
              const id = String(c?.user?.id ?? '');
              const name = String(c?.user?.name ?? '');
              let role = roleMap.get(id) || 'guest';
              if (ownerId && id === ownerId) role = 'owner';
              return { id, name, role };
            });

            for (const c of Array.from(set) as any[]) {
              _send(c.ws, { type: 'presence:state', payload: { roomId, members } });
            }
          }
        }
        catch (err) {
          console.error('[weered/api] swallowed try error', err);
        }

        // Ack (optional)
        _send(ws, { type: 'room:role_set', payload: { roomId, userId: targetId, role: newRole } });
        return;
      }
      // ROLE_V2_END

    const msg = (safeJsonParse(raw) || {}) as WsIn;
    const type = (msg as any)?.type;

    // AUTH
    if (type === 'auth:hello') {
      const token = String(((msg as any)?.token ?? (msg as any)?.payload?.token) || '');
      if (!token) { send(ws, { type: 'auth:fail' }); return; }
      try {
        const dec: any = jwt.verify(token, JWT_SECRET);
        const userId = String(dec?.sub || '');
        const name = String(dec?.name || 'Weered');
        if (!userId) { send(ws, { type: 'auth:fail' }); return; }
        ctx.user = { id: userId, name };
        send(ws, { type: 'auth:ok', payload: { user: ctx.user } });

        // if user previously tried to join a locked room and got admitted, re-attempt
        if (ctx.pendingRoomId) await joinRoom(ctx, ctx.pendingRoomId);
      });
      }
      return;
    }

    if (!ctx.user) { send(ws, { type: 'server:error', error: 'unauthorized' }); return; }

    // PRESENCE JOIN
    if (type === 'presence:join') {
      const roomId = String(((msg as any)?.roomId ?? (msg as any)?.payload?.roomId) || '').trim();
      if (!roomId) { send(ws, { type: 'server:error', error: 'bad_request' }); return; }
      await joinRoom(ctx, roomId);
      return;
    }

    // CHAT SEND (broadcast even if DB write fails)
    if (type === 'chat:send') {
      const roomId = String(((msg as any)?.roomId ?? (msg as any)?.payload?.roomId) || '').trim();
      const body = String(((msg as any)?.body ?? (msg as any)?.text ?? (msg as any)?.payload?.body ?? (msg as any)?.payload?.text) || '').trim();
      if (!roomId || !body) { send(ws, { type: 'server:error', error: 'bad_request' }); return; }
      if (ctx.roomId !== roomId) { send(ws, { type: 'server:error', error: 'not_in_room' }); return; }

      const at = new Date().toISOString();
      broadcast(roomId, { type: 'chat:new', payload: { roomId, body, at, from: { id: ctx.user.id, name: ctx.user.name } } });

      try {
        await prisma.message.create({ data: { roomId, userId: ctx.user.id, body } });
      } catch (e: any) {
        app.log.warn({ err: e }, 'message persist failed (non-fatal)');
      }
      catch (err) {
        console.error('[weered/api] swallowed try error', err);
      }
      return;
    }

    // LOCK/UNLOCK
    if (type === 'room:set_lock') {
      const roomId = String(((msg as any)?.roomId ?? (msg as any)?.payload?.roomId) || '').trim();
      const locked = !!(msg as any)?.payload?.locked;
      if (!roomId) { send(ws, { type: 'server:error', error: 'bad_request' }); return; }

      const role = await requireRoomRole(ctx, roomId);
      if (!canLock(role)) { send(ws, { type: 'server:error', error: 'forbidden' }); return; }

      const room = await ensureRoom(roomId, ctx.user);
      const updated = await prisma.room.update({ where: { id: room.id }, data: { locked } });

      broadcast(roomId, { type: 'room:lock_changed', payload: { roomId, locked: updated.locked } });
      return;
    }

    // KNOCK
    if (type === 'room:knock') {
      const roomId = String(((msg as any)?.roomId ?? (msg as any)?.payload?.roomId) || '').trim();
      const message = String((msg as any)?.payload?.message || '').trim();
      if (!roomId) { send(ws, { type: 'server:error', error: 'bad_request' }); return; }

      const room = await ensureRoom(roomId, ctx.user);
      const role = await requireRoomRole(ctx, roomId);

      if (!room.locked) { send(ws, { type: 'server:error', error: 'room_not_locked' }); return; }
      if (role !== 'guest') { send(ws, { type: 'server:error', error: 'already_member' }); return; }

      const k: Knock = { userId: ctx.user.id, userName: ctx.user.name, message: message || undefined, createdAt: new Date().toISOString() };
      upsertKnock(roomId, k);

      // broadcast knock to anyone currently in room (UI only shows it for priv)
      broadcast(roomId, { type: 'room:knock', payload: { roomId, ...k } });
      return;
    }

    // KNOCKS GET
    if (type === 'room:knocks:get') {
      const roomId = String(((msg as any)?.roomId ?? (msg as any)?.payload?.roomId) || '').trim();
      if (!roomId) { send(ws, { type: 'server:error', error: 'bad_request' }); return; }
      const role = await requireRoomRole(ctx, roomId);
      if (!isPriv(role)) { send(ws, { type: 'server:error', error: 'forbidden' }); return; }
      send(ws, { type: 'room:knocks', payload: { roomId, knocks: getKnocks(roomId) } });
      return;
    }

    // ADMIT / DENY
    if (type === 'room:admit' || type === 'room:deny') {
      const roomId = String(((msg as any)?.roomId ?? (msg as any)?.payload?.roomId) || '').trim();
      const userId = String((msg as any)?.payload?.userId || '').trim();
      if (!roomId || !userId) { send(ws, { type: 'server:error', error: 'bad_request' }); return; }

      const role = await requireRoomRole(ctx, roomId);
      if (!isPriv(role)) { send(ws, { type: 'server:error', error: 'forbidden' }); return; }

      if (type === 'room:deny') {
        removeKnock(roomId, userId);
        // notify target sockets
        for (const c of clients) if (c.user?.id === userId) send(c.ws, { type: 'room:denied', payload: { roomId } });
        broadcast(roomId, { type: 'room:knocks', payload: { roomId, knocks: getKnocks(roomId) } });
        return;
      }

      // admit
      removeKnock(roomId, userId);

      await prisma.roomMember.upsert({
        where: { roomId_userId: { roomId, userId } },
        update: { role: 'member' },
        create: { roomId, userId, role: 'member' },
      });

      // notify + auto-join if they were pending
      for (const c of clients) {
        if (c.user?.id !== userId) continue;
        send(c.ws, { type: 'room:admitted', payload: { roomId } });
        if (c.pendingRoomId === roomId) {
          await joinRoom(c, roomId);
        }
      }

      broadcast(roomId, { type: 'room:knocks', payload: { roomId, knocks: getKnocks(roomId) } });
      return;
    }

    // KICK (removes from room, membership stays)
    if (type === 'room:kick') {
      const roomId = String(((msg as any)?.roomId ?? (msg as any)?.payload?.roomId) || '').trim();
      const userId = String((msg as any)?.payload?.userId || '').trim();
      if (!roomId || !userId) { send(ws, { type: 'server:error', error: 'bad_request' }); return; }

      const actorRole = await requireRoomRole(ctx, roomId);
      if (!isPriv(actorRole)) { send(ws, { type: 'server:error', error: 'forbidden' }); return; }

      if (ctx.user.id === userId) { send(ws, { type: 'server:error', error: 'cannot_kick_self' }); return; }

      const targetRole = await getRole(roomId, userId);
      if (targetRole === 'owner') { send(ws, { type: 'server:error', error: 'cannot_kick_owner' }); return; }

      const set = roomClients.get(roomId);
      if (set) {
        for (const c of Array.from(set)) {
          if (c.user?.id === userId) {
            removeFromRoom(c);
            send(c.ws, { type: 'room:kicked', payload: { roomId } });
          }
        }
      }

      broadcast(roomId, { type: 'presence:leave', payload: { roomId, memberId: userId } });
      await emitPresenceState(roomId);
      return;
    }

    // KICK (removes from room, membership stays)
    if (type === 'room:kick') {
      const roomId = String(((msg as any)?.roomId ?? (msg as any)?.payload?.roomId) || '').trim();
      const userId = String((msg as any)?.payload?.userId || '').trim();
      if (!roomId || !userId) { send(ws, { type: 'server:error', error: 'bad_request' }); return; }

      const actorRole = await requireRoomRole(ctx, roomId);
      if (!isPriv(actorRole)) { send(ws, { type: 'server:error', error: 'forbidden' }); return; }

      if (ctx.user.id === userId) { send(ws, { type: 'server:error', error: 'cannot_kick_self' }); return; }

      const targetRole = await getRole(roomId, userId);
      if (targetRole === 'owner') { send(ws, { type: 'server:error', error: 'cannot_kick_owner' }); return; }

      const set = roomClients.get(roomId);
      if (set) {
        for (const c of Array.from(set)) {
          if (c.user?.id === userId) {
            removeFromRoom(c);
            send(c.ws, { type: 'room:kicked', payload: { roomId } });
          }
        }
      }

      broadcast(roomId, { type: 'presence:leave', payload: { roomId, memberId: userId } });
      await emitPresenceState(roomId);
      return;
    }

    // KICK (removes from room, membership stays)
    if (type === 'room:kick') {
      const roomId = String(((msg as any)?.roomId ?? (msg as any)?.payload?.roomId) || '').trim();
      const userId = String((msg as any)?.payload?.userId || '').trim();
      if (!roomId || !userId) { send(ws, { type: 'server:error', error: 'bad_request' }); return; }

      const actorRole = await requireRoomRole(ctx, roomId);
      if (!isPriv(actorRole)) { send(ws, { type: 'server:error', error: 'forbidden' }); return; }

      if (ctx.user.id === userId) { send(ws, { type: 'server:error', error: 'cannot_kick_self' }); return; }

      const targetRole = await getRole(roomId, userId);
      if (targetRole === 'owner') { send(ws, { type: 'server:error', error: 'cannot_kick_owner' }); return; }

      const set = roomClients.get(roomId);
      if (set) {
        for (const c of Array.from(set)) {
          if (c.user?.id === userId) {
            removeFromRoom(c);
            send(c.ws, { type: 'room:kicked', payload: { roomId } });
          }
        }
      }

      broadcast(roomId, { type: 'presence:leave', payload: { roomId, memberId: userId } });
      await emitPresenceState(roomId);
      return;
    }

    // SET ROLE
    if (type === 'room:set_role') {
      const roomId = String(((msg as any)?.roomId ?? (msg as any)?.payload?.roomId) || '').trim();
      const userId = String((msg as any)?.payload?.userId || '').trim();
      const newRole = String((msg as any)?.payload?.role || '').trim() as Role;
      if (!roomId || !userId || !newRole) { send(ws, { type: 'server:error', error: 'bad_request' }); return; }

      const actorRole = await requireRoomRole(ctx, roomId);
      if (!canManageRoles(actorRole)) { send(ws, { type: 'server:error', error: 'forbidden' }); return; }

      // prevent self-demotion (dev safety)
      if (ctx.user.id === userId) { send(ws, { type: 'server:error', error: 'cannot_edit_self' }); return; }

      // prevent editing owner
      const targetRole = await getRole(roomId, userId);
      if (targetRole === 'owner') { send(ws, { type: 'server:error', error: 'cannot_edit_owner' }); return; }

      // admin cannot grant admin/owner
      if (actorRole === 'admin' && (newRole === 'admin' || newRole === 'owner')) {
        send(ws, { type: 'server:error', error: 'forbidden' });
        return;
      }

      if (newRole === 'guest') {
        await prisma.roomMember.deleteMany({ where: { roomId, userId } });

        // kick if currently connected in room
        const set = roomClients.get(roomId);
        if (set) {
          for (const c of set) {
            if (c.user?.id === userId) {
              removeFromRoom(c);
              send(c.ws, { type: 'presence:leave', payload: { roomId, memberId: userId } });
            }
          }
        }

        broadcast(roomId, { type: 'room:role_changed', payload: { roomId, userId, role: 'guest' } });
        await emitPresenceState(roomId);
        return;
      }

      await prisma.roomMember.upsert({
        where: { roomId_userId: { roomId, userId } },
        update: { role: newRole },
        create: { roomId, userId, role: newRole },
      });

      broadcast(roomId, { type: 'room:role_changed', payload: { roomId, userId, role: newRole } });
      await emitPresenceState(roomId);
      return;
    }

    // unknown message types ignored (by design)
  });

  ws.on('close', async () => {
    clients.delete(ctx);
    const rid = ctx.roomId;
    const uid = ctx.user?.id;
    removeFromRoom(ctx);
    if (rid && uid) {
      broadcast(rid, { type: 'presence:leave', payload: { roomId: rid, memberId: uid } });
      await emitPresenceState(rid);
    }
  });
});

function safeJsonParse(raw: string): any | null {
  try { return JSON.parse(raw); } catch (e) { return null; }
}

