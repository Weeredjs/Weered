app.post('/rooms', async (req, reply) => {
  const auth = String((req.headers as any)?.authorization || '');
  const token = auth.startsWith('Bearer ') ? auth.slice(7) : '';
  if (!token) return reply.code(401).send({ error: 'unauthorized' });

  let decoded: any;
  try { decoded = jwt.verify(token, JWT_SECRET); }); }
  const userId = String(decoded?.sub || '');
  const name = String(decoded?.name || 'Weered');

  const user = await prisma.user.findUnique({ where: { id: userId } });
  if (!user) return reply.code(401).send({ error: 'unauthorized' });

  const body = (req.body || {}) as any;
  const roomName = String(body?.name || '').trim() || null;

  // generate id
  let id = '';
  for (let i = 0; i < 10; i++) {
    const cand = shortId6();
    const exists = await prisma.room.findUnique({ where: { id: cand }, select: { id: true } });
    if (!exists) { id = cand; break; }
  } catch (e) { console.error("[ws] try error", e); }
  if (!id) id = shortId6();

  const room = await prisma.room.create({
    data: { id, name: roomName, locked: false, ownerId: userId },
  });

  await prisma.roomMember.upsert({
    where: { roomId_userId: { roomId: room.id, userId } },
    update: { role: 'owner' },
    create: { roomId: room.id, userId, role: 'owner' },
  });

  return reply.send({ room: { id: room.id, name: room.name, locked: room.locked } });
});

