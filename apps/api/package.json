{
  "name": "@weered/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "pnpm build && node --enable-source-maps dist/index.js",
    "prisma": "prisma",
    "test:smoke": "vitest run test/smoke.test.ts",
    "test:smoke:local": "API_BASE=http://127.0.0.1:4000 vitest run test/smoke.test.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --packages=external --outfile=dist/index.js --sourcemap",
    "start:tsx": "tsx src/index.ts",
    "test": "vitest run test/unit",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run --config test/integration/vitest.config.ts",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.1.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.4.2",
    "@fastify/swagger-ui": "^5.2.2",
    "@prisma/client": "^5.22.0",
    "@sentry/node": "^10.49.0",
    "@tensorflow/tfjs": "^4.22.0",
    "@types/nodemailer": "^8.0.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.4.5",
    "fastify": "^5.8.5",
    "fastify-type-provider-zod": "^4.0.2",
    "google-auth-library": "^10.6.1",
    "h3-js": "^4.2.1",
    "jsonwebtoken": "^9.0.2",
    "livekit-server-sdk": "^2.7.3",
    "nodemailer": "^9.0.1",
    "nsfwjs": "^4.3.0",
    "pino": "^9.0.0",
    "resend": "^6.12.2",
    "sharp": "^0.35.0",
    "web-push": "^3.6.7",
    "ws": "^8.20.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "25.2.3",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "4.1.5",
    "esbuild": "^0.28.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^4.1.5"
  }
}
