generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoomRole {
  OWNER
  MOD
  MEMBER
}

enum LobbyRole {
  OWNER
  MOD
  MEMBER
}

enum JoinMode {
  OPEN       // Anyone can join instantly
  APPROVAL   // Request to join, admin approves
  PASSWORD   // Must enter lobby password
  PAID       // Must subscribe to a lobby tier
}

enum GlobalRole {
  USER
  SUPPORT
  STAFF
  ADMIN
  GOD
}

enum ModuleType {
  FEED
  MARATHON
  BUNGIE
  TWITCH
  YOUTUBE
  CUSTOM
  MLB
  PGA
  NEWS
  NONE
  RIOT
  FORTNITE
  TRADING
  POKER
  HEADQUARTERS
  CS2
  DOTA2
  STUDY
  PUBG
  DND
  POE
  WINDROSE
  REDDIT
  HELLDIVERS2
  CHESS
  EVE
  MINECRAFT
  MTG
  HLL
  COWORK
}

model NewsArticle {
  id          String   @id @default(cuid())
  guid        String   @unique
  url         String
  title       String
  description String   @default("")
  imageUrl    String?
  source      String
  sourceIcon  String?
  category    String
  publishedAt DateTime
  fetchedAt   DateTime @default(now())
  heat        Int      @default(0)

  @@index([category, heat])
  @@index([publishedAt])
}

model Lobby {
  id          String     @id
  name        String     @default("")
  description String     @default("")
  verified    Boolean    @default(false)
  pinned      Boolean    @default(false)
  // Featured = promoted placement on the home dashboard's curated cards
  // (shows featured-first). The monetization hook: sell these slots later.
  // Distinct from `pinned` (system/seeded) and the single hero featuredLobbyId.
  featured    Boolean    @default(false)
  moduleType  ModuleType @default(FEED)
  moduleConfig Json?

  // Search keywords О“ГҮГ¶ e.g. ["destiny", "destiny2", "bungie", "guardian"]
  keywords    String[]   @default([])

  // Branding О“ГҮГ¶ used for pinned lobby cards and lobby page theming
  accentColor String?    // hex e.g. "#4F88C6"
  logoUrl     String?    // square logo for search card / lobby header
  bannerUrl   String?    // wide banner for lobby hero area
  websiteUrl  String?    // embedded in Content tab
  // linkedSubreddits stored in moduleConfig as { subreddits: string[] }

  // Lobby admin О“ГҮГ¶ custom role titles and module toggles
  // roleNames: JSON map of levelО“ГҘГҶtitle, e.g. {"5":"Boss","4":"Lieutenant","3":"Bouncer","2":"VIP","1":"Viewer"}
  roleNames       Json?
  // enabledModules: which modules lobby rooms can use, e.g. ["voice","youtube","reddit"]
  enabledModules  String[]  @default(["voice", "youtube", "reddit"])

  ownerId     String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Membership gating
  joinMode      JoinMode @default(OPEN)
  joinPassword  String?  // only used when joinMode=PASSWORD

  // Revenue sharing вҖ” manual payout percentage for lobby owner (0-100)
  revenueSharePct Float @default(0)

  // Per-lobby member perks shown in the Join overlay (max 5 enforced at API).
  // Empty array = fall back to platform-default perk list. Owner-editable.
  memberPerks   String[] @default([])

  // в”Җв”Җ AutoMod-light в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  // Owner-configurable per-lobby moderation. The chat WS handler checks these
  // before persisting/broadcasting a message.
  // - blockedWords: case-insensitive substring matches; matched messages are
  //   silently dropped (sender sees a soft notice).
  // - blockedDomains: substrings matched against any URL in the message.
  // - newAccountChatHours: messages from accounts younger than N hours are
  //   blocked. 0 = disabled.
  blockedWords        String[] @default([])
  blockedDomains      String[] @default([])
  newAccountChatHours Int      @default(0)

  rooms       Room[]
  members     LobbyMember[]
  bans        LobbyBan[]
  messages    LobbyMessage[]
  adminMessages LobbyAdminMessage[]
  audit       LobbyAudit[]
  tiers        LobbyTier[]
  events       Event[]
  forumPosts   ForumPost[]
  joinRequests LobbyJoinRequest[]
  communityServers CommunityServer[]
}

/// Community game servers registered against a lobby (e.g. WindrosePlus-enabled
/// Windrose servers). Owner-claimed, publicly visible in the lobby directory.
model CommunityServer {
  id            String   @id @default(cuid())
  lobbyId       String
  ownerId       String
  name          String
  host          String
  dashboardUrl  String?
  queryUrl      String?
  apiKey        String?  // CRCON API key (server-side only; never serialized to clients)
  bmServerId    String?  // BattleMetrics id вҖ” joins this server to rallies for verified seeding
  region        String?
  description   String?
  tags          String[] @default([])
  maxSlots      Int?
  framework     String?
  status        String   @default("pending")
  lastSeenAt    DateTime?
  lastState     Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  lobby         Lobby    @relation(fields: [lobbyId], references: [id], onDelete: Cascade)
  owner         User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([lobbyId])
  @@index([ownerId])
  @@index([lobbyId, status])
}

model LobbyMember {
  id        String    @id @default(cuid())
  lobbyId   String
  userId    String
  name      String    @default("")
  role      LobbyRole @default(MEMBER)
  roleLevel Int       @default(1)   // 1=Member, 2=Trusted, 3=Moderator, 4=Admin, 5=Owner
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  lobby Lobby @relation(fields: [lobbyId], references: [id], onDelete: Cascade)

  @@unique([lobbyId, userId])
}

model LobbyBan {
  id        String   @id @default(cuid())
  lobbyId   String
  userId    String
  reason    String   @default("")
  createdAt DateTime @default(now())

  lobby Lobby @relation(fields: [lobbyId], references: [id], onDelete: Cascade)

  @@unique([lobbyId, userId])
}

model LobbyJoinRequest {
  id        String   @id @default(cuid())
  lobbyId   String
  userId    String
  userName  String   @default("")
  message   String   @default("")   // optional "why I want to join"
  status    String   @default("PENDING")  // PENDING, APPROVED, DENIED
  reviewedById   String?
  reviewedByName String?
  reviewedAt     DateTime?
  denyReason     String?
  createdAt DateTime @default(now())

  lobby Lobby @relation(fields: [lobbyId], references: [id], onDelete: Cascade)

  @@unique([lobbyId, userId])
  @@index([lobbyId, status])
}

model LobbyMessage {
  id        String   @id
  lobbyId   String
  userId    String
  userName  String   @default("")
  body      String
  ts        DateTime @default(now())
  editedAt  DateTime?
  deletedAt DateTime?

  lobby Lobby @relation(fields: [lobbyId], references: [id], onDelete: Cascade)

  @@index([lobbyId, ts])
}

model LobbyAudit {
  id        String   @id
  lobbyId   String
  type      String
  actorId   String
  actorName String
  targetId  String?
  note      String?
  ts        DateTime @default(now())

  lobby Lobby @relation(fields: [lobbyId], references: [id], onDelete: Cascade)

  @@index([lobbyId, ts])
}

model LobbyAdminMessage {
  id        String   @id
  lobbyId   String
  userId    String
  userName  String   @default("")
  body      String
  ts        DateTime @default(now())

  lobby Lobby @relation(fields: [lobbyId], references: [id], onDelete: Cascade)

  @@index([lobbyId, ts])
}

model Room {
  id           String   @id
  name         String   @default("")
  description  String   @default("")
  locked       Boolean  @default(false)
  pinned       Boolean  @default(false)
  isEvent      Boolean  @default(false)
  passwordHash String?
  ownerId   String?
  lobbyId   String?
  // Owner-authored appearance вҖ” surfaces in the room header and room cards.
  // Icon mirrors the pinned/event aesthetic (small square badge); banner is
  // a wide image behind the header; accent tints UI chrome.
  iconUrl     String?
  bannerUrl   String?
  accentColor String?
  // Which stage module the room opens with on first join. Owner-set at create.
  defaultModule String?
  // Modules the owner has disabled in this room вҖ” module:set events that
  // request a disabled mode are rejected. Empty = nothing disabled.
  disabledModules String[]  @default([])
  // Voice publish gating. OPEN = anyone can publish; QUEUED = members
  // raise hand and a mod approves; LISTEN_ONLY = only mods/owner publish.
  voiceMode VoiceRoomMode @default(OPEN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lobby    Lobby?       @relation(fields: [lobbyId], references: [id], onDelete: SetNull)
  members  RoomMember[]
  bans     RoomBan[]
  messages RoomMessage[]
  audit    RoomAudit[]
  npcs     RoomNpc[]

  @@unique([lobbyId, name])
  @@index([ownerId])
}

model RoomMember {
  id          String   @id @default(cuid())
  roomId      String
  userId      String
  name        String   @default("")
  description String   @default("")
  role        RoomRole @default(MEMBER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@index([userId])
}

model RoomBan {
  id        String   @id @default(cuid())
  roomId    String
  userId    String
  createdAt DateTime @default(now())

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
}

model RoomMessage {
  id        String   @id
  roomId    String
  userId    String
  userName  String   @default("")
  body      String
  ts        DateTime @default(now())
  editedAt  DateTime?
  deletedAt DateTime?
  // Reply-to вҖ” snapshot of parent so preview stays stable across edits/deletes
  replyToId       String?
  replyToUserId   String?
  replyToUserName String?
  replyToBody     String?

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId, ts])
}

model RoomAudit {
  id        String   @id
  roomId    String
  type      String
  actorId   String
  actorName String
  targetId  String?
  note      String?
  ts        DateTime @default(now())

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId, ts])
}

model RoomNpc {
  id        String   @id @default(cuid())
  roomId    String
  name      String
  portrait  String   @default("")
  config    Json     @default("{}")
  createdBy String
  createdAt DateTime @default(now())

  room     Room         @relation(fields: [roomId], references: [id], onDelete: Cascade)
  messages NpcMessage[]

  @@index([roomId])
}

model NpcMessage {
  id        String   @id @default(cuid())
  npcId     String
  userId    String?
  userName  String   @default("")
  role      String
  content   String
  createdAt DateTime @default(now())

  npc RoomNpc @relation(fields: [npcId], references: [id], onDelete: Cascade)

  @@index([npcId, createdAt])
}

model User {
  id          String     @id @default(cuid())
  usernameKey String     @unique
  name        String     @default("")
  description String     @default("")
  equippedFlairId String?            // FlairItem currently displayed next to name
  bio         String?
  statusText  String?    // custom status message (Discord-style vanity status)
  statusEmoji String?    // emoji or short token shown beside statusText
  avatarFrame String?    // equipped avatar decoration/frame key (none|gold|flames|crystal|neon|circuit)
  nameEffect  String?    // username color/gradient effect key (none|gold|fire|ice|toxic|royal|rainbow)
  email       String?    @unique
  googleId    String?    @unique
  avatar      String?
  avatarColor String?
  bannerUrl   String?    // wide banner image for the right-rail ID card
  favoriteLobbyIds String[] @default([])  // server-synced lobby favorites (cross-device)

  // в”Җв”Җ Profile customization (Phase 1: colors only) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  // panelBgColor + panelAccentColor drive the user's own ID badge in the
  // right rail (UserCorner). pillBgColor tints how this user appears in
  // friends/presence lists when seen by others. pillAccentColor overrides
  // the left-edge stripe on presence rows (default = role/tier color).
  // All validated as #RRGGBB.
  panelBgColor      String?
  panelAccentColor  String?
  pillBgColor       String?
  pillAccentColor   String?

  notoriety   Int        @default(0)
  mediaBannedUntil DateTime?
  joinPolicy  String     @default("FRIENDS")
  invitePolicy String    @default("FRIENDS")
  paper       Int        @default(0)   // spendable virtual currency
  lastDailyAt DateTime?                  // atomic guard for the daily Paper bonus
  tier        UserTier   @default(INNOCENT)
  globalRole        GlobalRole @default(USER)
  onboardingComplete Boolean    @default(false)
  isGuest        Boolean   @default(false)
  guestExpiresAt DateTime?

  // Global ban вҖ” staff-imposed platform-wide ban
  banned      Boolean    @default(false)
  banReason   String?
  bannedAt    DateTime?
  bannedBy    String?    // userId of staff member who banned

  // Self-initiated account deletion (GDPR right to erasure)
  deletedAt   DateTime?

  // External presence integrations
  steamId     String?   // SteamID64, e.g. "76561198000000000"
  twitchLogin String?   // Twitch login (lowercase username)
  xboxGamertag String?  // Xbox gamertag (display)
  xboxXuid    String?   // Xbox user id (numeric) resolved from gamertag
  psnAccountId String?  // PSN online ID (manual, no live integration; identity-only chip)
  lichessUsername String?  // Lichess.org username вҖ” drives chess activity polling
  chessComUsername String? // Chess.com username вҖ” drives chess activity polling
  livePresence Json?    // { source, activity, detail?, url?, updatedAt } or null
  presenceCheckedAt DateTime?

  // Streamer overlay token вҖ” OBS browser-source URL is /overlay/<token>.
  // Anyone with the URL can render the user's public live state; rotate to revoke.
  overlayToken String?  @unique

  // GPS location (opt-in only)
  locationOptIn     Boolean    @default(false)
  latitude          Float?
  longitude         Float?
  locationH3        String?    // H3 hex index (resolution 7 вүҲ 5km)
  locationUpdatedAt DateTime?

  // Last-seen presence вҖ” set when the user's last WS socket disconnects.
  // Used by the friends list to show "Last seen in <room> В· 2h ago" on
  // offline rows.
  lastSeenAt        DateTime?
  lastSeenLocation  String?

  createdAt         DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  dmSent           DirectMessage[]  @relation("DMSent")
  dmReceived       DirectMessage[]  @relation("DMReceived")
  groupThreadsOwned GroupThread[]    @relation("GroupCreator")
  groupMemberships GroupMember[]
  groupMessagesSent GroupMessage[]   @relation("GroupMessageSender")
  blocksSent       UserBlock[]      @relation("BlocksSent")
  blocksReceived   UserBlock[]      @relation("BlocksReceived")
  reportsFiled     Report[]         @relation("ReportsFiled")
  reportsReviewed  Report[]         @relation("ReportsReviewed")
  reactions        Reaction[]       @relation("ReactionsFrom")
  LocalAuth        LocalAuth?
  staffNotes       StaffNote[]      @relation("StaffNoteTarget")
  auditLogs        GlobalAudit[]    @relation("GlobalAuditTarget")
  staffPosts       StaffPost[]      @relation("StaffPostAuthor")
  notorietyEvents  NotorietyEvent[]
  gameAccounts     UserGameAccount[]
  pushSubs         PushSubscription[]
  expoPushTokens   ExpoPushToken[]
  paperTransactions PaperTransaction[]
  inventory        UserItem[]
  marketListings   MarketListing[]   @relation("MarketSeller")
  communityServers CommunityServer[]
  banAppeals       BanAppeal[]       @relation("BanAppealUser")
  bugReports       BugReport[]       @relation("BugReportSubmitter")
  helldiversLoadouts HelldiversLoadout[]
  windroseBuilds     WindroseBuild[]
  windroseBuildVotes WindroseBuildVote[]
  windroseBuildComments WindroseBuildComment[]
  windroseBuildSaves WindroseBuildSave[]
  windroseBuildReports WindroseBuildReport[]
}

// вҖ”вҖ” Ban Court вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”
// Banned users submit an appeal here. Staff triages from /staff/bans.
// The user-facing list of currently banned users lives at /ban-court.

model BanAppeal {
  id           String    @id @default(cuid())
  userId       String
  reason       String    // user's explanation, вүӨ 2000 chars
  status       String    @default("PENDING") // PENDING, APPROVED, DENIED
  createdAt    DateTime  @default(now())
  reviewedBy   String?   // staff userId
  reviewerNote String?   // optional note shown back to the appellant
  reviewedAt   DateTime?

  user         User      @relation("BanAppealUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([userId])
}

// вҖ”вҖ” In-app bug reports вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”
// Submitted from anywhere in the app via the BugReportButton. Staff triages
// from the staff dashboard. Open / Closed only вҖ” keep it simple.

model BugReport {
  id           String   @id @default(cuid())
  userId       String?  // null for anonymous reports (we still capture browser/page)
  // BUG = something broke. LOBBY_MODULE_REQUEST = lobby owner asking for a
  // custom module / config. FEEDBACK = generic suggestion. Same queue, the
  // category just routes triage attention.
  category     String   @default("BUG")
  page         String   @default("") // window.location.pathname at submit time
  userAgent    String   @default("")
  body         String   // user description, вүӨ 4000 chars
  status       String   @default("OPEN") // OPEN, CLOSED
  staffNote    String?
  createdAt    DateTime @default(now())
  closedAt     DateTime?
  closedBy     String?

  user User? @relation("BugReportSubmitter", fields: [userId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([category, status])
}

// вҖ”вҖ” Site Config (key-value) вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”
// Stores platform-wide settings: featuredLobbyId, registrationOpen, etc.
// Staff-managed via /staff/config endpoints.

model SiteConfig {
  key       String   @id           // e.g. "featuredLobbyId", "registrationOpen"
  value     String   @default("")  // stored as string, parsed by consumer
  updatedAt DateTime @updatedAt
}

model RecentVisit {
  id        String   @id @default(cuid())
  userId    String
  roomId    String?              // ad-hoc room ID (null if lobby visit)
  lobbyId   String?              // lobby ID (null if ad-hoc room visit)
  name      String   @default("") // display name at time of visit
  visitedAt DateTime @default(now())

  @@unique([userId, roomId])     // one entry per user+room
  @@unique([userId, lobbyId])    // one entry per user+lobby
  @@index([userId, visitedAt])
}

model LocalAuth {
  id                    String    @id @default(cuid())
  username              String    @unique
  passwordHash          String
  email                 String?   @unique
  emailVerified         Boolean   @default(false)
  verifyToken           String?   @unique
  verifyTokenExp        DateTime?
  passwordResetToken    String?   @unique
  passwordResetTokenExp DateTime?
  userId                String    @unique
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model StaffNote {
  id         String   @id @default(cuid())
  targetId   String
  authorId   String
  authorName String   @default("")
  body       String
  createdAt  DateTime @default(now())

  target User @relation("StaffNoteTarget", fields: [targetId], references: [id], onDelete: Cascade)
}

model GlobalAudit {
  id         String   @id @default(cuid())
  actorId    String
  actorName  String   @default("")
  action     String
  targetId   String?
  targetName String?
  meta       Json?
  createdAt  DateTime @default(now())

  target User? @relation("GlobalAuditTarget", fields: [targetId], references: [id], onDelete: SetNull)

  @@index([createdAt])
}

enum UserTier {
  INNOCENT
  INDICTED
  FELON
  KINGPIN
}

model NotorietyEvent {
  id        String   @id @default(cuid())
  userId    String
  action    String
  points    Int
  refId     String?  // optional source linkage (e.g. tournamentId that awarded this)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, action])
}

// вҖ”вҖ” Notifications вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”

enum NotificationType {
  DM_RECEIVED
  FRIEND_REQUEST
  FRIEND_ACCEPTED
  CREW_INVITE
  ROOM_INVITE
  MENTION
  CHALLENGE_STARTED
  CHALLENGE_COMPLETED
  NOTORIETY_RANKUP
  LOBBY_EVENT
  SYSTEM
}

model Notification {
  id          String           @id @default(cuid())
  userId      String
  type        NotificationType
  title       String
  body        String           @default("")
  actionUrl   String?
  actorId     String?
  actorName   String?
  meta        Json?
  read        Boolean          @default(false)
  createdAt   DateTime         @default(now())

  @@index([userId, read, createdAt])
  @@index([userId, createdAt])
}

model DirectMessage {
  id        String    @id @default(cuid())
  fromId    String
  toId      String
  body      String
  readAt    DateTime?
  createdAt DateTime  @default(now())
  editedAt  DateTime?
  deletedAt DateTime?
  // Reply-to вҖ” snapshot of parent so preview stays stable across edits/deletes
  replyToId       String?
  replyToUserId   String?
  replyToUserName String?
  replyToBody     String?

  from User @relation("DMSent",     fields: [fromId], references: [id], onDelete: Cascade)
  to   User @relation("DMReceived", fields: [toId],   references: [id], onDelete: Cascade)

  @@index([fromId, toId, createdAt])
  @@index([toId, readAt])
}

// в”Җв”Җ Group messages в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// Discord-style group threads. A creator spins one up with N friends; any
// member can send. lastReadAt on the membership row drives unread counts.
model GroupThread {
  id          String   @id @default(cuid())
  name        String?  // optional thread title; falls back to member-name list
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  // Bumped on every new message so thread list ordering doesn't need to
  // re-aggregate from GroupMessage.
  lastMessageAt DateTime @default(now())

  createdBy   User           @relation("GroupCreator", fields: [createdById], references: [id], onDelete: Cascade)
  members     GroupMember[]
  messages    GroupMessage[]

  @@index([lastMessageAt])
}

model GroupMember {
  id         String   @id @default(cuid())
  threadId   String
  userId     String
  role       String   @default("MEMBER") // OWNER | MEMBER
  joinedAt   DateTime @default(now())
  lastReadAt DateTime @default(now())
  leftAt     DateTime?

  thread GroupThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([threadId, userId])
  @@index([userId, leftAt])
}

model GroupMessage {
  id        String    @id @default(cuid())
  threadId  String
  senderId  String
  body      String
  createdAt DateTime  @default(now())
  editedAt  DateTime?
  deletedAt DateTime?

  // Reply-to вҖ” snapshot of the parent so the preview survives edits / deletes.
  replyToId       String?
  replyToUserId   String?
  replyToUserName String?
  replyToBody     String?

  thread GroupThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender User        @relation("GroupMessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
}

// в”Җв”Җ User blocks в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
model UserBlock {
  id         String   @id @default(cuid())
  blockerId  String
  blockedId  String
  reason     String?
  createdAt  DateTime @default(now())

  blocker User @relation("BlocksSent",     fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("BlocksReceived", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockedId])
}

// в”Җв”Җ Message reactions в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
enum ReactionTargetType {
  ROOM_MESSAGE
  DIRECT_MESSAGE
  CREW_MESSAGE
}

model Reaction {
  id         String             @id @default(cuid())
  targetType ReactionTargetType
  targetId   String
  userId     String
  emoji      String
  createdAt  DateTime           @default(now())

  user User @relation("ReactionsFrom", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([targetType, targetId, userId, emoji])
  @@index([targetType, targetId])
  @@index([userId])
}

// в”Җв”Җ Reports в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
enum ReportStatus {
  OPEN
  REVIEWED
  ACTIONED
  DISMISSED
}

enum ReportTargetType {
  MESSAGE
  USER
  ROOM
  LOBBY
}

enum ReportReason {
  SPAM
  HARASSMENT
  HATE_SPEECH
  THREATS
  NSFW
  MINOR_SAFETY
  IMPERSONATION
  SELF_HARM
  OTHER
}

model Report {
  id            String           @id @default(cuid())
  reporterId   String
  targetType    ReportTargetType
  targetId      String
  context       String?          // roomId / lobbyId for message reports
  reason        ReportReason
  note          String?
  status        ReportStatus     @default(OPEN)
  bodySnapshot  String?          // captured content at time of report (for MESSAGE)
  createdAt     DateTime         @default(now())
  reviewedAt    DateTime?
  reviewedById  String?

  reporter User  @relation("ReportsFiled", fields: [reporterId], references: [id], onDelete: Cascade)
  reviewer User? @relation("ReportsReviewed", fields: [reviewedById], references: [id])

  @@index([status, createdAt])
  @@index([reporterId])
  @@index([targetType, targetId])
}

// О“Г¶ГҮО“Г¶ГҮ Crew / Dojo О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ

enum CrewRole {
  LEADER
  OFFICER
  MEMBER
}

model Crew {
  id          String   @id @default(cuid())
  name        String
  tag         String   @default("")
  description String   @default("")
  ownerId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // в”Җв”Җ Published crew profile в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  // When a crew opts to be publicly listed in a lobby, these fields
  // surface on a cards-view in that lobby. publicInLobbies gates where.
  logoUrl          String?
  bannerUrl        String?
  accentColor      String?   // "#xxxxxx"
  // Crew tag display shape вҖ” drives the [TAG] chip rendering in friends/profile
  tagShape         String    @default("rounded")  // rounded | square | diamond
  homePort         String?   // free text вҖ” "Tortuga", "Caribbean-3 server", etc.
  recruiting       Boolean   @default(false)
  recruitingNote   String    @default("")
  publicInLobbies  String[]  @default([])  // lobbyIds where this profile appears

  members CrewMember[]
  crewMessages CrewMessage[]
  joinRequests CrewJoinRequest[]

  @@index([recruiting])
}

model CrewMessage {
  id        String    @id @default(cuid())
  crewId    String
  crew      Crew      @relation(fields: [crewId], references: [id], onDelete: Cascade)
  userId    String
  userName  String    @default("")
  body      String
  createdAt DateTime  @default(now())
  editedAt  DateTime?
  deletedAt DateTime?
  // Reply-to вҖ” snapshot of parent so preview stays stable across edits/deletes
  replyToId       String?
  replyToUserId   String?
  replyToUserName String?
  replyToBody     String?

  @@index([crewId, createdAt])
}

model CrewMember {
  id          String   @id @default(cuid())
  crewId      String
  userId      String
  name        String   @default("")
  description String   @default("")
  role        CrewRole @default(MEMBER)
  joinedAt  DateTime @default(now())

  crew Crew @relation(fields: [crewId], references: [id], onDelete: Cascade)

  @@unique([crewId, userId])
  @@index([userId])
}

enum JoinRequestStatus {
  PENDING
  APPROVED
  DECLINED
}

// A user's request to join a crew (the applyвҶ’approve/decline flow). Distinct
// from CrewMember invites: this is member-initiated. One live request per
// (crew,user) вҖ” re-applying after a decline reuses the row (status reset).
model CrewJoinRequest {
  id        String            @id @default(cuid())
  crewId    String
  userId    String
  userName  String            @default("")
  note      String            @default("")
  status    JoinRequestStatus @default(PENDING)
  createdAt DateTime          @default(now())
  decidedAt DateTime?
  decidedBy String?

  crew Crew @relation(fields: [crewId], references: [id], onDelete: Cascade)

  @@unique([crewId, userId])
  @@index([crewId, status])
}

// О“Г¶ГҮО“Г¶ГҮ Friends О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ

enum FriendStatus {
  PENDING
  ACCEPTED
  DECLINED
  BLOCKED
}

model FriendRequest {
  id         String       @id @default(cuid())
  fromId     String
  toId       String
  status     FriendStatus @default(PENDING)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@unique([fromId, toId])
  @@index([toId, status])
  @@index([fromId, status])
}

model FeedItem {
  id          String   @id @default(cuid())
  url         String   @unique
  title       String
  thumbnail   String?
  domain      String
  sourceName  String
  category    String
  heat        Int      @default(0)
  usersInRoom Int      @default(0)
  fetchedAt   DateTime @default(now())
  postedAt    DateTime @default(now())

  @@index([category, heat])
  @@index([fetchedAt])
}

// О“Г¶ГҮО“Г¶ГҮ Game Accounts О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ
// Stores per-user OAuth tokens and cached playcard data for each game integration.
// gameType maps to ModuleType (BUNGIE = Destiny 2, etc.)

model UserGameAccount {
  id            String     @id @default(cuid())
  userId        String
  gameType      ModuleType

  // OAuth
  accessToken   String?
  refreshToken  String?
  tokenExpiry   DateTime?

  // Game identity
  externalId    String?    // e.g. Bungie membershipId
  displayName   String     @default("")
  platform      String     @default("")  // e.g. "pc", "xbox", "psn"

  // Cached playcard О“ГҮГ¶ refreshed on hover if stale (5 min TTL)
  cardData      Json?
  cardCachedAt  DateTime?

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, gameType])
  @@index([userId])
}

// О“Г¶ГҮО“Г¶ГҮ Invites О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ

enum InviteType {
  PLATFORM
  ROOM
  LOBBY
  CREW
  GUEST
}

model Invite {
  id        String     @id @default(cuid())
  token     String     @unique @default(cuid())
  type      InviteType @default(PLATFORM)
  targetId  String?    // roomId, lobbyId, or crewId О“ГҮГ¶ null for PLATFORM
  createdBy String     // userId of creator
  note      String?
  maxUses   Int        @default(1)
  uses      Int        @default(0)
  expiresAt DateTime?
  createdAt DateTime   @default(now())

  @@index([token])
  @@index([createdBy])
}

// О“Г¶ГҮО“Г¶ГҮ Subscriptions (Stripe-backed) О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ

enum SubTier {
  FREE       // Innocent О“ГҮГ¶ default
  INDICTED   // $6/mo О“ГҮГ¶ colored username, video streaming, custom fonts
  FELON      // $14/mo О“ГҮГ¶ above + own up to 3 lobbies
  KINGPIN    // Staff-granted О“ГҮГ¶ unlimited lobbies, all modules
}

model Subscription {
  id                 String   @id @default(cuid())
  userId             String   @unique
  tier               SubTier  @default(FREE)
  stripeCustomerId   String?  @unique
  stripeSubId        String?  @unique  // Stripe subscription ID
  stripePriceId      String?            // Which price they're on
  status             String   @default("inactive")  // active, past_due, canceled, inactive
  currentPeriodEnd   DateTime?
  cancelAtPeriodEnd  Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([userId])
  @@index([stripeCustomerId])
}

// О“Г¶ГҮО“Г¶ГҮ Lobby Paid Tiers О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ
// Lobby owners can create paid subscription tiers that auto-promote members.

model LobbyTier {
  id              String   @id @default(cuid())
  lobbyId         String
  name            String                    // e.g. "VIP", "Patron", "Supporter"
  description     String   @default("")
  priceMonthly    Int                       // cents, e.g. 500 = $5.00
  grantLevel      Int      @default(2)      // roleLevel to auto-assign (1-4, never 5)
  color           String?                   // hex accent for badge display
  stripePriceId   String?  @unique          // Stripe Price ID (created dynamically)
  stripeProductId String?                   // Stripe Product ID
  sortOrder       Int      @default(0)      // display order
  active          Boolean  @default(true)   // soft-disable without deleting
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  lobby       Lobby          @relation(fields: [lobbyId], references: [id], onDelete: Cascade)
  subscribers LobbyTierSub[]

  @@index([lobbyId, active])
}

model LobbyTierSub {
  id                String    @id @default(cuid())
  lobbyTierId       String
  lobbyId           String                // denormalized for fast queries
  userId            String
  stripeSubId       String?   @unique     // Stripe subscription ID
  stripeCustomerId  String?               // Stripe customer (may reuse from platform Subscription)
  status            String    @default("inactive") // active, past_due, canceled, inactive
  currentPeriodEnd  DateTime?
  cancelAtPeriodEnd Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  tier LobbyTier @relation(fields: [lobbyTierId], references: [id], onDelete: Cascade)

  @@unique([lobbyId, userId])             // one active lobby sub per user per lobby
  @@index([userId])
  @@index([stripeSubId])
}

// О“Г¶ГҮО“Г¶ГҮ LFG / Fireteam Board О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ

enum LfgStatus {
  OPEN
  FULL
  CLOSED
  COMPLETED   // host marked the group as having run + finished (feeds reliability/notoriety)
}

model LfgPost {
  id          String    @id @default(cuid())
  lobbyId     String
  userId      String
  userName    String    @default("")
  activity    String    // e.g. "Raid: Crota's End", "Nightfall", "Trials of Osiris"
  description String    @default("")
  maxPlayers  Int       @default(6)
  players     String[]  @default([])  // userId array of joined players
  playerNames String[]  @default([])  // display names parallel array
  status      LfgStatus @default(OPEN)
  platform    String    @default("crossplay")  // pc, xbox, psn, crossplay
  gameMode    String?   // e.g. "solo", "duo", "squad", "zero-build", "ranked", "creative"
  rankTier    String?   // e.g. "Bronze", "Silver", "Gold", "Platinum", "Diamond", "Elite", "Unreal", "Champion"
  region      String?   // e.g. "NAE", "NAW", "EU", "OCE", "ASIA", "BR"
  tags        String[]  @default([])  // ["casual", "competitive", "chill", "sweaty", "mic-required", "no-mic"]
  metadata    Json?     // extensible game-specific data
  // Optional role slots (additive вҖ” flat boards like HD2/Windrose leave these
  // empty and keep join/leave semantics). When roleSlots is non-empty the post
  // is a role-based session: roleSlots[i] is the role name, roleClaims[i] is the
  // userId in that slot ("" = open), roleClaimNames[i] the display name.
  roleSlots      String[] @default([])
  roleClaims     String[] @default([])
  roleClaimNames String[] @default([])
  // Optional scheduled start (The100.io-style "Thursday 8pm" sessions). null =
  // "now / ASAP". timezone is a display label like "EST".
  scheduledFor DateTime?
  scheduledTz  String    @default("")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([lobbyId, status])
  @@index([lobbyId, createdAt])
}

// в”Җв”Җ Fortnite Wishlist в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
model FortniteWishlist {
  id          String   @id @default(cuid())
  userId      String
  cosmeticId  String   // fortnite-api.com item ID
  name        String   @default("")
  type        String   @default("")   // Outfit, Pickaxe, Glider, etc.
  rarity      String   @default("")
  image       String?
  notified    Boolean  @default(false) // has user been notified it's in shop?
  notifiedAt  DateTime?
  createdAt   DateTime @default(now())

  @@unique([userId, cosmeticId])
  @@index([cosmeticId])
  @@index([userId])
}

// О“Г¶ГҮО“Г¶ГҮ Bungie Manifest Cache О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ
// Caches Bungie API responses (Xur inventory, weekly reset, etc.) with TTL

model BungieCache {
  key       String   @id           // e.g. "xur_inventory", "weekly_reset", "nightfall"
  data      Json
  fetchedAt DateTime @default(now())
  expiresAt DateTime
}

// вҖ” Reserved Names вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”
// Blocks lobby IDs and usernames from being claimed. Staff-managed via admin panel.

enum ReservedScope {
  BOTH       // blocks lobbies AND usernames
  LOBBY      // blocks lobby IDs only
  USERNAME   // blocks usernames only
}

model ReservedName {
  id        String        @id @default(cuid())
  name      String        @unique   // lowercase, normalized
  scope     ReservedScope @default(BOTH)
  reason    String        @default("")
  addedBy   String        @default("system")  // userId or "system" for seed
  createdAt DateTime      @default(now())
}

// О“Г¶ГҮО“Г¶ГҮ Events О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ
// Global + lobby-scoped events with promotion pipeline.

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELED
  COMPLETED
}

enum PromotionStatus {
  NONE
  PENDING
  APPROVED
  DENIED
}

model Event {
  id              String          @id @default(cuid())

  // Core
  title           String
  description     String          @default("")
  category        String          @default("")        // free-text: "raid_night", "watch_party", "ban_court", etc.
  coverImageUrl   String?

  // Scheduling
  startsAt        DateTime
  endsAt          DateTime?
  timezone        String          @default("UTC")

  // Scope вҖ” null lobbyId = global event
  lobbyId         String?
  lobby           Lobby?          @relation(fields: [lobbyId], references: [id], onDelete: Cascade)

  // Status
  status          EventStatus     @default(DRAFT)

  // Creator
  createdById     String
  createdByName   String          @default("")

  // Promotion pipeline (lobby events requesting global visibility)
  promotionStatus         PromotionStatus @default(NONE)
  promotionNote           String?         // lobby owner's pitch to staff
  promotionReviewedById   String?
  promotionReviewedByName String?
  promotionReviewedAt     DateTime?
  promotionDenyReason     String?

  // Staff decides per-event whether to fire system:broadcast on publish
  broadcastOnPublish Boolean @default(false)

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([lobbyId, status, startsAt])
  @@index([status, startsAt])
  @@index([createdById])
}

model StaffPost {
  id         String   @id @default(cuid())
  authorId   String
  authorName String   @default("")
  body       String
  pinned     Boolean  @default(false)
  createdAt  DateTime @default(now())

  author User @relation("StaffPostAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([createdAt])
}

// вҖ”вҖ” Push Notification Subscriptions вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Expo (mobile) push tokens. Separate from web push because Expo uses a
// different transport (https://exp.host/--/api/v2/push/send) and opaque
// token strings instead of endpoint+keys.
model ExpoPushToken {
  id         String   @id @default(cuid())
  userId     String
  token      String   @unique
  platform   String?  // "ios" | "android"
  createdAt  DateTime @default(now())
  lastUsedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// в”Җв”Җ Forum в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

enum ForumCategory {
  BUG_REPORT
  FEATURE_REQUEST
  DISCUSSION
  ANNOUNCEMENT
}

model ForumPost {
  id           String        @id @default(cuid())
  title        String
  body         String
  category     ForumCategory @default(DISCUSSION)
  sectionId    String?
  lobbyId      String?
  authorId     String
  authorName   String        @default("")
  pinned       Boolean       @default(false)
  locked       Boolean       @default(false)
  score        Int           @default(0)
  commentCount Int           @default(0)
  tags         Json          @default("[]")
  removedAt    DateTime?
  removedById  String?
  removeReason String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  lobby    Lobby?         @relation(fields: [lobbyId], references: [id], onDelete: Cascade)
  section  ForumSection?  @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  comments ForumComment[]
  votes    ForumVote[]    @relation("PostVotes")
  bookmarks    ForumBookmark[]
  subscriptions ForumSubscription[]
  reports      ForumReport[]

  @@index([lobbyId, createdAt])
  @@index([lobbyId, score])
  @@index([category, createdAt])
  @@index([sectionId, createdAt])
  @@index([sectionId, score])
  @@index([score])
  @@index([pinned, createdAt])
  @@index([authorId])
  @@index([removedAt])
}

model ForumComment {
  id         String   @id @default(cuid())
  postId     String
  parentId   String?
  depth      Int      @default(0)
  path       String   @default("")
  authorId   String
  authorName String   @default("")
  body       String
  score      Int      @default(0)
  removedAt    DateTime?
  removedById  String?
  removeReason String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  post     ForumPost      @relation(fields: [postId], references: [id], onDelete: Cascade)
  parent   ForumComment?  @relation("CommentTree", fields: [parentId], references: [id], onDelete: Cascade)
  children ForumComment[] @relation("CommentTree")
  votes    ForumVote[]    @relation("CommentVotes")
  reports  ForumReport[]

  @@index([postId, createdAt])
  @@index([parentId])
  @@index([postId, path])
  @@index([removedAt])
}

model ForumVote {
  id        String  @id @default(cuid())
  userId    String
  postId    String?
  commentId String?
  value     Int     // +1 or -1

  post    ForumPost?    @relation("PostVotes", fields: [postId], references: [id], onDelete: Cascade)
  comment ForumComment? @relation("CommentVotes", fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@unique([userId, commentId])
  @@index([postId])
  @@index([commentId])
}

// в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
// в”Җв”Җ DESTINY META-GAME LAUNCHER в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ

enum ChallengeScope {
  GLOBAL
  LOBBY
  CREW
  TOURNAMENT
}

enum ChallengeStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  FAILED
  ABANDONED
}

enum TournamentFormat {
  LEADERBOARD
  BRACKET
  BRACKET_DOUBLE
  ROUND_ROBIN
  CHALLENGE_RACE
}

enum TournamentStatus {
  REGISTRATION
  ACTIVE
  COMPLETED
  CANCELED
}

enum TournamentEntryType {
  SOLO
  CREW
}

enum MatchStatus {
  PENDING       // waiting for previous round to finish
  READY         // both entries known, can start
  LIVE          // match started (someone marked it live)
  REPORTED      // result reported, awaiting confirmation
  CONFIRMED     // result final, winner advanced
  DISPUTED      // conflicting reports, admin needed
  CANCELED      // admin canceled
}

// в”Җв”Җ Challenge definition вҖ” reusable template в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

model ChallengeDefinition {
  id            String          @id @default(cuid())

  title         String
  description   String          @default("")
  iconUrl       String?
  category      String          @default("")     // crucible, pve, raid, seasonal
  difficulty    Int             @default(1)       // 1-5

  scope         ChallengeScope  @default(GLOBAL)
  lobbyId       String?
  crewId        String?
  createdById   String

  // Objective spec вҖ” JSON DSL array
  objectives    Json                              // Array of ObjectiveSpec
  requireAll    Boolean         @default(true)
  requireCount  Int?

  // Activity-level modifier requirements. Modifiers are Bungie modifier
  // hashes (strings). For a completion to count, the activity's
  // modifierHashes set must include ALL of these. Empty = no modifier req.
  requiredModifiers     Json    @default("[]")
  // Difficulty tier minimum (1=Normal, 2=Hero, 3=Legend, 4=Master, 5=GM).
  // Null = any difficulty counts.
  requireDifficultyTier Int?
  // Optional party size constraints (Bungie returns fireteam composition
  // in PGCR вҖ” fireteamIds.length).
  minPartySize Int?
  maxPartySize Int?

  // Chain support
  chainParentId String?
  chainOrder    Int             @default(0)

  // Recurrence
  isRecurring   Boolean         @default(false)
  recurSchedule String?                          // weekly_tuesday, daily

  // Rewards
  notorietyReward   Int         @default(0)
  paperReward       Int         @default(0)
  crewRepReward     Int         @default(0)
  badgeId           String?

  // Slice D: optional source-tag вҖ” used by helldiversWorker to mark MO challenges
  // and dedupe on the MO id. Null for normal manually-authored challenges.
  kind          String?
  externalRef   String?

  status        ChallengeStatus @default(DRAFT)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  instances     ChallengeInstance[]
  chainParent   ChallengeDefinition?  @relation("ChallengeChain", fields: [chainParentId], references: [id])
  chainSteps    ChallengeDefinition[] @relation("ChallengeChain")

  @@index([scope, status])
  @@index([lobbyId, status])
  @@index([category, status])
  @@index([kind, externalRef])
}

// в”Җв”Җ Challenge instance вҖ” time-bound run of a definition в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

model ChallengeInstance {
  id              String           @id @default(cuid())
  definitionId    String

  startsAt        DateTime
  endsAt          DateTime?
  status          ChallengeStatus  @default(ACTIVE)

  createdAt       DateTime         @default(now())

  definition      ChallengeDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  enrollments     ChallengeEnrollment[]

  @@index([definitionId, status])
  @@index([status, startsAt])
  @@index([status, endsAt])
}

// в”Җв”Җ Challenge enrollment вҖ” player's progress on an instance в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

model ChallengeEnrollment {
  id            String           @id @default(cuid())
  instanceId    String
  userId        String

  status        EnrollmentStatus @default(ACTIVE)

  // Progress per objective: { "obj_1": { current: 35, target: 50, completed: false } }
  progress      Json             @default("{}")

  lastCheckedAt              DateTime?
  lastActivityInstanceId     String?

  completedAt   DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  instance      ChallengeInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@unique([instanceId, userId])
  @@index([userId, status])
  @@index([status, lastCheckedAt])
}

// в”Җв”Җ Activity log вҖ” processed Bungie match history в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

model BungieActivityLog {
  id                 String   @id @default(cuid())
  userId             String
  membershipId       String
  activityInstanceId String                       // Bungie PGCR instanceId

  activityHash       String
  activityName       String   @default("")
  mode               Int
  modeName           String   @default("")
  period             DateTime

  kills              Int      @default(0)
  deaths             Int      @default(0)
  assists            Int      @default(0)
  score              Int      @default(0)
  standing           Int      @default(0)         // 0=Victory, 1=Defeat
  completed          Boolean  @default(false)
  duration           Int      @default(0)         // seconds

  weaponKills        Json     @default("[]")      // [{ hash, name, kills }]
  subclassHash       String?
  fireteamIds        String[] @default([])
  // Activity modifiers active during this run, sourced from activity manifest.
  modifierHashes     Json     @default("[]")      // ["123456", "789012"]
  difficultyTier     Int?                          // 1-5 if known

  createdAt          DateTime @default(now())

  @@unique([userId, activityInstanceId])
  @@index([userId, period])
  @@index([userId, mode, period])
}

// в”Җв”Җ Chess activity log вҖ” Lichess + Chess.com game history в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
//
// Parallel to BungieActivityLog. Worker polls users' linked chess accounts
// (~5 min cadence) and ingests each finished game once. Challenge worker
// reads from here for chess-specific objectives (wins, streaks, rating
// climb, opening-specific clears, time-control limits).
model ChessActivityLog {
  id            String   @id @default(cuid())
  userId        String
  provider      String   // "LICHESS" | "CHESS_COM"
  externalGameId String  // provider-prefixed unique game id
  username      String   // the username this game was played under (for audit)

  // Game metadata
  playedAt      DateTime
  timeControl   String   // "bullet" | "blitz" | "rapid" | "classical" | "correspondence"
  initialSeconds Int?    // base time in seconds
  incrementSeconds Int?  // increment per move
  rated         Boolean  @default(true)
  variant       String   @default("standard") // "standard" | "chess960" | "atomic" | "antichess" | ...

  // Player state
  color         String   // "WHITE" | "BLACK"
  rating        Int?     // player's rating going into the game
  ratingDiff    Int?     // rating delta after (positive = gained)
  opponent      String?  // opponent username
  opponentRating Int?

  // Outcome
  result        String   // "WIN" | "LOSS" | "DRAW"
  termination   String?  // "normal" | "resignation" | "timeout" | "checkmate" | "stalemate" | "agreement"
  movesCount    Int?     // ply count

  // Opening (ECO + name when available)
  ecoCode       String?  // e.g. "B01" for Scandinavian Defense
  openingName   String?  // e.g. "Sicilian Defense: Najdorf"

  createdAt     DateTime @default(now())

  @@unique([userId, externalGameId])
  @@index([userId, playedAt])
  @@index([userId, timeControl, playedAt])
  @@index([userId, result])
}


// в”Җв”Җ Tournament в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

model Tournament {
  id              String             @id @default(cuid())

  title           String
  description     String             @default("")
  iconUrl         String?

  format          TournamentFormat   @default(LEADERBOARD)
  entryType       TournamentEntryType @default(SOLO)

  lobbyId         String?
  createdById     String

  scoringRule     Json                             // { type, definitionId, stat, ... }

  registrationOpensAt  DateTime
  startsAt             DateTime
  endsAt               DateTime
  status               TournamentStatus @default(REGISTRATION)

  maxEntries      Int              @default(100)
  minEntries      Int              @default(2)

  rewards         Json             @default("[]")

  // CHALLENGE_RACE: pool of challenge definition IDs that count toward this race.
  // Empty array means "any challenge in this lobby counts". Each completion
  // awards `pointsPerCompletion` to the entry's score.
  challengePoolIds  Json     @default("[]")
  pointsPerCompletion Int    @default(100)
  pointsToWin       Int?              // if set, first entry to reach this wins
  raceWinCondition  String?            // "THRESHOLD" | "DEADLINE" | "ALL_COMPLETED"

  // Featured-strip override. Null = AUTO (show in strip from 24h before startsAt).
  // "UPCOMING" forces upcoming-banner from creation. "ACTIVE" forces active-banner.
  featuredMode    String?

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  entries         TournamentEntry[]
  matches         TournamentMatch[]

  @@index([status, startsAt])
  @@index([lobbyId, status])
}

model TournamentEntry {
  id            String   @id @default(cuid())
  tournamentId  String

  userId        String?
  crewId        String?
  displayName   String   @default("")

  score         Float    @default(0)
  rank          Int?

  scoreBreakdown Json    @default("{}")

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tournament    Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, userId])
  @@unique([tournamentId, crewId])
  @@index([tournamentId, score])
}

// в”Җв”Җ Tournament BRACKET match вҖ” single-elim node в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// Each match belongs to a round + bracket position. Winners advance via
// nextMatchId вҖ” a tree where leaves are first-round matches and the root
// is the final. Reporting is two-step: a player (or admin) reports the
// result, the opponent (or admin) confirms. Confirm auto-advances the
// winner into nextMatch's empty slot. Disputed reports require admin.

model TournamentMatch {
  id              String     @id @default(cuid())
  tournamentId    String
  round           Int        // 1 = first round
  bracketPosition Int        // ordinal within the round (0-indexed)

  entryAId        String?    // TournamentEntry.id, may be null for byes
  entryBId        String?

  scoreA          Int?
  scoreB          Int?
  winnerEntryId   String?

  status          MatchStatus @default(PENDING)

  reportedById    String?
  reportedAt      DateTime?
  confirmedAt     DateTime?

  scheduledAt     DateTime?
  liveAt          DateTime?
  twitchLogin     String?    // optional caster handle to embed when LIVE
  notes           String?

  nextMatchId     String?
  nextMatch       TournamentMatch?  @relation("Advance", fields: [nextMatchId], references: [id])
  prevMatches     TournamentMatch[] @relation("Advance")

  // Double-elimination support: bracketSide tags WINNERS / LOSERS / GRAND.
  // loserMatchId points to the losers-bracket match the LOSER drops into
  // when this match is in the WINNERS bracket. Null for ROUND_ROBIN +
  // single-elim BRACKET (where loser is just eliminated).
  bracketSide     String?           // "WINNERS" | "LOSERS" | "GRAND" вҖ” null for single-elim/round-robin
  loserMatchId    String?
  loserMatch      TournamentMatch?  @relation("LoserDrop", fields: [loserMatchId], references: [id])
  loserDrops      TournamentMatch[] @relation("LoserDrop")

  // Bungie auto-detect (Destiny 2 only). When both participants appear in
  // the same BungieActivityLog row during the match window, we auto-confirm
  // with the real scores from Bungie's PGCR. expectedActivityHash optionally
  // restricts to a specific mode/playlist (Trials, Comp, etc.).
  expectedActivityHash String?
  pgcrInstanceId       String?
  autoDetectedAt       DateTime?

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  tournament      Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, round, bracketPosition])
  @@index([tournamentId, status])
  @@index([nextMatchId])
}

// в”Җв”Җ Badges в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

model ChallengeBadge {
  id          String   @id @default(cuid())
  name        String
  description String   @default("")
  iconUrl     String   @default("")
  rarity      Int      @default(1)
  createdAt   DateTime @default(now())
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  earnedAt  DateTime @default(now())

  @@unique([userId, badgeId])
  @@index([userId])
}

// вҖ”вҖ” Outreach CRM вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”

enum OutreachStatus {
  LEAD
  CONTACTED
  REPLIED
  IN_PROGRESS
  PARTNERED
  DECLINED
  STALE
}

enum OutreachCategory {
  GAME_STUDIO
  ESPORTS_ORG
  CONTENT_CREATOR
  BRAND_SPONSOR
  MEDIA
  COMMUNITY
  PLATFORM
  TRADING
