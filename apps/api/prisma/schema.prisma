// в”Җв”Җ Paper Trading в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// Virtual trading engine: users paper-trade crypto with fake money in lobbies.
// Competitions add time-bounded tournaments with leaderboards.

enum OrderSide {
  BUY
  SELL
}

enum OrderType {
  MARKET
  LIMIT
  STOP
}

enum OrderStatus {
  PENDING    // limit/stop waiting to fill
  FILLED
  CANCELLED
}

enum PositionStatus {
  OPEN
  CLOSED
}

enum CompetitionStatus {
  UPCOMING
  ACTIVE
  ENDED
}

enum PaperAccountMode {
  CASUAL    // $100K start вҖ” for fun, no Notoriety, low Paper conversion
  RANKED    // $1K start вҖ” counts toward Notoriety, 10Г— Paper conversion, leaderboards split
}

enum VoiceRoomMode {
  OPEN         // anyone in the room can publish mic/camera/screen
  QUEUED       // raise hand, mod approves before publishing is allowed
  LISTEN_ONLY  // only mods + owner can publish; queue is disabled
}

model PaperAccount {
  id           String   @id @default(cuid())
  userId       String
  lobbyId      String
  competitionId String?
  mode         PaperAccountMode @default(CASUAL)

  cashBalance  Float    @default(100000) // starting + remaining cash
  startBalance Float    @default(100000) // frozen at creation for P&L calc
  realizedPnl  Float    @default(0)      // locked-in profit/loss from closed positions
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  positions    PaperPosition[]
  orders       PaperOrder[]

  @@unique([userId, lobbyId, competitionId, mode])
  @@index([lobbyId])
  @@index([competitionId])
  @@index([userId])
  @@index([lobbyId, mode])
}

model PaperPosition {
  id           String         @id @default(cuid())
  accountId    String
  account      PaperAccount   @relation(fields: [accountId], references: [id], onDelete: Cascade)

  symbol       String         // e.g. "BTCUSDT"
  side         OrderSide      // BUY = long, SELL = short
  quantity     Float          // amount of asset
  entryPrice   Float          // average entry price
  entryValue   Float          // quantity * entryPrice at open
  exitPrice    Float?         // set when closed
  realizedPnl  Float?         // profit/loss when closed
  status       PositionStatus @default(OPEN)

  // Optional auto-exit triggers. The 5s position worker auto-closes the
  // position when the live mark price crosses one of these. closeReason
  // records whether a close was manual / SL hit / TP hit for chat chip
  // annotation.
  stopLoss     Float?
  takeProfit   Float?
  closeReason  String?        // "MANUAL" | "STOP_LOSS" | "TAKE_PROFIT"

  openedAt     DateTime       @default(now())
  closedAt     DateTime?

  @@index([accountId, status])
  @@index([symbol])
}

model PaperOrder {
  id           String       @id @default(cuid())
  accountId    String
  account      PaperAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  symbol       String
  side         OrderSide
  orderType    OrderType    @default(MARKET)
  quantity     Float        // asset quantity
  price        Float?       // limit/stop price (null for market)
  filledPrice  Float?       // actual execution price
  filledAt     DateTime?
  status       OrderStatus  @default(PENDING)
  createdAt    DateTime     @default(now())

  @@index([accountId])
  @@index([symbol, status])
}

model TradingCompetition {
  id           String            @id @default(cuid())
  lobbyId      String
  name         String            @default("Trading Competition")
  description  String            @default("")
  startBalance Float             @default(100000)
  startTime    DateTime
  endTime      DateTime
  status       CompetitionStatus @default(UPCOMING)
  createdById  String
  createdAt    DateTime          @default(now())

  @@index([lobbyId, status])
  @@index([startTime])
}

// в”Җв”Җ Paper Economy в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// Virtual currency earned through gameplay, spent in store/marketplace/tournaments.

enum PaperTxType {
  EARN_FAKEOUT        // profit from FakeOut paper trading
  EARN_CHALLENGE      // challenge/tournament completion
  EARN_DAILY          // daily login bonus
  EARN_TRADE_SOLD     // sold item on marketplace
  EARN_GIFT           // received from another user or system
  EARN_COMPETITION    // competition prize payout
  SPEND_STORE         // purchased from store
  SPEND_MARKET        // purchased from marketplace
  SPEND_TOURNAMENT    // tournament buy-in
  SPEND_GIFT          // gifted to another user
  SPEND_UNLOCK        // unlocked gated area/feature
  ADJUSTMENT          // admin adjustment
  POKER_BUYIN         // poker table buy-in
  POKER_WIN           // poker hand winnings
  POKER_CASHOUT       // poker table cash-out
}

model PaperTransaction {
  id          String      @id @default(cuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        PaperTxType
  amount      Int         // positive = earned, negative = spent
  balance     Int         // balance AFTER this transaction (running total)
  description String      @default("")
  refId       String?     // optional reference (itemId, listingId, competitionId, etc.)
  createdAt   DateTime    @default(now())

  @@index([userId, createdAt])
  @@index([type])
}

// в”Җв”Җ Windrose Bounty Board в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// Players post Paper-denominated bounties on in-game targets. A hunter
// submits proof (text + optional image/clip URL), the poster confirms or
// rejects, Paper settles. Escrow is held on the poster (deducted at post,
// refunded on cancel, paid out to claimant on settle). In-game handles are
// free-text вҖ” we can't verify game identity, so the system relies on the
// poster's manual confirmation.

enum BountyStatus {
  OPEN        // posted, awaiting claim
  CLAIMED     // someone submitted proof, awaiting poster confirmation
  SETTLED     // poster confirmed вҖ” Paper released to claimant
  CANCELLED   // poster cancelled while OPEN вҖ” Paper refunded
}

model WindroseBounty {
  id            String       @id @default(cuid())
  lobbyId       String       @default("windrose")
  posterId      String       // Weered userId of the poster
  posterName    String       // snapshot of poster's display name
  targetHandle  String       // in-game handle of the mark
  targetServer  String?      // optional вҖ” which server the mark plays on
  amount        Int          // Paper escrowed at creation
  reason        String       @default("")
  status        BountyStatus @default(OPEN)
  claimantId    String?      // Weered userId of the hunter
  claimantName  String?      // snapshot of hunter's display name
  proofNote     String?      // hunter's submitted text
  proofImageUrl String?      // optional вҖ” imgur, gyazo, twitch clip, youtube, etc.
  createdAt     DateTime     @default(now())
  claimedAt     DateTime?
  settledAt     DateTime?
  cancelledAt   DateTime?

  @@index([lobbyId, status, createdAt])
  @@index([posterId, createdAt])
  @@index([claimantId])
}

// в”Җв”Җ Store Items в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// Items that can be purchased from the store or traded between users.

enum ItemRarity {
  COMMON
  UNCOMMON
  RARE
  EPIC
  LEGENDARY
}

enum ItemCategory {
  AVATAR       // profile avatar/frame
  BADGE        // profile badge
  TITLE        // custom title display
  KEY          // unlocks gated area or feature
  CONSUMABLE   // one-time use (e.g. tournament entry token)
  COLLECTIBLE  // purely collectible, tradeable
  ORNAMENT     // lobby/room decoration
}

model StoreItem {
  id            String       @id @default(cuid())
  name          String
  description   String       @default("")
  category      ItemCategory
  rarity        ItemRarity   @default(COMMON)
  imageUrl      String?
  price         Int          // Paper cost
  maxSupply     Int?         // null = unlimited, number = limited mint
  totalMinted   Int          @default(0)
  available     Boolean      @default(true)
  featured      Boolean      @default(false) // show in featured section
  weeklyRotation Boolean     @default(false) // part of weekly rotating stock
  rotationWeek  Int?         // which ISO week this item is available (null = always)
  // Items with utility
  unlockTarget  String?      // e.g. lobbyId, roomId, or feature flag this item unlocks
  metadata      Json?        // flexible data: CSS styles, animation, duration, etc.
  createdAt     DateTime     @default(now())

  instances     UserItem[]

  @@index([available, featured])
  @@index([category])
  @@index([rarity])
}

model UserItem {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  itemId      String
  item        StoreItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  acquiredAt  DateTime  @default(now())
  equipped    Boolean   @default(false)  // is this item currently active/displayed
  consumed    Boolean   @default(false)  // for consumables: has it been used
  consumedAt  DateTime?
  // Trade provenance
  acquiredFrom String?  // "store", "market", "drop", "gift", userId
  acquiredPrice Int?    // what they paid (Paper)
  mintNumber  Int?      // #37 of 50 вҖ” for limited items

  @@index([userId, equipped])
  @@index([itemId])
  @@unique([userId, itemId, mintNumber])
}

// в”Җв”Җ Marketplace в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// User-to-user item trading with Paper currency.

enum ListingStatus {
  ACTIVE
  SOLD
  CANCELLED
  EXPIRED
}

model MarketListing {
  id          String        @id @default(cuid())
  sellerId    String
  seller      User          @relation("MarketSeller", fields: [sellerId], references: [id], onDelete: Cascade)
  userItemId  String        // the UserItem being sold
  itemId      String        // denormalized StoreItem id for search
  itemName    String        @default("")  // denormalized for display
  itemRarity  ItemRarity    @default(COMMON)
  price       Int           // asking price in Paper
  status      ListingStatus @default(ACTIVE)
  buyerId     String?       // who bought it
  soldAt      DateTime?
  expiresAt   DateTime?     // optional auto-expire
  createdAt   DateTime      @default(now())

  @@index([status, itemId])
  @@index([sellerId])
  @@index([status, createdAt])
  @@index([itemRarity, status])
}

// в”Җв”Җ Mods в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// Lobby-scoped mod catalog. Nexus is the source of truth; we
// cache metadata and layer crew-scoped intelligence on top.
// Discovery is intentionally subtle вҖ” no rails tab, just chat
// embeds, profile lines, and slash commands.

enum ModSource {
  NEXUS
  CURSEFORGE
  MODDB
  STEAM_WORKSHOP
}

enum ModCrewRole {
  RECOMMENDED
  REQUIRED
  BANNED
}

model Mod {
  id            String     @id @default(cuid())
  source        ModSource  @default(NEXUS)
  sourceId      String
  gameSlug      String     @default("windrose")
  name          String
  summary       String     @default("")
  description   String     @default("")
  author        String     @default("")
  category      String     @default("")
  thumbnailUrl  String?
  sourceUrl     String?
  endorsements  Int        @default(0)
  downloads     Int        @default(0)
  sourceUpdatedAt DateTime?
  fetchedAt     DateTime   @default(now())

  excluded      Boolean    @default(false)
  excludedNote  String?
  excludedAt    DateTime?

  versions      ModVersion[]
  crewMods      CrewMod[]
  installs      UserModInstall[]

  @@unique([source, sourceId])
  @@index([gameSlug, endorsements])
  @@index([gameSlug, sourceUpdatedAt])
  @@index([excluded])
}

model ModVersion {
  id         String    @id @default(cuid())
  modId      String
  version    String
  fileId     String?
  fileName   String?
  sizeKb     Int       @default(0)
  compat     String    @default("")
  changelog  String    @default("")
  uploadedAt DateTime?
  isPrimary  Boolean   @default(false)

  mod Mod @relation(fields: [modId], references: [id], onDelete: Cascade)

  @@index([modId, uploadedAt])
}

model CrewMod {
  id        String      @id @default(cuid())
  crewId    String
  modId     String
  role      ModCrewRole @default(RECOMMENDED)
  note      String      @default("")
  addedById String
  addedAt   DateTime    @default(now())

  mod Mod @relation(fields: [modId], references: [id], onDelete: Cascade)

  @@unique([crewId, modId])
  @@index([crewId])
}

model CrewModLoadout {
  id          String   @id @default(cuid())
  crewId      String
  name        String
  description String   @default("")
  modIds      String[] @default([])
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([crewId])
}

model UserModInstall {
  id          String   @id @default(cuid())
  userId      String
  modId       String
  version     String   @default("")
  installedAt DateTime @default(now())

  mod Mod @relation(fields: [modId], references: [id], onDelete: Cascade)

  @@unique([userId, modId])
  @@index([userId])
}


// в”Җв”Җв”Җ Campaign Ledger (D&D campaign state) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// Campaign = a persistent tabletop run, anchored to a room (or later a
// multi-room party). Holds shared gold, loot/xp ledger, session log,
// NPC encounter index, plot threads, world-note wiki. Spec-B character
// sheets will replace `characterName` on CampaignMember with an FK.

enum LedgerEntryType {
  GOLD
  ITEM
  XP
}

enum NpcEncounterStatus {
  ALIVE
  DEAD
  HOSTILE
  ALLIED
  UNKNOWN
}

enum PlotThreadStatus {
  OPEN
  CLOSED
  DORMANT
}

model Campaign {
  id          String   @id @default(cuid())
  roomId      String
  name        String
  description String   @default("")
  partyGold   Int      @default(0)
  dmUserId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members     CampaignMember[]
  ledger      LedgerEntry[]
  sessions    SessionLog[]
  npcs        NpcEncounter[]
  threads     PlotThread[]
  notes       WorldNote[]
  characters  Character[]

  @@index([roomId])
  @@index([dmUserId])
}

model CampaignMember {
  id            String   @id @default(cuid())
  campaignId    String
  userId        String
  characterName String   @default("")
  joinedAt      DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, userId])
  @@index([userId])
}

model LedgerEntry {
  id               String          @id @default(cuid())
  campaignId       String
  type             LedgerEntryType
  delta            Int             @default(0)
  description      String          @default("")
  awardedToUserId  String?
  createdAt        DateTime        @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, createdAt])
  @@index([campaignId, type])
}

model SessionLog {
  id            String   @id @default(cuid())
  campaignId    String
  sessionNumber Int
  dmUserId      String
  body          String   @default("")
  createdAt     DateTime @default(now())

  campaign Campaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  encounters NpcEncounter[]

  @@unique([campaignId, sessionNumber])
  @@index([campaignId, createdAt])
}

model NpcEncounter {
  id                 String             @id @default(cuid())
  campaignId         String
  name               String
  firstMetSessionId  String?
  status             NpcEncounterStatus @default(UNKNOWN)
  notes              String             @default("")
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  campaign       Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  firstMetSession SessionLog? @relation(fields: [firstMetSessionId], references: [id], onDelete: SetNull)

  @@index([campaignId])
  @@index([campaignId, status])
}

model PlotThread {
  id         String           @id @default(cuid())
  campaignId String
  title      String
  body       String           @default("")
  status     PlotThreadStatus @default(OPEN)
  createdAt  DateTime         @default(now())
  closedAt   DateTime?

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, status])
  @@index([campaignId, createdAt])
}

model WorldNote {
  id         String   @id @default(cuid())
  campaignId String
  parentId   String?
  title      String
  body       String   @default("")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  campaign Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  parent   WorldNote?  @relation("WorldNoteHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children WorldNote[] @relation("WorldNoteHierarchy")

  @@index([campaignId])
  @@index([campaignId, parentId])
}

// в”Җв”Җв”Җ Character Sheets (D&D 5e) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// Per-player character data вҖ” ability scores, vitals, spells, inventory,
// notes. Modifiers and proficiency bonus are derived server-side on read,
// not stored. campaignId is a soft FK (string only) so this model can be
// created independently of the campaign-ledger work; the relation will be
// wired up at integration time.

model Character {
  id          String  @id @default(cuid())
  name        String
  className   String  @default("")
  level       Int     @default(1)
  race        String  @default("")
  alignment   String  @default("")
  ownerUserId String
  campaignId  String?
  campaign    Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  // Optional room scoping. The DM (room owner) sees every character whose
  // roomId matches their room; players see only their own.
  roomId      String?

  // Ability scores (raw)
  str Int @default(10)
  dex Int @default(10)
  con Int @default(10)
  int Int @default(10)
  wis Int @default(10)
  cha Int @default(10)

  // Vitals вҖ” HP max and AC are user-entered, not auto-computed.
  hpCurrent Int    @default(0)
  hpMax     Int    @default(0)
  hpTemp    Int    @default(0)
  ac        Int    @default(10)
  speed     Int    @default(30)
  hitDice   String @default("")

  // Save proficiencies вҖ” array of "STR"|"DEX"|"CON"|"INT"|"WIS"|"CHA".
  saveProfs String[] @default([])
  // Skill proficiencies вҖ” JSON: [{ skill: "perception", expertise: false }, ...]
  skillProfs Json @default("[]")

  // Spell slots вҖ” JSON: { "1": { current, max }, "2": {...}, ... }.
  spellSlots Json @default("{}")
  // Spell list вҖ” JSON: [{ name, level }]. No full spell data here; that
  // lives in the Compendium.
  spells Json @default("[]")

  // Inventory вҖ” JSON: [{ name, qty, equipped, attuned, notes }].
  inventory Json @default("[]")

  // Coin
  cp Int @default(0)
  sp Int @default(0)
  ep Int @default(0)
  gp Int @default(0)
  pp Int @default(0)

  // Features & traits вҖ” JSON: [{ title, body, source }] where source is
  // "race"|"class"|"feat"|"background"|"other".
  features Json @default("[]")

  // Click-to-roll attacks вҖ” JSON: [{ name, expression, damage, notes }].
  attacks Json @default("[]")

  // Notes вҖ” three buckets, all on the model so the DM doesn't need a
  // separate join to read DM-private content.
  notesDM     String @default("")
  notesPlayer String @default("")
  notesParty  String @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerUserId])
  @@index([roomId])
  @@index([campaignId])
}

// в”Җв”Җ Tactical Map (D&D Battle Map) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
enum MapTokenKind {
  PC
  NPC
  MONSTER
}

model TacticalMap {
  id           String   @id @default(cuid())
  roomId       String
  name         String   @default("Untitled Map")
  imageUrl     String
  widthPx      Int
  heightPx     Int
  gridSize     Int      @default(50)
  gridColor    String   @default("#000000")
  gridOpacity  Float    @default(0.35)
  gridEnabled  Boolean  @default(true)
  fogEnabled   Boolean  @default(true)
  createdById  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tokens     MapToken[]
  fogReveals MapFogReveal[]

  @@index([roomId])
}

model MapToken {
  id          String       @id @default(cuid())
  mapId       String
  name        String       @default("Token")
  color       String       @default("#C4A55A")
  imageUrl    String?
  sizeCells   Int          @default(1)
  x           Float        @default(0)
  y           Float        @default(0)
  z           Int          @default(0)
  hp          Int          @default(0)
  hpMax       Int          @default(0)
  hpVisible   Boolean      @default(true)
  ownerId     String?
  hidden      Boolean      @default(false)
  kind        MapTokenKind @default(PC)
  combatantId String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  map TacticalMap @relation(fields: [mapId], references: [id], onDelete: Cascade)

  @@index([mapId])
}

model MapFogReveal {
  id    String @id @default(cuid())
  mapId String
  x     Int
  y     Int

  map TacticalMap @relation(fields: [mapId], references: [id], onDelete: Cascade)

  @@unique([mapId, x, y])
  @@index([mapId])
}

// в”Җв”Җ Helldivers 2 вҖ” Loadout Sharer (Slice C) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// Community library of HD2 loadouts. Each loadout = primary + secondary +
// throwable + armor + helmet (opt) + 4 stratagems, named, faction-tagged,
// shareable via slug, voted on by the community.

// Fire Mission drill (HLL artillery arcade): one row per user, best run only.
model HllArtyScore {
  id        String   @id @default(cuid())
  userId    String   @unique
  name      String
  score     Int
  shots     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([score])
}

// Stratagem Hero arcade: one row per user, their best run. Upserted only on
// improvement, so the leaderboard is personal-bests, not spam.
model HelldiversStratScore {
  id        String   @id @default(cuid())
  userId    String   @unique
  name      String
  score     Int
  rounds    Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([score])
}

model HelldiversLoadout {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  authorId    String
  primary     String
  secondary   String
  throwable   String
  armor       String
  helmet      String?
  stratagem1  String
  stratagem2  String
  stratagem3  String
  stratagem4  String
  faction     String   // TERMINIDS | AUTOMATONS | ILLUMINATE | ANY
  difficulty  String?
  role        String?
  upvotes     Int      @default(0)
  downvotes   Int      @default(0)
  views       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  author      User     @relation(fields: [authorId], references: [id])
  votes       HelldiversLoadoutVote[]

  @@index([faction])
  @@index([upvotes])
}

model HelldiversLoadoutVote {
  id         String   @id @default(cuid())
  loadoutId  String
  userId     String
  value      Int      // +1 or -1
  createdAt  DateTime @default(now())
  loadout    HelldiversLoadout @relation(fields: [loadoutId], references: [id], onDelete: Cascade)

  @@unique([loadoutId, userId])
}


// в”Җв”Җ WINDROSE BUILD SHOWCASE в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// Community-uploaded build screenshots with metadata, voting, comments,
// saves, and reports. The centerpiece social surface for the Windrose
// vertical. Image storage: WebP-converted вүӨ1MB primary + вүӨ80KB thumbnail
// per file, served from /builds/* with immutable cache.

model WindroseBuild {
  id           String   @id @default(cuid())
  slug         String   @unique
  title        String
  description  String?  @db.Text

  authorId     String
  author       User     @relation(fields: [authorId], references: [id])

  // Media вҖ” JSON array of { url, thumbUrl, width, height, dominantColor, order }
  // Capped at 3 images per build server-side. dominantColor is a #RRGGBB hex
  // used as a placeholder background while the image lazy-loads.
  images       Json     @default("[]")
  // Primary thumbnail, denormalized for grid card render performance.
  thumbnailUrl String?
  primaryColor String?  // dominant color of the primary image, #RRGGBB

  // Categorization
  biome        String?  // PLAINS | COAST | CLIFFS | SWAMP | CAVE | MOUNTAIN | ISLAND
  buildType    String?  // SHIP | DOCK | FORTRESS | TAVERN | HIDEOUT | OUTPOST | BRIDGE | MISC
  difficulty   String?  // BEGINNER | INTERMEDIATE | ADVANCED | MASTERWORK
  shipClass    String?  // SLOOP | BRIG | GALLEON | FRIGATE вҖ” only when buildType=SHIP
  tags         String[] @default([])

  // Optional metadata users can fill in
  partsCount     Int?
  inGameLocation String?

  // Social
  upvotes      Int      @default(0)
  downvotes    Int      @default(0)
  views        Int      @default(0)
  saveCount    Int      @default(0)

  // Curation
  featured     Boolean  @default(false)
  featuredAt   DateTime?
  // PENDING | APPROVED | REMOVED. First post auto-APPROVED unless prior reports.
  moderationStatus String @default("APPROVED")

  // Author opt-ins
  watermarked  Boolean  @default(false)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  votes        WindroseBuildVote[]
  comments     WindroseBuildComment[]
  saves        WindroseBuildSave[]
  reports      WindroseBuildReport[]

  @@index([biome])
  @@index([buildType])
  @@index([upvotes])
  @@index([featured, featuredAt])
  @@index([authorId])
  @@index([moderationStatus])
}

model WindroseBuildVote {
  id        String   @id @default(cuid())
  buildId   String
  userId    String
  value     Int      // +1 or -1
  createdAt DateTime @default(now())
  build     WindroseBuild @relation(fields: [buildId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id])
  @@unique([buildId, userId])
  @@index([userId])
}

model WindroseBuildComment {
  id        String   @id @default(cuid())
  buildId   String
  userId    String
  body      String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  build     WindroseBuild @relation(fields: [buildId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id])
  @@index([buildId, createdAt])
}

model WindroseBuildSave {
  id        String   @id @default(cuid())
  buildId   String
  userId    String
  createdAt DateTime @default(now())
  build     WindroseBuild @relation(fields: [buildId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id])
  @@unique([buildId, userId])
  @@index([userId])
}

model WindroseBuildReport {
  id        String   @id @default(cuid())
  buildId   String
  userId    String
  reason    String   // SPAM | NSFW | THEFT | OFFENSIVE | OTHER
  note      String?
  status    String   @default("OPEN")  // OPEN | REVIEWED | DISMISSED
  createdAt DateTime @default(now())
  build     WindroseBuild @relation(fields: [buildId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id])
  @@index([status])
}

// в”Җв”Җ Flair: equippable account ornaments earned from tournaments + contests в”Җв”Җ

enum FlairKind {
  BADGE        // small icon shown next to name
  BANNER       // wide image shown on profile / member card
  NAMEPLATE    // styled name display (color, glow)
}

enum FlairSource {
  MANUAL          // staff-assigned
  TOURNAMENT      // earned by winning a tournament
  CONTEST         // earned by winning a flair design contest
  ACHIEVEMENT     // earned by hitting a milestone
  PURCHASE        // bought from store
}

model FlairItem {
  id           String      @id @default(cuid())
  slug         String      @unique
  name         String
  description  String      @default("")
  kind         FlairKind
  imageUrl     String?
  color        String?              // for NAMEPLATE: hex color
  rarity       String      @default("COMMON")  // COMMON | RARE | EPIC | LEGENDARY
  source       FlairSource @default(MANUAL)
  sourceRefId  String?              // tournament id or contest id that minted this
  createdById  String?              // for CONTEST flair: the artist
  meta         Json        @default("{}")

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  ownedBy      UserFlair[]

  @@index([source, sourceRefId])
}

model UserFlair {
  id           String     @id @default(cuid())
  userId       String
  flairItemId  String
  flairItem    FlairItem  @relation(fields: [flairItemId], references: [id], onDelete: Cascade)
  acquiredAt   DateTime   @default(now())
  acquiredFrom String?              // "tournament:xxx" | "contest:yyy" | "manual"

  @@unique([userId, flairItemId])
  @@index([userId])
}

// в”Җв”Җ Flair design contests: community submits banner designs, votes pick winner в”Җв”Җ

model FlairContest {
  id                 String   @id @default(cuid())
  lobbyId            String?
  title              String
  description        String   @default("")
  theme              String   @default("")
  kind               FlairKind @default(BANNER)
  status             String   @default("SUBMISSIONS")  // SUBMISSIONS | VOTING | COMPLETED | CANCELED
  submissionOpensAt  DateTime
  submissionClosesAt DateTime
  voteOpensAt        DateTime
  voteClosesAt       DateTime
  winnerSubmissionId String?
  rewardFlairId      String?              // FlairItem created from the winning submission
  createdById        String

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  submissions        FlairSubmission[]

  @@index([lobbyId, status])
  @@index([status, voteClosesAt])
}

model FlairSubmission {
  id          String   @id @default(cuid())
  contestId   String
  contest     FlairContest @relation(fields: [contestId], references: [id], onDelete: Cascade)
  userId      String
  imageUrl    String
  caption     String   @default("")
  voteCount   Int      @default(0)         // denormalized for sorting
  createdAt   DateTime @default(now())

  votes       FlairVote[]

  @@unique([contestId, userId])             // one submission per user per contest
  @@index([contestId, voteCount])
}

model FlairVote {
  id            String   @id @default(cuid())
  contestId     String
  submissionId  String
  submission    FlairSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  voterId       String
  createdAt     DateTime @default(now())

  @@unique([contestId, voterId])            // one vote per user per contest
  @@index([submissionId])
}

// в”Җв”Җ Forum Tier 2: per-lobby sections, bookmarks, subscriptions, mod tools в”Җв”Җ

model ForumSection {
  id          String   @id @default(cuid())
  lobbyId     String
  slug        String
  name        String
  description String   @default("")
  color       String?
  icon        String?
  order       Int      @default(0)
  postsOnly   Boolean  @default(false)   // true = only mods can post
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  posts ForumPost[]

  @@unique([lobbyId, slug])
  @@index([lobbyId, order])
}

model ForumBookmark {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  post ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([userId, createdAt])
  @@index([postId])
}

model ForumSubscription {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  post ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([postId])
}

enum ForumReportReason {
  SPAM
  HARASSMENT
  HATE_SPEECH
  NSFW
  MISINFORMATION
  OFF_TOPIC
  OTHER
}

enum ForumReportStatus {
  PENDING
  REVIEWED
  ACTIONED
  DISMISSED
}

model ForumReport {
  id          String           @id @default(cuid())
  postId      String?
  commentId   String?
  reporterId  String
  reason      ForumReportReason
  detail      String           @default("")
  status      ForumReportStatus @default(PENDING)
  reviewedById String?
  reviewedAt  DateTime?
  actionTaken String?
  createdAt   DateTime         @default(now())

  post    ForumPost?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment ForumComment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([postId])
  @@index([commentId])
  @@index([reporterId])
}

enum ForumModActionKind {
  POST_REMOVE
  POST_RESTORE
  POST_LOCK
  POST_UNLOCK
  POST_PIN
  POST_UNPIN
  COMMENT_REMOVE
  COMMENT_RESTORE
  USER_BAN
  USER_UNBAN
  USER_TIMEOUT
}

model ForumModAction {
  id          String              @id @default(cuid())
  lobbyId     String?
  modId       String
  kind        ForumModActionKind
  targetType  String              // "POST" | "COMMENT" | "USER"
  targetId    String
  reason      String              @default("")
  meta        Json                @default("{}")
  createdAt   DateTime            @default(now())

  @@index([lobbyId, createdAt])
  @@index([modId, createdAt])
  @@index([targetType, targetId])
}

enum ForumAutoModKind {
  REGEX_FILTER
  KARMA_MIN
  ACCOUNT_AGE_MIN
  LINK_BLOCK
  WORD_BLOCK
}

enum ForumAutoModAction {
  REPORT
  REMOVE
  SHADOW_REMOVE
  REQUIRE_REVIEW
}

model ForumAutoModRule {
  id        String              @id @default(cuid())
  lobbyId   String
  name      String
  kind      ForumAutoModKind
  config    Json                @default("{}")
  action    ForumAutoModAction
  enabled   Boolean             @default(true)
  createdById String
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@index([lobbyId, enabled])
}

// в”Җв”Җ Minecraft pairing + presence в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// Short-lived device-code pairing flow used by the Weered Connect Fabric mod.
// Mod POSTs /mc/pair/start to get a code, displays it to the player, polls
// /mc/pair/poll until the user confirms in-browser at /connect/minecraft.

model McPairingCode {
  code         String    @id
  userId       String?   // null until confirmed
  token        String?   // null until confirmed
  mcUuid       String?
  mcUsername   String?
  expiresAt    DateTime
  createdAt    DateTime  @default(now())
  consumedAt   DateTime?

  @@index([expiresAt])
}

// Active in-game presence вҖ” "James is on this Realm right now". Refreshed
// by the mod every ~60s while in-game; rows with stale lastSeenAt are
// considered offline. Server keying: serverAddress = literal host:port for
// public/direct servers, or "REALM:<ownerUUID>:<realmName>" for Realms.

model McPresence {
  id            String   @id @default(cuid())
  userId        String
  mcUuid        String
  mcUsername    String
  serverAddress String
  serverName    String?
  isRealm       Boolean  @default(false)
  worldName     String?
  lastSeenAt    DateTime @default(now())

  @@unique([userId, serverAddress])
  @@index([serverAddress, lastSeenAt])
  @@index([userId])
}

// в”Җв”Җ Announcements в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// Staff-authored system messages. Replaces the old single in-memory siteBanner.
// pinned = shows as a banner; sticky = user can't dismiss it (e.g. Maintenance);
// non-sticky pinned banners are dismissible per-browser. Unpinned rows are
// history (re-pinnable). DB-backed so it survives restarts.
model Announcement {
  id          String   @id @default(cuid())
  message     String
  level       String   @default("info")   // info | warning | urgent
  pinned      Boolean  @default(false)
  sticky      Boolean  @default(false)     // pinned + sticky = can't dismiss
  createdById String
  createdByName String @default("")
  createdAt   DateTime @default(now())

  @@index([pinned, createdAt])
  @@index([createdAt])
}

model ChatAttachment {
  id         String    @id @default(cuid())
  uploaderId String
  roomId     String    @default("")
  url        String
  thumbUrl   String
  width      Int       @default(0)
  height     Int       @default(0)
  bytes      Int       @default(0)
  phash      String    @default("")
  trusted    Boolean   @default(false)
  status     String    @default("ACTIVE")
  reports    Int       @default(0)
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([uploaderId])
  @@index([status, expiresAt])
  @@index([phash])
}

model BlockedImageHash {
  id        String   @id @default(cuid())
  phash     String   @unique
  reason    String   @default("")
  createdAt DateTime @default(now())
}
