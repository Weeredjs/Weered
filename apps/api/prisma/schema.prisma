generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoomRole {
  OWNER
  MOD
  MEMBER
}

enum LobbyRole {
  OWNER
  MOD
  MEMBER
}

enum GlobalRole {
  USER
  SUPPORT
  STAFF
  ADMIN
  GOD
}

enum ModuleType {
  REDDIT
  MARATHON
  BUNGIE
  TWITCH
  YOUTUBE
  CUSTOM
  NONE
}

model Lobby {
  id          String     @id
  name        String     @default("")
  description String     @default("")
  verified    Boolean    @default(false)
  pinned      Boolean    @default(false)
  moduleType  ModuleType @default(REDDIT)
  moduleConfig Json?

  // Search keywords 풉칂칬 e.g. ["destiny", "destiny2", "bungie", "guardian"]
  keywords    String[]   @default([])

  // Branding 풉칂칬 used for pinned lobby cards and lobby page theming
  accentColor String?    // hex e.g. "#4F88C6"
  logoUrl     String?    // square logo for search card / lobby header
  bannerUrl   String?    // wide banner for lobby hero area
  websiteUrl  String?    // embedded in Content tab
  // linkedSubreddits stored in moduleConfig as { subreddits: string[] }

  // Lobby admin 풉칂칬 custom role titles and module toggles
  // roleNames: JSON map of level풉친칁title, e.g. {"5":"Boss","4":"Lieutenant","3":"Bouncer","2":"VIP","1":"Viewer"}
  roleNames       Json?
  // enabledModules: which modules lobby rooms can use, e.g. ["voice","youtube","reddit"]
  enabledModules  String[]  @default(["voice", "youtube", "reddit"])

  ownerId     String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  rooms       Room[]
  members     LobbyMember[]
  bans        LobbyBan[]
  messages    LobbyMessage[]
  adminMessages LobbyAdminMessage[]
  audit       LobbyAudit[]
}

model LobbyMember {
  id        String    @id @default(cuid())
  lobbyId   String
  userId    String
  name      String    @default("")
  role      LobbyRole @default(MEMBER)
  roleLevel Int       @default(1)   // 1=Member, 2=Trusted, 3=Moderator, 4=Admin, 5=Owner
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  lobby Lobby @relation(fields: [lobbyId], references: [id], onDelete: Cascade)

  @@unique([lobbyId, userId])
}

model LobbyBan {
  id        String   @id @default(cuid())
  lobbyId   String
  userId    String
  reason    String   @default("")
  createdAt DateTime @default(now())

  lobby Lobby @relation(fields: [lobbyId], references: [id], onDelete: Cascade)

  @@unique([lobbyId, userId])
}

model LobbyMessage {
  id        String   @id
  lobbyId   String
  userId    String
  userName  String   @default("")
  body      String
  ts        DateTime @default(now())

  lobby Lobby @relation(fields: [lobbyId], references: [id], onDelete: Cascade)

  @@index([lobbyId, ts])
}

model LobbyAudit {
  id        String   @id
  lobbyId   String
  type      String
  actorId   String
  actorName String
  targetId  String?
  note      String?
  ts        DateTime @default(now())

  lobby Lobby @relation(fields: [lobbyId], references: [id], onDelete: Cascade)

  @@index([lobbyId, ts])
}

model LobbyAdminMessage {
  id        String   @id
  lobbyId   String
  userId    String
  userName  String   @default("")
  body      String
  ts        DateTime @default(now())

  lobby Lobby @relation(fields: [lobbyId], references: [id], onDelete: Cascade)

  @@index([lobbyId, ts])
}

model Room {
  id        String   @id
  name      String   @default("")
  locked    Boolean  @default(false)
  ownerId   String?
  lobbyId   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lobby    Lobby?       @relation(fields: [lobbyId], references: [id], onDelete: SetNull)
  members  RoomMember[]
  bans     RoomBan[]
  messages RoomMessage[]
  audit    RoomAudit[]

  @@unique([lobbyId, name])
}

model RoomMember {
  id        String   @id @default(cuid())
  roomId    String
  userId    String
  name      String   @default("")
  role      RoomRole @default(MEMBER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
}

model RoomBan {
  id        String   @id @default(cuid())
  roomId    String
  userId    String
  createdAt DateTime @default(now())

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
}

model RoomMessage {
  id       String   @id
  roomId   String
  userId   String
  userName String   @default("")
  body     String
  ts       DateTime @default(now())

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId, ts])
}

model RoomAudit {
  id        String   @id
  roomId    String
  type      String
  actorId   String
  actorName String
  targetId  String?
  note      String?
  ts        DateTime @default(now())

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId, ts])
}

model User {
  id          String     @id @default(cuid())
  usernameKey String     @unique
  name        String     @default("")
  bio         String?
  email       String?    @unique
  googleId    String?    @unique
  avatar      String?
  avatarColor String?
  notoriety   Int        @default(0)
  tier        UserTier   @default(INNOCENT)
  globalRole        GlobalRole @default(USER)
  onboardingComplete Boolean    @default(false)
  createdAt         DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  dmSent           DirectMessage[]  @relation("DMSent")
  dmReceived       DirectMessage[]  @relation("DMReceived")
  LocalAuth        LocalAuth?
  staffNotes       StaffNote[]      @relation("StaffNoteTarget")
  auditLogs        GlobalAudit[]    @relation("GlobalAuditTarget")
  notorietyEvents  NotorietyEvent[]
  gameAccounts     UserGameAccount[]
}

model LocalAuth {
  id               String    @id @default(cuid())
  username         String    @unique
  passwordHash     String
  email            String?   @unique
  emailVerified    Boolean   @default(false)
  verifyToken      String?   @unique
  verifyTokenExp   DateTime?
  userId           String    @unique
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model StaffNote {
  id         String   @id @default(cuid())
  targetId   String
  authorId   String
  authorName String   @default("")
  body       String
  createdAt  DateTime @default(now())

  target User @relation("StaffNoteTarget", fields: [targetId], references: [id], onDelete: Cascade)
}

model GlobalAudit {
  id         String   @id @default(cuid())
  actorId    String
  actorName  String   @default("")
  action     String
  targetId   String?
  targetName String?
  meta       Json?
  createdAt  DateTime @default(now())

  target User? @relation("GlobalAuditTarget", fields: [targetId], references: [id], onDelete: SetNull)

  @@index([createdAt])
}

enum UserTier {
  INNOCENT
  INDICTED
  FELON
  KINGPIN
}

model NotorietyEvent {
  id        String   @id @default(cuid())
  userId    String
  action    String
  points    Int
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, action])
}

model DirectMessage {
  id        String    @id @default(cuid())
  fromId    String
  toId      String
  body      String
  readAt    DateTime?
  createdAt DateTime  @default(now())

  from User @relation("DMSent",     fields: [fromId], references: [id], onDelete: Cascade)
  to   User @relation("DMReceived", fields: [toId],   references: [id], onDelete: Cascade)

  @@index([fromId, toId, createdAt])
  @@index([toId, readAt])
}

// 풉칬칂풉칬칂 Crew / Dojo 풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂

enum CrewRole {
  LEADER
  OFFICER
  MEMBER
}

model Crew {
  id          String   @id @default(cuid())
  name        String
  tag         String   @default("")
  description String   @default("")
  ownerId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members CrewMember[]
}

model CrewMember {
  id        String   @id @default(cuid())
  crewId    String
  userId    String
  name      String   @default("")
  role      CrewRole @default(MEMBER)
  joinedAt  DateTime @default(now())

  crew Crew @relation(fields: [crewId], references: [id], onDelete: Cascade)

  @@unique([crewId, userId])
  @@index([userId])
}

// 풉칬칂풉칬칂 Friends 풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂

enum FriendStatus {
  PENDING
  ACCEPTED
  DECLINED
  BLOCKED
}

model FriendRequest {
  id         String       @id @default(cuid())
  fromId     String
  toId       String
  status     FriendStatus @default(PENDING)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@unique([fromId, toId])
  @@index([toId, status])
  @@index([fromId, status])
}

model FeedItem {
  id          String   @id @default(cuid())
  url         String   @unique
  title       String
  thumbnail   String?
  domain      String
  sourceName  String
  category    String
  heat        Int      @default(0)
  usersInRoom Int      @default(0)
  fetchedAt   DateTime @default(now())
  postedAt    DateTime @default(now())

  @@index([category, heat])
  @@index([fetchedAt])
}

// 풉칬칂풉칬칂 Game Accounts 풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂
// Stores per-user OAuth tokens and cached playcard data for each game integration.
// gameType maps to ModuleType (BUNGIE = Destiny 2, etc.)

model UserGameAccount {
  id            String     @id @default(cuid())
  userId        String
  gameType      ModuleType

  // OAuth
  accessToken   String?
  refreshToken  String?
  tokenExpiry   DateTime?

  // Game identity
  externalId    String?    // e.g. Bungie membershipId
  displayName   String     @default("")
  platform      String     @default("")  // e.g. "pc", "xbox", "psn"

  // Cached playcard 풉칂칬 refreshed on hover if stale (5 min TTL)
  cardData      Json?
  cardCachedAt  DateTime?

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, gameType])
  @@index([userId])
}

// 풉칬칂풉칬칂 Invites 풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂

enum InviteType {
  PLATFORM
  ROOM
  LOBBY
  CREW
}

model Invite {
  id        String     @id @default(cuid())
  token     String     @unique @default(cuid())
  type      InviteType @default(PLATFORM)
  targetId  String?    // roomId, lobbyId, or crewId 풉칂칬 null for PLATFORM
  createdBy String     // userId of creator
  note      String?
  maxUses   Int        @default(1)
  uses      Int        @default(0)
  expiresAt DateTime?
  createdAt DateTime   @default(now())

  @@index([token])
  @@index([createdBy])
}

// 풉칬칂풉칬칂 Subscriptions (Stripe-backed) 풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂

enum SubTier {
  FREE       // Innocent 풉칂칬 default
  INDICTED   // $6/mo 풉칂칬 colored username, video streaming, custom fonts
  FELON      // $14/mo 풉칂칬 above + own up to 3 lobbies
  KINGPIN    // Staff-granted 풉칂칬 unlimited lobbies, all modules
}

model Subscription {
  id                 String   @id @default(cuid())
  userId             String   @unique
  tier               SubTier  @default(FREE)
  stripeCustomerId   String?  @unique
  stripeSubId        String?  @unique  // Stripe subscription ID
  stripePriceId      String?            // Which price they're on
  status             String   @default("inactive")  // active, past_due, canceled, inactive
  currentPeriodEnd   DateTime?
  cancelAtPeriodEnd  Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([userId])
  @@index([stripeCustomerId])
}

// 풉칬칂풉칬칂 LFG / Fireteam Board 풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂

enum LfgStatus {
  OPEN
  FULL
  CLOSED
}

model LfgPost {
  id          String    @id @default(cuid())
  lobbyId     String
  userId      String
  userName    String    @default("")
  activity    String    // e.g. "Raid: Crota's End", "Nightfall", "Trials of Osiris"
  description String    @default("")
  maxPlayers  Int       @default(6)
  players     String[]  @default([])  // userId array of joined players
  playerNames String[]  @default([])  // display names parallel array
  status      LfgStatus @default(OPEN)
  platform    String    @default("crossplay")  // pc, xbox, psn, crossplay
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([lobbyId, status])
  @@index([lobbyId, createdAt])
}

// 풉칬칂풉칬칂 Bungie Manifest Cache 풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂
// Caches Bungie API responses (Xur inventory, weekly reset, etc.) with TTL

model BungieCache {
  key       String   @id           // e.g. "xur_inventory", "weekly_reset", "nightfall"
  data      Json
  fetchedAt DateTime @default(now())
  expiresAt DateTime
}

