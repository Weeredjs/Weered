generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoomRole {
  OWNER
  MOD
  MEMBER
}

enum LobbyRole {
  OWNER
  MOD
  MEMBER
}

enum JoinMode {
  OPEN       // Anyone can join instantly
  APPROVAL   // Request to join, admin approves
  PASSWORD   // Must enter lobby password
  PAID       // Must subscribe to a lobby tier
}

enum GlobalRole {
  USER
  SUPPORT
  STAFF
  ADMIN
  GOD
}

enum ModuleType {
  FEED
  MARATHON
  BUNGIE
  TWITCH
  YOUTUBE
  CUSTOM
  MLB
  PGA
  NEWS
  NONE
  RIOT
  FORTNITE
  TRADING
  POKER
  HEADQUARTERS
  CS2
  DOTA2
  STUDY
  PUBG
  DND
  POE
}

model NewsArticle {
  id          String   @id @default(cuid())
  guid        String   @unique
  url         String
  title       String
  description String   @default("")
  imageUrl    String?
  source      String
  sourceIcon  String?
  category    String
  publishedAt DateTime
  fetchedAt   DateTime @default(now())
  heat        Int      @default(0)

  @@index([category, heat])
  @@index([publishedAt])
}

model Lobby {
  id          String     @id
  name        String     @default("")
  description String     @default("")
  verified    Boolean    @default(false)
  pinned      Boolean    @default(false)
  moduleType  ModuleType @default(FEED)
  moduleConfig Json?

  // Search keywords ΓÇö e.g. ["destiny", "destiny2", "bungie", "guardian"]
  keywords    String[]   @default([])

  // Branding ΓÇö used for pinned lobby cards and lobby page theming
  accentColor String?    // hex e.g. "#4F88C6"
  logoUrl     String?    // square logo for search card / lobby header
  bannerUrl   String?    // wide banner for lobby hero area
  websiteUrl  String?    // embedded in Content tab
  // linkedSubreddits stored in moduleConfig as { subreddits: string[] }

  // Lobby admin ΓÇö custom role titles and module toggles
  // roleNames: JSON map of levelΓåÆtitle, e.g. {"5":"Boss","4":"Lieutenant","3":"Bouncer","2":"VIP","1":"Viewer"}
  roleNames       Json?
  // enabledModules: which modules lobby rooms can use, e.g. ["voice","youtube","reddit"]
  enabledModules  String[]  @default(["voice", "youtube", "reddit"])

  ownerId     String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Membership gating
  joinMode      JoinMode @default(OPEN)
  joinPassword  String?  // only used when joinMode=PASSWORD

  // Revenue sharing — manual payout percentage for lobby owner (0-100)
  revenueSharePct Float @default(0)

  rooms       Room[]
  members     LobbyMember[]
  bans        LobbyBan[]
  messages    LobbyMessage[]
  adminMessages LobbyAdminMessage[]
  audit       LobbyAudit[]
  tiers        LobbyTier[]
  events       Event[]
  forumPosts   ForumPost[]
  joinRequests LobbyJoinRequest[]
}

model LobbyMember {
  id        String    @id @default(cuid())
  lobbyId   String
  userId    String
  name      String    @default("")
  role      LobbyRole @default(MEMBER)
  roleLevel Int       @default(1)   // 1=Member, 2=Trusted, 3=Moderator, 4=Admin, 5=Owner
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  lobby Lobby @relation(fields: [lobbyId], references: [id], onDelete: Cascade)

  @@unique([lobbyId, userId])
}

model LobbyBan {
  id        String   @id @default(cuid())
  lobbyId   String
  userId    String
  reason    String   @default("")
  createdAt DateTime @default(now())

  lobby Lobby @relation(fields: [lobbyId], references: [id], onDelete: Cascade)

  @@unique([lobbyId, userId])
}

model LobbyJoinRequest {
  id        String   @id @default(cuid())
  lobbyId   String
  userId    String
  userName  String   @default("")
  message   String   @default("")   // optional "why I want to join"
  status    String   @default("PENDING")  // PENDING, APPROVED, DENIED
  reviewedById   String?
  reviewedByName String?
  reviewedAt     DateTime?
  denyReason     String?
  createdAt DateTime @default(now())

  lobby Lobby @relation(fields: [lobbyId], references: [id], onDelete: Cascade)

  @@unique([lobbyId, userId])
  @@index([lobbyId, status])
}

model LobbyMessage {
  id        String   @id
  lobbyId   String
  userId    String
  userName  String   @default("")
  body      String
  ts        DateTime @default(now())
  editedAt  DateTime?
  deletedAt DateTime?

  lobby Lobby @relation(fields: [lobbyId], references: [id], onDelete: Cascade)

  @@index([lobbyId, ts])
}

model LobbyAudit {
  id        String   @id
  lobbyId   String
  type      String
  actorId   String
  actorName String
  targetId  String?
  note      String?
  ts        DateTime @default(now())

  lobby Lobby @relation(fields: [lobbyId], references: [id], onDelete: Cascade)

  @@index([lobbyId, ts])
}

model LobbyAdminMessage {
  id        String   @id
  lobbyId   String
  userId    String
  userName  String   @default("")
  body      String
  ts        DateTime @default(now())

  lobby Lobby @relation(fields: [lobbyId], references: [id], onDelete: Cascade)

  @@index([lobbyId, ts])
}

model Room {
  id           String   @id
  name         String   @default("")
  description  String   @default("")
  locked       Boolean  @default(false)
  pinned       Boolean  @default(false)
  isEvent      Boolean  @default(false)
  passwordHash String?
  ownerId   String?
  lobbyId   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lobby    Lobby?       @relation(fields: [lobbyId], references: [id], onDelete: SetNull)
  members  RoomMember[]
  bans     RoomBan[]
  messages RoomMessage[]
  audit    RoomAudit[]
  npcs     RoomNpc[]

  @@unique([lobbyId, name])
}

model RoomMember {
  id          String   @id @default(cuid())
  roomId      String
  userId      String
  name        String   @default("")
  description String   @default("")
  role        RoomRole @default(MEMBER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
}

model RoomBan {
  id        String   @id @default(cuid())
  roomId    String
  userId    String
  createdAt DateTime @default(now())

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
}

model RoomMessage {
  id        String   @id
  roomId    String
  userId    String
  userName  String   @default("")
  body      String
  ts        DateTime @default(now())
  editedAt  DateTime?
  deletedAt DateTime?

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId, ts])
}

model RoomAudit {
  id        String   @id
  roomId    String
  type      String
  actorId   String
  actorName String
  targetId  String?
  note      String?
  ts        DateTime @default(now())

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId, ts])
}

model RoomNpc {
  id        String   @id @default(cuid())
  roomId    String
  name      String
  portrait  String   @default("")
  config    Json     @default("{}")
  createdBy String
  createdAt DateTime @default(now())

  room     Room         @relation(fields: [roomId], references: [id], onDelete: Cascade)
  messages NpcMessage[]

  @@index([roomId])
}

model NpcMessage {
  id        String   @id @default(cuid())
  npcId     String
  userId    String?
  userName  String   @default("")
  role      String
  content   String
  createdAt DateTime @default(now())

  npc RoomNpc @relation(fields: [npcId], references: [id], onDelete: Cascade)

  @@index([npcId, createdAt])
}

model User {
  id          String     @id @default(cuid())
  usernameKey String     @unique
  name        String     @default("")
  description String     @default("")
  bio         String?
  email       String?    @unique
  googleId    String?    @unique
  avatar      String?
  avatarColor String?
  notoriety   Int        @default(0)
  paper       Int        @default(0)   // spendable virtual currency
  tier        UserTier   @default(INNOCENT)
  globalRole        GlobalRole @default(USER)
  onboardingComplete Boolean    @default(false)

  // Global ban — staff-imposed platform-wide ban
  banned      Boolean    @default(false)
  banReason   String?
  bannedAt    DateTime?
  bannedBy    String?    // userId of staff member who banned

  // Self-initiated account deletion (GDPR right to erasure)
  deletedAt   DateTime?

  // GPS location (opt-in only)
  locationOptIn     Boolean    @default(false)
  latitude          Float?
  longitude         Float?
  locationH3        String?    // H3 hex index (resolution 7 ≈ 5km)
  locationUpdatedAt DateTime?

  createdAt         DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  dmSent           DirectMessage[]  @relation("DMSent")
  dmReceived       DirectMessage[]  @relation("DMReceived")
  blocksSent       UserBlock[]      @relation("BlocksSent")
  blocksReceived   UserBlock[]      @relation("BlocksReceived")
  reportsFiled     Report[]         @relation("ReportsFiled")
  reportsReviewed  Report[]         @relation("ReportsReviewed")
  reactions        Reaction[]       @relation("ReactionsFrom")
  LocalAuth        LocalAuth?
  staffNotes       StaffNote[]      @relation("StaffNoteTarget")
  auditLogs        GlobalAudit[]    @relation("GlobalAuditTarget")
  staffPosts       StaffPost[]      @relation("StaffPostAuthor")
  notorietyEvents  NotorietyEvent[]
  gameAccounts     UserGameAccount[]
  pushSubs         PushSubscription[]
  paperTransactions PaperTransaction[]
  inventory        UserItem[]
  marketListings   MarketListing[]   @relation("MarketSeller")
}

// —— Site Config (key-value) ————————————————————————————————————————————————
// Stores platform-wide settings: featuredLobbyId, registrationOpen, etc.
// Staff-managed via /staff/config endpoints.

model SiteConfig {
  key       String   @id           // e.g. "featuredLobbyId", "registrationOpen"
  value     String   @default("")  // stored as string, parsed by consumer
  updatedAt DateTime @updatedAt
}

model RecentVisit {
  id        String   @id @default(cuid())
  userId    String
  roomId    String?              // ad-hoc room ID (null if lobby visit)
  lobbyId   String?              // lobby ID (null if ad-hoc room visit)
  name      String   @default("") // display name at time of visit
  visitedAt DateTime @default(now())

  @@unique([userId, roomId])     // one entry per user+room
  @@unique([userId, lobbyId])    // one entry per user+lobby
  @@index([userId, visitedAt])
}

model LocalAuth {
  id               String    @id @default(cuid())
  username         String    @unique
  passwordHash     String
  email            String?   @unique
  emailVerified    Boolean   @default(false)
  verifyToken      String?   @unique
  verifyTokenExp   DateTime?
  userId           String    @unique
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model StaffNote {
  id         String   @id @default(cuid())
  targetId   String
  authorId   String
  authorName String   @default("")
  body       String
  createdAt  DateTime @default(now())

  target User @relation("StaffNoteTarget", fields: [targetId], references: [id], onDelete: Cascade)
}

model GlobalAudit {
  id         String   @id @default(cuid())
  actorId    String
  actorName  String   @default("")
  action     String
  targetId   String?
  targetName String?
  meta       Json?
  createdAt  DateTime @default(now())

  target User? @relation("GlobalAuditTarget", fields: [targetId], references: [id], onDelete: SetNull)

  @@index([createdAt])
}

enum UserTier {
  INNOCENT
  INDICTED
  FELON
  KINGPIN
}

model NotorietyEvent {
  id        String   @id @default(cuid())
  userId    String
  action    String
  points    Int
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, action])
}

// —— Notifications ——————————————————————————————————————————————————————————

enum NotificationType {
  DM_RECEIVED
  FRIEND_REQUEST
  FRIEND_ACCEPTED
  CREW_INVITE
  MENTION
  CHALLENGE_STARTED
  CHALLENGE_COMPLETED
  NOTORIETY_RANKUP
  LOBBY_EVENT
  SYSTEM
}

model Notification {
  id          String           @id @default(cuid())
  userId      String
  type        NotificationType
  title       String
  body        String           @default("")
  actionUrl   String?
  actorId     String?
  actorName   String?
  meta        Json?
  read        Boolean          @default(false)
  createdAt   DateTime         @default(now())

  @@index([userId, read, createdAt])
  @@index([userId, createdAt])
}

model DirectMessage {
  id        String    @id @default(cuid())
  fromId    String
  toId      String
  body      String
  readAt    DateTime?
  createdAt DateTime  @default(now())
  editedAt  DateTime?
  deletedAt DateTime?

  from User @relation("DMSent",     fields: [fromId], references: [id], onDelete: Cascade)
  to   User @relation("DMReceived", fields: [toId],   references: [id], onDelete: Cascade)

  @@index([fromId, toId, createdAt])
  @@index([toId, readAt])
}

// ── User blocks ─────────────────────────────────────────────────────────────
model UserBlock {
  id         String   @id @default(cuid())
  blockerId  String
  blockedId  String
  reason     String?
  createdAt  DateTime @default(now())

  blocker User @relation("BlocksSent",     fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("BlocksReceived", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockedId])
}

// ── Message reactions ───────────────────────────────────────────────────────
enum ReactionTargetType {
  ROOM_MESSAGE
  DIRECT_MESSAGE
  CREW_MESSAGE
}

model Reaction {
  id         String             @id @default(cuid())
  targetType ReactionTargetType
  targetId   String
  userId     String
  emoji      String
  createdAt  DateTime           @default(now())

  user User @relation("ReactionsFrom", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([targetType, targetId, userId, emoji])
  @@index([targetType, targetId])
  @@index([userId])
}

// ── Reports ─────────────────────────────────────────────────────────────────
enum ReportStatus {
  OPEN
  REVIEWED
  ACTIONED
  DISMISSED
}

enum ReportTargetType {
  MESSAGE
  USER
  ROOM
  LOBBY
}

enum ReportReason {
  SPAM
  HARASSMENT
  HATE_SPEECH
  THREATS
  NSFW
  MINOR_SAFETY
  IMPERSONATION
  SELF_HARM
  OTHER
}

model Report {
  id            String           @id @default(cuid())
  reporterId   String
  targetType    ReportTargetType
  targetId      String
  context       String?          // roomId / lobbyId for message reports
  reason        ReportReason
  note          String?
  status        ReportStatus     @default(OPEN)
  bodySnapshot  String?          // captured content at time of report (for MESSAGE)
  createdAt     DateTime         @default(now())
  reviewedAt    DateTime?
  reviewedById  String?

  reporter User  @relation("ReportsFiled", fields: [reporterId], references: [id], onDelete: Cascade)
  reviewer User? @relation("ReportsReviewed", fields: [reviewedById], references: [id])

  @@index([status, createdAt])
  @@index([reporterId])
  @@index([targetType, targetId])
}

// ΓöÇΓöÇ Crew / Dojo ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ

enum CrewRole {
  LEADER
  OFFICER
  MEMBER
}

model Crew {
  id          String   @id @default(cuid())
  name        String
  tag         String   @default("")
  description String   @default("")
  ownerId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members CrewMember[]
}

model CrewMessage {
  id        String    @id @default(cuid())
  crewId    String
  userId    String
  userName  String    @default("")
  body      String
  createdAt DateTime  @default(now())
  editedAt  DateTime?
  deletedAt DateTime?

  @@index([crewId, createdAt])
}

model CrewMember {
  id          String   @id @default(cuid())
  crewId      String
  userId      String
  name        String   @default("")
  description String   @default("")
  role        CrewRole @default(MEMBER)
  joinedAt  DateTime @default(now())

  crew Crew @relation(fields: [crewId], references: [id], onDelete: Cascade)

  @@unique([crewId, userId])
  @@index([userId])
}

// ΓöÇΓöÇ Friends ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ

enum FriendStatus {
  PENDING
  ACCEPTED
  DECLINED
  BLOCKED
}

model FriendRequest {
  id         String       @id @default(cuid())
  fromId     String
  toId       String
  status     FriendStatus @default(PENDING)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@unique([fromId, toId])
  @@index([toId, status])
  @@index([fromId, status])
}

model FeedItem {
  id          String   @id @default(cuid())
  url         String   @unique
  title       String
  thumbnail   String?
  domain      String
  sourceName  String
  category    String
  heat        Int      @default(0)
  usersInRoom Int      @default(0)
  fetchedAt   DateTime @default(now())
  postedAt    DateTime @default(now())

  @@index([category, heat])
  @@index([fetchedAt])
}

// ΓöÇΓöÇ Game Accounts ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ
// Stores per-user OAuth tokens and cached playcard data for each game integration.
// gameType maps to ModuleType (BUNGIE = Destiny 2, etc.)

model UserGameAccount {
  id            String     @id @default(cuid())
  userId        String
  gameType      ModuleType

  // OAuth
  accessToken   String?
  refreshToken  String?
  tokenExpiry   DateTime?

  // Game identity
  externalId    String?    // e.g. Bungie membershipId
  displayName   String     @default("")
  platform      String     @default("")  // e.g. "pc", "xbox", "psn"

  // Cached playcard ΓÇö refreshed on hover if stale (5 min TTL)
  cardData      Json?
  cardCachedAt  DateTime?

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, gameType])
  @@index([userId])
}

// ΓöÇΓöÇ Invites ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ

enum InviteType {
  PLATFORM
  ROOM
  LOBBY
  CREW
}

model Invite {
  id        String     @id @default(cuid())
  token     String     @unique @default(cuid())
  type      InviteType @default(PLATFORM)
  targetId  String?    // roomId, lobbyId, or crewId ΓÇö null for PLATFORM
  createdBy String     // userId of creator
  note      String?
  maxUses   Int        @default(1)
  uses      Int        @default(0)
  expiresAt DateTime?
  createdAt DateTime   @default(now())

  @@index([token])
  @@index([createdBy])
}

// ΓöÇΓöÇ Subscriptions (Stripe-backed) ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ

enum SubTier {
  FREE       // Innocent ΓÇö default
  INDICTED   // $6/mo ΓÇö colored username, video streaming, custom fonts
  FELON      // $14/mo ΓÇö above + own up to 3 lobbies
  KINGPIN    // Staff-granted ΓÇö unlimited lobbies, all modules
}

model Subscription {
  id                 String   @id @default(cuid())
  userId             String   @unique
  tier               SubTier  @default(FREE)
  stripeCustomerId   String?  @unique
  stripeSubId        String?  @unique  // Stripe subscription ID
  stripePriceId      String?            // Which price they're on
  status             String   @default("inactive")  // active, past_due, canceled, inactive
  currentPeriodEnd   DateTime?
  cancelAtPeriodEnd  Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([userId])
  @@index([stripeCustomerId])
}

// ΓöÇΓöÇ Lobby Paid Tiers ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ
// Lobby owners can create paid subscription tiers that auto-promote members.

model LobbyTier {
  id              String   @id @default(cuid())
  lobbyId         String
  name            String                    // e.g. "VIP", "Patron", "Supporter"
  description     String   @default("")
  priceMonthly    Int                       // cents, e.g. 500 = $5.00
  grantLevel      Int      @default(2)      // roleLevel to auto-assign (1-4, never 5)
  color           String?                   // hex accent for badge display
  stripePriceId   String?  @unique          // Stripe Price ID (created dynamically)
  stripeProductId String?                   // Stripe Product ID
  sortOrder       Int      @default(0)      // display order
  active          Boolean  @default(true)   // soft-disable without deleting
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  lobby       Lobby          @relation(fields: [lobbyId], references: [id], onDelete: Cascade)
  subscribers LobbyTierSub[]

  @@index([lobbyId, active])
}

model LobbyTierSub {
  id                String    @id @default(cuid())
  lobbyTierId       String
  lobbyId           String                // denormalized for fast queries
  userId            String
  stripeSubId       String?   @unique     // Stripe subscription ID
  stripeCustomerId  String?               // Stripe customer (may reuse from platform Subscription)
  status            String    @default("inactive") // active, past_due, canceled, inactive
  currentPeriodEnd  DateTime?
  cancelAtPeriodEnd Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  tier LobbyTier @relation(fields: [lobbyTierId], references: [id], onDelete: Cascade)

  @@unique([lobbyId, userId])             // one active lobby sub per user per lobby
  @@index([userId])
  @@index([stripeSubId])
}

// ΓöÇΓöÇ LFG / Fireteam Board ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ

enum LfgStatus {
  OPEN
  FULL
  CLOSED
}

model LfgPost {
  id          String    @id @default(cuid())
  lobbyId     String
  userId      String
  userName    String    @default("")
  activity    String    // e.g. "Raid: Crota's End", "Nightfall", "Trials of Osiris"
  description String    @default("")
  maxPlayers  Int       @default(6)
  players     String[]  @default([])  // userId array of joined players
  playerNames String[]  @default([])  // display names parallel array
  status      LfgStatus @default(OPEN)
  platform    String    @default("crossplay")  // pc, xbox, psn, crossplay
  gameMode    String?   // e.g. "solo", "duo", "squad", "zero-build", "ranked", "creative"
  rankTier    String?   // e.g. "Bronze", "Silver", "Gold", "Platinum", "Diamond", "Elite", "Unreal", "Champion"
  region      String?   // e.g. "NAE", "NAW", "EU", "OCE", "ASIA", "BR"
  tags        String[]  @default([])  // ["casual", "competitive", "chill", "sweaty", "mic-required", "no-mic"]
  metadata    Json?     // extensible game-specific data
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([lobbyId, status])
  @@index([lobbyId, createdAt])
}

// ── Fortnite Wishlist ──────────────────────────────────────────────────────
model FortniteWishlist {
  id          String   @id @default(cuid())
  userId      String
  cosmeticId  String   // fortnite-api.com item ID
  name        String   @default("")
  type        String   @default("")   // Outfit, Pickaxe, Glider, etc.
  rarity      String   @default("")
  image       String?
  notified    Boolean  @default(false) // has user been notified it's in shop?
  notifiedAt  DateTime?
  createdAt   DateTime @default(now())

  @@unique([userId, cosmeticId])
  @@index([cosmeticId])
  @@index([userId])
}

// ΓöÇΓöÇ Bungie Manifest Cache ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ
// Caches Bungie API responses (Xur inventory, weekly reset, etc.) with TTL

model BungieCache {
  key       String   @id           // e.g. "xur_inventory", "weekly_reset", "nightfall"
  data      Json
  fetchedAt DateTime @default(now())
  expiresAt DateTime
}

// — Reserved Names —————————————————————————————————————————————————————————
// Blocks lobby IDs and usernames from being claimed. Staff-managed via admin panel.

enum ReservedScope {
  BOTH       // blocks lobbies AND usernames
  LOBBY      // blocks lobby IDs only
  USERNAME   // blocks usernames only
}

model ReservedName {
  id        String        @id @default(cuid())
  name      String        @unique   // lowercase, normalized
  scope     ReservedScope @default(BOTH)
  reason    String        @default("")
  addedBy   String        @default("system")  // userId or "system" for seed
  createdAt DateTime      @default(now())
}

// ΓöÇΓöÇ Events ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ
// Global + lobby-scoped events with promotion pipeline.

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELED
  COMPLETED
}

enum PromotionStatus {
  NONE
  PENDING
  APPROVED
  DENIED
}

model Event {
  id              String          @id @default(cuid())

  // Core
  title           String
  description     String          @default("")
  category        String          @default("")        // free-text: "raid_night", "watch_party", "ban_court", etc.
  coverImageUrl   String?

  // Scheduling
  startsAt        DateTime
  endsAt          DateTime?
  timezone        String          @default("UTC")

  // Scope — null lobbyId = global event
  lobbyId         String?
  lobby           Lobby?          @relation(fields: [lobbyId], references: [id], onDelete: Cascade)

  // Status
  status          EventStatus     @default(DRAFT)

  // Creator
  createdById     String
  createdByName   String          @default("")

  // Promotion pipeline (lobby events requesting global visibility)
  promotionStatus         PromotionStatus @default(NONE)
  promotionNote           String?         // lobby owner's pitch to staff
  promotionReviewedById   String?
  promotionReviewedByName String?
  promotionReviewedAt     DateTime?
  promotionDenyReason     String?

  // Staff decides per-event whether to fire system:broadcast on publish
  broadcastOnPublish Boolean @default(false)

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([lobbyId, status, startsAt])
  @@index([status, startsAt])
  @@index([createdById])
}

model StaffPost {
  id         String   @id @default(cuid())
  authorId   String
  authorName String   @default("")
  body       String
  pinned     Boolean  @default(false)
  createdAt  DateTime @default(now())

  author User @relation("StaffPostAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([createdAt])
}

// —— Push Notification Subscriptions ———————————————————————————————————————
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ── Forum ─────────────────────────────────────────────────────────────────────

enum ForumCategory {
  BUG_REPORT
  FEATURE_REQUEST
  DISCUSSION
  ANNOUNCEMENT
}

model ForumPost {
  id           String        @id @default(cuid())
  title        String
  body         String
  category     ForumCategory @default(DISCUSSION)
  lobbyId      String?
  authorId     String
  authorName   String        @default("")
  pinned       Boolean       @default(false)
  locked       Boolean       @default(false)
  score        Int           @default(0)
  commentCount Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  lobby    Lobby?         @relation(fields: [lobbyId], references: [id], onDelete: Cascade)
  comments ForumComment[]
  votes    ForumVote[]    @relation("PostVotes")

  @@index([lobbyId, createdAt])
  @@index([lobbyId, score])
  @@index([category, createdAt])
  @@index([score])
  @@index([pinned, createdAt])
  @@index([authorId])
}

model ForumComment {
  id         String   @id @default(cuid())
  postId     String
  authorId   String
  authorName String   @default("")
  body       String
  score      Int      @default(0)
  createdAt  DateTime @default(now())

  post  ForumPost   @relation(fields: [postId], references: [id], onDelete: Cascade)
  votes ForumVote[] @relation("CommentVotes")

  @@index([postId, createdAt])
}

model ForumVote {
  id        String  @id @default(cuid())
  userId    String
  postId    String?
  commentId String?
  value     Int     // +1 or -1

  post    ForumPost?    @relation("PostVotes", fields: [postId], references: [id], onDelete: Cascade)
  comment ForumComment? @relation("CommentVotes", fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@unique([userId, commentId])
  @@index([postId])
  @@index([commentId])
}

// ══════════════════════════════════════════════════════════════════════════════
// ── DESTINY META-GAME LAUNCHER ──────────────────────────────────────────────
// ══════════════════════════════════════════════════════════════════════════════

enum ChallengeScope {
  GLOBAL
  LOBBY
  CREW
  TOURNAMENT
}

enum ChallengeStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  FAILED
  ABANDONED
}

enum TournamentFormat {
  LEADERBOARD
  BRACKET
  ROUND_ROBIN
}

enum TournamentStatus {
  REGISTRATION
  ACTIVE
  COMPLETED
  CANCELED
}

enum TournamentEntryType {
  SOLO
  CREW
}

// ── Challenge definition — reusable template ────────────────────────────────

model ChallengeDefinition {
  id            String          @id @default(cuid())

  title         String
  description   String          @default("")
  iconUrl       String?
  category      String          @default("")     // crucible, pve, raid, seasonal
  difficulty    Int             @default(1)       // 1-5

  scope         ChallengeScope  @default(GLOBAL)
  lobbyId       String?
  crewId        String?
  createdById   String

  // Objective spec — JSON DSL array
  objectives    Json                              // Array of ObjectiveSpec
  requireAll    Boolean         @default(true)
  requireCount  Int?

  // Chain support
  chainParentId String?
  chainOrder    Int             @default(0)

  // Recurrence
  isRecurring   Boolean         @default(false)
  recurSchedule String?                          // weekly_tuesday, daily

  // Rewards
  notorietyReward   Int         @default(0)
  paperReward       Int         @default(0)
  crewRepReward     Int         @default(0)
  badgeId           String?

  status        ChallengeStatus @default(DRAFT)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  instances     ChallengeInstance[]
  chainParent   ChallengeDefinition?  @relation("ChallengeChain", fields: [chainParentId], references: [id])
  chainSteps    ChallengeDefinition[] @relation("ChallengeChain")

  @@index([scope, status])
  @@index([lobbyId, status])
  @@index([category, status])
}

// ── Challenge instance — time-bound run of a definition ─────────────────────

model ChallengeInstance {
  id              String           @id @default(cuid())
  definitionId    String

  startsAt        DateTime
  endsAt          DateTime?
  status          ChallengeStatus  @default(ACTIVE)

  createdAt       DateTime         @default(now())

  definition      ChallengeDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  enrollments     ChallengeEnrollment[]

  @@index([definitionId, status])
  @@index([status, startsAt])
  @@index([status, endsAt])
}

// ── Challenge enrollment — player's progress on an instance ─────────────────

model ChallengeEnrollment {
  id            String           @id @default(cuid())
  instanceId    String
  userId        String

  status        EnrollmentStatus @default(ACTIVE)

  // Progress per objective: { "obj_1": { current: 35, target: 50, completed: false } }
  progress      Json             @default("{}")

  lastCheckedAt              DateTime?
  lastActivityInstanceId     String?

  completedAt   DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  instance      ChallengeInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@unique([instanceId, userId])
  @@index([userId, status])
  @@index([status, lastCheckedAt])
}

// ── Activity log — processed Bungie match history ───────────────────────────

model BungieActivityLog {
  id                 String   @id @default(cuid())
  userId             String
  membershipId       String
  activityInstanceId String                       // Bungie PGCR instanceId

  activityHash       String
  activityName       String   @default("")
  mode               Int
  modeName           String   @default("")
  period             DateTime

  kills              Int      @default(0)
  deaths             Int      @default(0)
  assists            Int      @default(0)
  score              Int      @default(0)
  standing           Int      @default(0)         // 0=Victory, 1=Defeat
  completed          Boolean  @default(false)
  duration           Int      @default(0)         // seconds

  weaponKills        Json     @default("[]")      // [{ hash, name, kills }]
  subclassHash       String?
  fireteamIds        String[] @default([])

  createdAt          DateTime @default(now())

  @@unique([userId, activityInstanceId])
  @@index([userId, period])
  @@index([userId, mode, period])
}

// ── Tournament ──────────────────────────────────────────────────────────────

model Tournament {
  id              String             @id @default(cuid())

  title           String
  description     String             @default("")
  iconUrl         String?

  format          TournamentFormat   @default(LEADERBOARD)
  entryType       TournamentEntryType @default(SOLO)

  lobbyId         String?
  createdById     String

  scoringRule     Json                             // { type, definitionId, stat, ... }

  registrationOpensAt  DateTime
  startsAt             DateTime
  endsAt               DateTime
  status               TournamentStatus @default(REGISTRATION)

  maxEntries      Int              @default(100)
  minEntries      Int              @default(2)

  rewards         Json             @default("[]")

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  entries         TournamentEntry[]

  @@index([status, startsAt])
  @@index([lobbyId, status])
}

model TournamentEntry {
  id            String   @id @default(cuid())
  tournamentId  String

  userId        String?
  crewId        String?
  displayName   String   @default("")

  score         Float    @default(0)
  rank          Int?

  scoreBreakdown Json    @default("{}")

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tournament    Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, userId])
  @@unique([tournamentId, crewId])
  @@index([tournamentId, score])
}

// ── Badges ──────────────────────────────────────────────────────────────────

model ChallengeBadge {
  id          String   @id @default(cuid())
  name        String
  description String   @default("")
  iconUrl     String   @default("")
  rarity      Int      @default(1)
  createdAt   DateTime @default(now())
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  earnedAt  DateTime @default(now())

  @@unique([userId, badgeId])
  @@index([userId])
}

// —— Outreach CRM ————————————————————————————————————————————————————————————

enum OutreachStatus {
  LEAD
  CONTACTED
  REPLIED
  IN_PROGRESS
  PARTNERED
  DECLINED
  STALE
}

enum OutreachCategory {
  GAME_STUDIO
  ESPORTS_ORG
  CONTENT_CREATOR
  BRAND_SPONSOR
  MEDIA
  COMMUNITY
  PLATFORM
  TRADING
  CRYPTO
  OTHER
}

model OutreachContact {
  id          String           @id @default(cuid())
  name        String
  company     String
  email       String           @default("")
  role        String           @default("")
  category    OutreachCategory @default(OTHER)
  status      OutreachStatus   @default(LEAD)
  notes       String           @default("")
  postUrl     String           @default("")
  lastContact DateTime?
  nextFollowUp DateTime?
  createdById String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([status])
  @@index([category])
  @@index([createdAt])
}

// ── Paper Trading ────────────────────────────────────────────────────────────
// Virtual trading engine: users paper-trade crypto with fake money in lobbies.
// Competitions add time-bounded tournaments with leaderboards.

enum OrderSide {
  BUY
  SELL
}

enum OrderType {
  MARKET
  LIMIT
  STOP
}

enum OrderStatus {
  PENDING    // limit/stop waiting to fill
  FILLED
  CANCELLED
}

enum PositionStatus {
  OPEN
  CLOSED
}

enum CompetitionStatus {
  UPCOMING
  ACTIVE
  ENDED
}

model PaperAccount {
  id           String   @id @default(cuid())
  userId       String
  lobbyId      String
  competitionId String?

  cashBalance  Float    @default(100000) // starting + remaining cash
  startBalance Float    @default(100000) // frozen at creation for P&L calc
  realizedPnl  Float    @default(0)      // locked-in profit/loss from closed positions
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  positions    PaperPosition[]
  orders       PaperOrder[]

  @@unique([userId, lobbyId, competitionId])
  @@index([lobbyId])
  @@index([competitionId])
  @@index([userId])
}

model PaperPosition {
  id           String         @id @default(cuid())
  accountId    String
  account      PaperAccount   @relation(fields: [accountId], references: [id], onDelete: Cascade)

  symbol       String         // e.g. "BTCUSDT"
  side         OrderSide      // BUY = long, SELL = short
  quantity     Float          // amount of asset
  entryPrice   Float          // average entry price
  entryValue   Float          // quantity * entryPrice at open
  exitPrice    Float?         // set when closed
  realizedPnl  Float?         // profit/loss when closed
  status       PositionStatus @default(OPEN)

  openedAt     DateTime       @default(now())
  closedAt     DateTime?

  @@index([accountId, status])
  @@index([symbol])
}

model PaperOrder {
  id           String       @id @default(cuid())
  accountId    String
  account      PaperAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  symbol       String
  side         OrderSide
  orderType    OrderType    @default(MARKET)
  quantity     Float        // asset quantity
  price        Float?       // limit/stop price (null for market)
  filledPrice  Float?       // actual execution price
  filledAt     DateTime?
  status       OrderStatus  @default(PENDING)
  createdAt    DateTime     @default(now())

  @@index([accountId])
  @@index([symbol, status])
}

model TradingCompetition {
  id           String            @id @default(cuid())
  lobbyId      String
  name         String            @default("Trading Competition")
  description  String            @default("")
  startBalance Float             @default(100000)
  startTime    DateTime
  endTime      DateTime
  status       CompetitionStatus @default(UPCOMING)
  createdById  String
  createdAt    DateTime          @default(now())

  @@index([lobbyId, status])
  @@index([startTime])
}

// ── Paper Economy ────────────────────────────────────────────────────────────
// Virtual currency earned through gameplay, spent in store/marketplace/tournaments.

enum PaperTxType {
  EARN_FAKEOUT        // profit from FakeOut paper trading
  EARN_CHALLENGE      // challenge/tournament completion
  EARN_DAILY          // daily login bonus
  EARN_TRADE_SOLD     // sold item on marketplace
  EARN_GIFT           // received from another user or system
  EARN_COMPETITION    // competition prize payout
  SPEND_STORE         // purchased from store
  SPEND_MARKET        // purchased from marketplace
  SPEND_TOURNAMENT    // tournament buy-in
  SPEND_GIFT          // gifted to another user
  SPEND_UNLOCK        // unlocked gated area/feature
  ADJUSTMENT          // admin adjustment
  POKER_BUYIN         // poker table buy-in
  POKER_WIN           // poker hand winnings
  POKER_CASHOUT       // poker table cash-out
}

model PaperTransaction {
  id          String      @id @default(cuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        PaperTxType
  amount      Int         // positive = earned, negative = spent
  balance     Int         // balance AFTER this transaction (running total)
  description String      @default("")
  refId       String?     // optional reference (itemId, listingId, competitionId, etc.)
  createdAt   DateTime    @default(now())

  @@index([userId, createdAt])
  @@index([type])
}

// ── Store Items ─────────────────────────────────────────────────────────────
// Items that can be purchased from the store or traded between users.

enum ItemRarity {
  COMMON
  UNCOMMON
  RARE
  EPIC
  LEGENDARY
}

enum ItemCategory {
  AVATAR       // profile avatar/frame
  BADGE        // profile badge
  TITLE        // custom title display
  KEY          // unlocks gated area or feature
  CONSUMABLE   // one-time use (e.g. tournament entry token)
  COLLECTIBLE  // purely collectible, tradeable
  ORNAMENT     // lobby/room decoration
}

model StoreItem {
  id            String       @id @default(cuid())
  name          String
  description   String       @default("")
  category      ItemCategory
  rarity        ItemRarity   @default(COMMON)
  imageUrl      String?
  price         Int          // Paper cost
  maxSupply     Int?         // null = unlimited, number = limited mint
  totalMinted   Int          @default(0)
  available     Boolean      @default(true)
  featured      Boolean      @default(false) // show in featured section
  weeklyRotation Boolean     @default(false) // part of weekly rotating stock
  rotationWeek  Int?         // which ISO week this item is available (null = always)
  // Items with utility
  unlockTarget  String?      // e.g. lobbyId, roomId, or feature flag this item unlocks
  metadata      Json?        // flexible data: CSS styles, animation, duration, etc.
  createdAt     DateTime     @default(now())

  instances     UserItem[]

  @@index([available, featured])
  @@index([category])
  @@index([rarity])
}

model UserItem {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  itemId      String
  item        StoreItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  acquiredAt  DateTime  @default(now())
  equipped    Boolean   @default(false)  // is this item currently active/displayed
  consumed    Boolean   @default(false)  // for consumables: has it been used
  consumedAt  DateTime?
  // Trade provenance
  acquiredFrom String?  // "store", "market", "drop", "gift", userId
  acquiredPrice Int?    // what they paid (Paper)
  mintNumber  Int?      // #37 of 50 — for limited items

  @@index([userId, equipped])
  @@index([itemId])
  @@unique([userId, itemId, mintNumber])
}

// ── Marketplace ─────────────────────────────────────────────────────────────
// User-to-user item trading with Paper currency.

enum ListingStatus {
  ACTIVE
  SOLD
  CANCELLED
  EXPIRED
}

model MarketListing {
  id          String        @id @default(cuid())
  sellerId    String
  seller      User          @relation("MarketSeller", fields: [sellerId], references: [id], onDelete: Cascade)
  userItemId  String        // the UserItem being sold
  itemId      String        // denormalized StoreItem id for search
  itemName    String        @default("")  // denormalized for display
  itemRarity  ItemRarity    @default(COMMON)
  price       Int           // asking price in Paper
  status      ListingStatus @default(ACTIVE)
  buyerId     String?       // who bought it
  soldAt      DateTime?
  expiresAt   DateTime?     // optional auto-expire
  createdAt   DateTime      @default(now())

  @@index([status, itemId])
  @@index([sellerId])
  @@index([status, createdAt])
  @@index([itemRarity, status])
}

