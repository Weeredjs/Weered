generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum RoomRole {
  OWNER
  MOD
  MEMBER
}

enum LobbyRole {
  OWNER    // Created / claimed the lobby
  MOD      // Lobby-scoped moderator (verified lobbies only)
  MEMBER   // Regular member
}

enum GlobalRole {
  USER
  SUPPORT  // Can view staff tools, limited actions
  STAFF    // Full mod tools across all lobbies/rooms
  ADMIN    // Platform admin (between STAFF and GOD)
  GOD      // Superuser
}

enum ModuleType {
  REDDIT   // Default — subreddit browser
  BUNGIE   // Destiny 2 / Bungie API
  TWITCH   // Twitch stream embed
  YOUTUBE  // YouTube embed
  CUSTOM   // Custom iframe / integration
  NONE     // No module, chat only
}

// ─── Lobby ────────────────────────────────────────────────────────────────────

model Lobby {
  id          String     @id                    // e.g. "r/gaming", "destiny2", "weered.ca"
  name        String     @default("")           // Display name e.g. "r/gaming"
  description String     @default("")
  verified    Boolean    @default(false)        // Verified/claimed lobby
  pinned      Boolean    @default(false)        // Always show on Home
  moduleType  ModuleType @default(REDDIT)       // Which module to render
  moduleConfig Json?                            // Module-specific config (subreddit, channel id, etc.)
  ownerId     String?                           // User who claimed/created this lobby
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  rooms       Room[]
  members     LobbyMember[]
  bans        LobbyBan[]
  messages    LobbyMessage[]
  audit       LobbyAudit[]
}

model LobbyMember {
  id        String    @id @default(cuid())
  lobbyId   String
  userId    String
  name      String    @default("")
  role      LobbyRole @default(MEMBER)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  lobby Lobby @relation(fields: [lobbyId], references: [id], onDelete: Cascade)

  @@unique([lobbyId, userId])
}

model LobbyBan {
  id        String   @id @default(cuid())
  lobbyId   String
  userId    String
  reason    String   @default("")
  createdAt DateTime @default(now())

  lobby Lobby @relation(fields: [lobbyId], references: [id], onDelete: Cascade)

  @@unique([lobbyId, userId])
}

model LobbyMessage {
  id        String   @id
  lobbyId   String
  userId    String
  userName  String   @default("")
  body      String
  ts        DateTime @default(now())

  lobby Lobby @relation(fields: [lobbyId], references: [id], onDelete: Cascade)

  @@index([lobbyId, ts])
}

model LobbyAudit {
  id        String   @id
  lobbyId   String
  type      String
  actorId   String
  actorName String
  targetId  String?
  note      String?
  ts        DateTime @default(now())

  lobby Lobby @relation(fields: [lobbyId], references: [id], onDelete: Cascade)

  @@index([lobbyId, ts])
}

// ─── Room ─────────────────────────────────────────────────────────────────────

model Room {
  id        String   @id
  name      String   @default("")
  locked    Boolean  @default(false)
  ownerId   String?
  lobbyId   String?                             // Which lobby this room belongs to (null = orphan/legacy)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lobby    Lobby?       @relation(fields: [lobbyId], references: [id], onDelete: SetNull)
  members  RoomMember[]
  bans     RoomBan[]
  messages RoomMessage[]
  audit    RoomAudit[]

  @@unique([lobbyId, name])                     // No duplicate room names within a lobby
}

model RoomMember {
  id        String   @id @default(cuid())
  roomId    String
  userId    String
  name      String   @default("")
  role      RoomRole @default(MEMBER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
}

model RoomBan {
  id        String   @id @default(cuid())
  roomId    String
  userId    String
  createdAt DateTime @default(now())

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
}

model RoomMessage {
  id       String   @id
  roomId   String
  userId   String
  userName String   @default("")
  body     String
  ts       DateTime @default(now())

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId, ts])
}

model RoomAudit {
  id        String   @id
  roomId    String
  type      String
  actorId   String
  actorName String
  targetId  String?
  note      String?
  ts        DateTime @default(now())

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId, ts])
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id          String     @id @default(cuid())
  usernameKey String     @unique
  name        String     @default("")
  bio         String?
  notoriety   Int        @default(0)
  tier        UserTier   @default(INNOCENT)
  globalRole  GlobalRole @default(USER)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  dmSent     DirectMessage[] @relation("DMSent")
  dmReceived DirectMessage[] @relation("DMReceived")
  LocalAuth        LocalAuth?
  staffNotes       StaffNote[]      @relation("StaffNoteTarget")
  auditLogs        GlobalAudit[]    @relation("GlobalAuditTarget")
  notorietyEvents  NotorietyEvent[]
}

model LocalAuth {
  id               String    @id @default(cuid())
  username         String    @unique
  passwordHash     String
  email            String?   @unique
  emailVerified    Boolean   @default(false)
  verifyToken      String?   @unique
  verifyTokenExp   DateTime?
  userId           String    @unique
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model StaffNote {
  id         String   @id @default(cuid())
  targetId   String
  authorId   String
  authorName String   @default("")
  body       String
  createdAt  DateTime @default(now())

  target User @relation("StaffNoteTarget", fields: [targetId], references: [id], onDelete: Cascade)
}

model GlobalAudit {
  id         String   @id @default(cuid())
  actorId    String
  actorName  String   @default("")
  action     String
  targetId   String?
  targetName String?
  meta       Json?
  createdAt  DateTime @default(now())

  target User? @relation("GlobalAuditTarget", fields: [targetId], references: [id], onDelete: SetNull)

  @@index([createdAt])
}
enum UserTier {
  INNOCENT
  INDICTED
  FELON
  KINGPIN
}

// ── ADD THIS MODEL ────────────────────────────────────────────────────────────

model NotorietyEvent {
  id        String   @id @default(cuid())
  userId    String
  action    String
  points    Int
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, action])
}

model DirectMessage {
  id        String    @id @default(cuid())
  fromId    String
  toId      String
  body      String
  readAt    DateTime?
  createdAt DateTime  @default(now())

  from User @relation("DMSent",     fields: [fromId], references: [id], onDelete: Cascade)
  to   User @relation("DMReceived", fields: [toId],   references: [id], onDelete: Cascade)

  @@index([fromId, toId, createdAt])
  @@index([toId, readAt])
}

