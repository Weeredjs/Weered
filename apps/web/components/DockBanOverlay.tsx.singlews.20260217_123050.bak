'use client';

import React, { useEffect, useMemo, useState } from 'react';

export type BanRecord = {
  userId: string;
  reason?: string | null;
  createdAt?: string | null;
  updatedAt?: string | null;

  displayName?: string | null;
  userDisplayName?: string | null;

  user?: {
    id?: string | null;
    displayName?: string | null;
    name?: string | null;
  } | null;
};

function pickName(b: BanRecord): string {
  return (
    (b.userDisplayName ?? '') ||
    (b.displayName ?? '') ||
    (b.user?.displayName ?? '') ||
    (b.user?.name ?? '') ||
    (b.userId ? ('User ' + b.userId.slice(0, 8)) : 'Unknown user')
  );
}

type Props = {
  roomId: string;
  isPriv: boolean;
  bans: BanRecord[];
  onRefresh: () => void;
  onUnban: (userId: string) => void;
  onSaveReason: (userId: string, reason: string) => void;
};

export default function DockBanOverlay(props: Props) {
  const { roomId, isPriv, bans, onRefresh, onUnban, onSaveReason } = props;

  const canShow = useMemo(() => !!roomId && isPriv, [roomId, isPriv]);
  const [open, setOpen] = useState(false);
  const [reasonDraft, setReasonDraft] = useState<Record<string, string>>({});

  useEffect(() => {
    if (!canShow) { setOpen(false); setReasonDraft({}); return; }
    setReasonDraft((prev) => {
      const copy = { ...prev };
      for (const b of (Array.isArray(bans) ? bans : [])) {
        const id = b?.userId;
        if (!id) continue;
        if (copy[id] === undefined) copy[id] = (b.reason ?? '') as string;
      }
      return copy;
    });
  }, [canShow, bans]);

  if (!canShow) return null;

  return (
    <div style={{ position: 'fixed', bottom: 12, right: 12, zIndex: 10000, fontFamily: 'system-ui, sans-serif' }}>
      <button
        type="button"
        onClick={() => setOpen(v => !v)}
        style={{ border: '1px solid #ddd', borderRadius: 10, padding: '8px 10px', background: '#fff', boxShadow: '0 6px 18px rgba(0,0,0,0.10)' }}
        title="Bans"
      >
        Bans
      </button>

      {open && (
        <div style={{ marginTop: 8, width: 420, maxWidth: '90vw', border: '1px solid #e5e5e5', borderRadius: 12, background: '#fff', boxShadow: '0 10px 28px rgba(0,0,0,0.12)' }}>
          <div style={{ display: 'flex', alignItems: 'center', gap: 10, padding: 10, borderBottom: '1px solid #f0f0f0' }}>
            <div style={{ fontWeight: 800 }}>Banned users</div>
            <div style={{ marginLeft: 'auto', display: 'flex', gap: 8 }}>
              <button type="button" onClick={onRefresh} style={{ border: '1px solid #ddd', borderRadius: 10, padding: '6px 10px', background: '#fff' }}>Refresh</button>
              <button type="button" onClick={() => setOpen(false)} style={{ border: '1px solid #ddd', borderRadius: 10, padding: '6px 10px', background: '#fff' }}>Close</button>
            </div>
          </div>

          <div style={{ maxHeight: '60vh', overflow: 'auto', padding: 10 }}>
            {(!bans || bans.length === 0) ? (
              <div style={{ color: '#777' }}>No bans.</div>
            ) : (
              <div style={{ display: 'flex', flexDirection: 'column', gap: 10 }}>
                {bans.map((b) => {
                  const id = b.userId;
                  const name = pickName(b);
                  const draft = reasonDraft[id] ?? '';
                  return (
                    <div key={id} style={{ border: '1px solid #eee', borderRadius: 12, padding: 10 }}>
                      <div style={{ display: 'flex', alignItems: 'flex-start', gap: 10 }}>
                        <div style={{ flex: 1, minWidth: 0 }}>
                          <div style={{ fontWeight: 700, fontSize: 13, whiteSpace: 'nowrap', overflow: 'hidden', textOverflow: 'ellipsis' }}>{name}</div>
                          <div style={{ fontSize: 11, color: '#777', fontFamily: 'ui-monospace, SFMono-Regular', whiteSpace: 'nowrap', overflow: 'hidden', textOverflow: 'ellipsis' }}>{id}</div>
                        </div>
                        <button type="button" onClick={() => onUnban(id)} style={{ border: '1px solid #ddd', borderRadius: 10, padding: '6px 10px', background: '#fff' }}>
                          Unban
                        </button>
                      </div>

                      <div style={{ display: 'flex', gap: 8, marginTop: 10 }}>
                        <input
                          value={draft}
                          onChange={(e) => {
                            const v = e.target.value;
                            setReasonDraft((prev) => ({ ...prev, [id]: v }));
                          }}
                          placeholder="Reason"
                          style={{ flex: 1, border: '1px solid #ddd', borderRadius: 10, padding: '8px 10px' }}
                        />
                        <button
                          type="button"
                          onClick={() => onSaveReason(id, (reasonDraft[id] ?? '').trim())}
                          style={{ border: '1px solid #ddd', borderRadius: 10, padding: '6px 10px', background: '#fff' }}
                        >
                          Save
                        </button>
                      </div>
                    </div>
                  );
                })}
              </div>
            )}
          </div>
        </div>
      )}
    </div>
  );
}