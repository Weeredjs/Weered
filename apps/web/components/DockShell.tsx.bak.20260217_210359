'use client';

import DockBanOverlay, { type BanRecord } from './DockBanOverlay';

import React, { useEffect, useMemo, useState } from 'react';
import RoomActionsPanel from './RoomActionsPanel';
import { useRouterusePathnameusePathname } from 'next/navigation';
import { weeredWs, type WsMsg, type WsStatus, subscribeAuth, syncAuthFromStorage } from '../app/weeredClient';
type Room = { id: string; name: string | null; locked: boolean; ownerId?: string | null; ownerName?: string | null };
type Role = 'owner' | 'admin' | 'mod' | 'member' | 'guest';
type Member = { id: string; name: string; role?: Role };
type Knock = { userId: string; userName?: string; message?: string; createdAt: string };
type ChatMsg = { at: string; from: string; body: string };

export default function DockShell() {
  // WEE_ROUTE_ROOMID:start
  const pathname = (typeof window !== 'undefined') ? window.location.pathname : '';
  const routeRoomId = (() => {
    const m = (pathname || '').match(/^\/room\/([^\/\?#]+)/);
    return (m && m[1]) ? m[1] : '';
  })();
  // WEE_ROUTE_ROOMID:endconst router = useRouter();
const API = process.env.NEXT_PUBLIC_API_BASE || 'http://127.0.0.1:4000';

const [dockOpen, setDockOpen] = useState(false);
const [chatOpen, setChatOpen] = useState(false);

const [token, setToken] = useState('');
const [meId, setMeId] = useState('');

// WEE_LS_AUTH_SYNC_DOCK:start
(() => {
  let prevToken = '';
  let prevName = '';
  let prevId = '';

  const sync = () => {
    try {
      const t = localStorage.getItem('weered_token') || '';
      const id = localStorage.getItem('weered_user_id') || '';
      const name = localStorage.getItem('weered_name') || '';

      setToken(t);
      setMeId(id);
      setMeName(name);

      // Token changed => reset rooms + reconnect WS
      if (t !== prevToken) {
        prevToken = t;
        try { weeredWs.resetRooms?.(); } catch {}
        try { weeredWs.disconnect?.(); } catch {}
        if (t) {
          try { weeredWs.setToken?.(t); } catch {}
          try { weeredWs.connect?.(t); } catch {}
          try {
            const rid = localStorage.getItem('weered_last_room') || '';
            if (rid) weeredWs.setActiveRoom?.(rid);
          } catch {}
        }
      }

      // Name/id changed => re-announce + refresh active room presence
      if (t && (name !== prevName || id !== prevId)) {
        prevName = name; prevId = id;
        try { weeredWs.send?.({ type: 'auth:hello', payload: { token: t, userId: id, displayName: name } }); } catch {}
        try {
          const rid = localStorage.getItem('weered_last_room') || '';
          if (rid) weeredWs.setActiveRoom?.(rid);
        } catch {}
      }
    } catch {}
  };

  const onVis = () => { if (!document.hidden) sync(); };

  sync();
  window.addEventListener('weered:auth', sync);
  window.addEventListener('focus', sync);
  document.addEventListener('visibilitychange', onVis);

  return () => {
    window.removeEventListener('weered:auth', sync);
    window.removeEventListener('focus', sync);
    document.removeEventListener('visibilitychange', onVis);
  };
}, []);
// WEE_LS_AUTH_SYNC_DOCK:end

const [meName, setMeName] = useState('');

// WEE_AUTH_SUB_DOCK:start
(() => {
  // initial sync (covers hard refresh + first render)
  try { syncAuthFromStorage(); } catch {}

  const unsub = subscribeAuth((a) => {
    setToken(a?.token ?? '');
    setMeId(a?.userId ?? '');
    setMeName(a?.displayName ?? '');
  });

  const onAuth = () => { try { syncAuthFromStorage(); } catch {} };
  window.addEventListener('weered:auth', onAuth);

  return () => {
    window.removeEventListener('weered:auth', onAuth);
    try { unsub(); } catch {}
  };
}, []);
// WEE_AUTH_SUB_DOCK:end


const [status, setStatus] = useState<WsStatus>(weeredWs.getStatus());
const [error, setError] = useState('');

const [rooms, setRooms] = useState<Room[]>([]);
const [roomId, setRoomId] = useState('');
const [roomLocked, setRoomLocked] = useState<boolean>(false);
const [myRole, setMyRole] = useState<Role>('guest');

const [createName, setCreateName] = useState('');
const [joinId, setJoinId] = useState('');

const [members, setMembers] = useState<Member[]>([]);
const [knocks, setKnocks] = useState<Knock[]>([]);
const [knockMsg, setKnockMsg] = useState('');

const [messages, setMessages] = useState<ChatMsg[]>([]);
const [input, setInput] = useState('');

const [bans, setBans] = useState<BanRecord[]>([]);

const [lastSend, setLastSend] = useState('');
const [lastRecv, setLastRecv] = useState('');

const isAuthed = useMemo(() => !!token, [token]);
const isPriv = useMemo(() => myRole === 'owner' || myRole === 'admin' || myRole === 'mod', [myRole]);
const canLock = useMemo(() => myRole === 'owner' || myRole === 'admin', [myRole]);
const canManageRoles = canLock;

const roleOptionsForActor = useMemo(() => {
if (myRole === 'owner') return ['admin', 'mod', 'member'] as Role[];
if (myRole === 'admin') return ['mod', 'member'] as Role[];
return [] as Role[];
}, [myRole]);

// Load persisted UI state safely (client-only)
useEffect(() => {
try {
setToken(localStorage.getItem('weered_token') || '');
setMeId(localStorage.getItem('weered_user_id') || '');
setMeName(localStorage.getItem('weered_name') || '');
setDockOpen((localStorage.getItem('weered_dock_open') || '') === '1');
setChatOpen((localStorage.getItem('weered_chat_open') || '') === '1');
setRoomId(localStorage.getItem('weered_last_room') || '');
setJoinId(localStorage.getItem('weered_last_room') || '');
} catch {}
}, []);

// Persist UI state
useEffect(() => { try { localStorage.setItem('weered_dock_open', dockOpen ? '1' : '0'); } catch {} }, [dockOpen]);
useEffect(() => { try { localStorage.setItem('weered_chat_open', chatOpen ? '1' : '0'); } catch {} }, [chatOpen]);
useEffect(() => { try { if (roomId) localStorage.setItem('weered_last_room', roomId); } catch {} }, [roomId]);
useEffect(() => { try { if (meId) localStorage.setItem('weered_user_id', meId); } catch {} }, [meId]);
useEffect(() => { try { if (meName) localStorage.setItem('weered_name', meName); } catch {} }, [meName]);

// Mirror WS status from singleton
useEffect(() => weeredWs.onStatus(setStatus), []);

// Route incoming WS messages (single bus)
useEffect(() => {
return weeredWs.subscribe((raw, msg) => {
setLastRecv(raw);
if (!msg || !msg.type) return;

if (msg.type === 'server:error') {
setError(msg.error || 'server:error');
return;
}
if (msg.type === 'auth:fail') {
setError('auth failed');
return;
}

if (msg.type === 'auth:ok') {
const u = msg?.payload?.user;
const id = String(u?.id ?? '').trim();
const name = String(u?.name ?? '').trim();
if (id) setMeId(id);
if (name) setMeName(name);
return;
}

if (msg.type === 'room:locked') {
setError('room is locked ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Â ÃƒÂ¢Ã¢â€šÂ¬Ã¢â€žÂ¢ÃƒÆ’Ã†â€™ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã¢â‚¬Â¦Ãƒâ€šÃ‚Â¡ÃƒÆ’Ã†â€™ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™Ãƒâ€ Ã¢â‚¬â„¢ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã‚Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã†â€™ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡ÃƒÆ’Ã¢â‚¬Å¡Ãƒâ€šÃ‚Â knock to request access');
setMyRole('guest');
setChatOpen(true);
return;      if (msg.type === 'room:locked') {
if (String(msg?.payload?.roomId ?? '') !== roomId) return;
const locked = msg?.payload?.locked ?? false;
setRoomLocked(locked);  // Set the room lock state
setError(locked ? 'Room is locked' : '');
setMyRole(locked ? 'guest' : 'member');  // Ensure guests can only knock
}
}

if (msg.type === 'room:lock_changed') {
if (String(msg?.payload?.roomId ?? '') !== roomId) return;
setRoomLocked(!!msg?.payload?.locked);
refreshRooms();
return;
}

if (msg.type === 'room:knocks') {
if (String(msg?.payload?.roomId ?? '') !== roomId) return;
setKnocks(Array.isArray(msg?.payload?.knocks) ? msg.payload.knocks : []);
return;
}

if (msg.type === 'room:knock') {
if (String(msg?.payload?.roomId ?? '') !== roomId) return;
const k: Knock = {
userId: String(msg?.payload?.userId ?? ''),
userName: String(msg?.payload?.userName ?? ''),
message: String(msg?.payload?.message ?? ''),
createdAt: String(msg?.payload?.createdAt ?? new Date().toISOString()),
};
if (k.userId) setKnocks((prev) => {
const next = prev.filter((x) => x.userId !== k.userId);
next.push(k);
return next;
});
return;
}

if (msg.type === 'room:admitted') {
if (String(msg?.payload?.roomId ?? '') !== roomId) return;
setError('');
return;
}

if (msg.type === 'room:denied') {
if (String(msg?.payload?.roomId ?? '') !== roomId) return;
setError('knock denied');
return;
}

if (msg.type === 'room:role_changed') {
if (String(msg?.payload?.roomId ?? '') !== roomId) return;
const userId = String(msg?.payload?.userId ?? '');
const role = String(msg?.payload?.role ?? '') as Role;
if (!userId || !role) return;
setMembers((prev) => prev.map((m) => (m.id === userId ? { ...m, role } : m)));
if (userId === meId) setMyRole(role);
return;
}

if (msg.type === 'presence:state') {
if (String(msg?.payload?.roomId ?? '') !== roomId) return;
const list = Array.isArray(msg?.payload?.members) ? msg.payload.members : [];
setMembers(list);

const me = list.find((m: any) => String(m?.id ?? '') === meId);
const r = (me?.role as Role) || 'guest';
setMyRole(r);
return;
}

if (msg.type === 'presence:join') {
if (String(msg?.payload?.roomId ?? '') !== roomId) return;
const m = msg?.payload?.member;
if (m?.id) {
setMembers((prev) => {
const next = prev.filter((x) => x.id !== m.id);
next.push(m);
return next;
});
if (m.id === meId && m.role) setMyRole(m.role);
}
return;
}

if (msg.type === 'presence:leave') {
if (String(msg?.payload?.roomId ?? '') !== roomId) return;
const memberId = String(msg?.payload?.memberId ?? '');
if (memberId) setMembers((prev) => prev.filter((x) => x.id !== memberId));
return;
}

if (msg.type === 'chat:new') {
if (String(msg?.payload?.roomId ?? '') !== roomId) return;
const body = String(msg?.payload?.body ?? '');
const at = String(msg?.payload?.at ?? new Date().toISOString());
const from = String(msg?.payload?.from?.name ?? 'Unknown');
if (!body) return;
setMessages((prev) => [...prev, { at, from, body }]);
return;
}

if (msg.type === 'room:bans') {
const rid = String(msg?.payload?.roomId ?? msg?.roomId ?? '');
if (rid && rid !== roomId) return;
const list =
(Array.isArray(msg?.payload?.bans) ? msg.payload.bans : null) ??
(Array.isArray((msg as any)?.bans) ? (msg as any).bans : null) ??
[];
setBans(list as BanRecord[]);
return;
}
});
// eslint-disable-next-line react-hooks/exhaustive-deps
}, [roomId, meId]);

// Keep role in sync if meId lands after presence:state
useEffect(() => {
if (!meId) return;
const me = members.find((m: any) => String(m?.id ?? '') === meId);
const r = (me?.role as Role) || 'guest';
setMyRole(r);
}, [meId, members]);

function sendJson(obj: any) {
const raw = weeredWs.send(obj);
if (raw) setLastSend(raw);
}

function disconnect() {
weeredWs.disconnect();
}

function connect() {
if (!token) return;
setError('');
weeredWs.connect(token);
}

async function refreshRooms() {
try {
const res = await fetch(API + '/rooms');
const data = await res.json();
const list = Array.isArray(data?.rooms) ? data.rooms : [];
setRooms(list);
if (roomId) {
const r = list.find((x: Room) => x.id === roomId);
if (r) setRoomLocked(!!r.locked);
}
} catch (e: any) {
setError(String(e?.message || e));
}
}

useEffect(() => { refreshRooms(); /* eslint-disable-next-line */ }, []);

// Auto-connect when UI is being used (singleton WS)
useEffect(() => {
const wants = !!token && (dockOpen || chatOpen || !!roomId);
if (!wants) return;
weeredWs.setToken(token);
weeredWs.connect();
// eslint-disable-next-line react-hooks/exhaustive-deps
}, [token, dockOpen, chatOpen, roomId]);

// Ensure presence join for current room
useEffect(() => {
if (!token || !roomId) return;
if (status !== 'open') return;
((weeredWs as any).setActiveRoom ? (weeredWs as any).setActiveRoom(roomId) : (weeredWs as any).joinRoom?.(roomId));
}, [token, roomId, status]);

// Auto-refresh bans for priv roles when connected
useEffect(() => {
if (!roomId || !isPriv) return;
if (status !== 'open') return;
refreshBans();
// eslint-disable-next-line react-hooks/exhaustive-deps
}, [roomId, isPriv, status]);

function selectRoom(id: string) {
const rid = id.trim();
if (!rid) return;
setRoomId(rid);
setMessages([]);
setMembers([]);
setKnocks([]);
setMyRole('guest');
setChatOpen(true);

const r = rooms.find((x) => x.id === rid);
setRoomLocked(!!r?.locked);

weeredWs.setToken(token);
weeredWs.connect();
if (weeredWs.getStatus() === 'open') weeredWs.setActiveRoom(rid);

refreshRooms();
}

async function createRoom() {
try {
const res = await fetch(API + '/rooms', {
method: 'POST',
headers: { 'content-type': 'application/json', 'authorization': 'Bearer ' + token },
body: JSON.stringify({ name: createName }),
});
const data = await res.json();
if (!res.ok) throw new Error(data?.error || 'create_failed');
const id = String(data?.room?.id || '');
if (!id) throw new Error('no_room_id');
setCreateName('');
await refreshRooms();
selectRoom(id);
} catch (e: any) {
setError(String(e?.message || e));
}
}

function sendChat() {
const body = input.trim();
if (!body || !roomId) return;
sendJson({ type: 'chat:send', payload: { roomId: (routeRoomId || roomId), body } });
setInput('');
}

function knock() {
if (!roomId) return;
sendJson({ type: 'room:knock', payload: { roomId: (routeRoomId || roomId), message: knockMsg.trim() } });
setKnockMsg('');
}

function refreshKnocks() {
if (!roomId) return;
sendJson({ type: 'room:knocks:get', payload: { roomId: (routeRoomId || roomId) } });
}

function admit(userId: string) {
sendJson({ type: 'room:admit', payload: { roomId: (routeRoomId || roomId), userId } });
}

function deny(userId: string) {
sendJson({ type: 'room:deny', payload: { roomId: (routeRoomId || roomId), userId } });
}

function setLock(locked: boolean) {
sendJson({ type: 'room:set_lock', payload: { roomId: (routeRoomId || roomId), locked } });
setRoomLocked(locked);
refreshRooms();
if (locked && isPriv) refreshKnocks();
}

function setRole(userId: string, role: Role) {
if (!roomId || !userId || !role) return;
sendJson({ type: 'room:set_role', payload: { roomId: (routeRoomId || roomId), userId, role } });
