function refreshBans() {
if (!roomId) return;
sendJson({ type: 'room:bans:get', payload: { roomId: (routeRoomId || roomId) } });
}

function unbanUser(userId: string) {
if (!roomId || !userId) return;
sendJson({ type: 'room:unban', payload: { roomId: (routeRoomId || roomId), userId } });
setTimeout(refreshBans, 150);
}

function saveBanReason(userId: string, reason: string) {
if (!roomId || !userId) return;
sendJson({ type: 'room:ban', payload: { roomId: (routeRoomId || roomId), userId, reason } });
setTimeout(refreshBans, 150);
}

