'use client';

export type WsStatus = 'closed' | 'connecting' | 'open';

export type WsMsg = {
  type: string;
  payload?: any;
  error?: string;
  [k: string]: any;
};

type Handler = (msg: WsMsg, raw: string) => void;
type StatusHandler = (s: WsStatus) => void;

class WeeredWsClient {
  private ws: WebSocket | null = null;
  private status: WsStatus = 'closed';
  private token = '';

  private handlers = new Set<Handler>();
  private statusHandlers = new Set<StatusHandler>();

  // We only want ONE effective room at a time for presence/chat parity (Dock + Room page).
  private joinedRooms = new Set<string>();
  private activeRoomId = '';

  setToken(t: string) {
    this.token = (t || '').trim();
  }

  getStatus(): WsStatus {
    return this.status;
  }

  getActiveRoom(): string {
    return this.activeRoomId;
  }

  subscribe(fn: Handler) {
    this.handlers.add(fn);
    return () => this.handlers.delete(fn);
  }

  onStatus(fn: StatusHandler) {
    this.statusHandlers.add(fn);
    return () => this.statusHandlers.delete(fn);
  }

  private setStatus(s: WsStatus) {
    this.status = s;
    for (const fn of this.statusHandlers) fn(s);
  }

  connect(url: string) {
    if (!this.token) return;
    if (this.ws && (this.ws.readyState === WebSocket.OPEN || this.ws.readyState === WebSocket.CONNECTING)) return;

    this.setStatus('connecting');
    const ws = new WebSocket(url);
    this.ws = ws;

    ws.onopen = () => {
      this.setStatus('open');

      // auth
      this.send({ type: 'auth:hello', payload: { token: this.token } });

      // join any rooms we consider active (normally 0/1)
      for (const rid of this.joinedRooms) {
        this.send({ type: 'presence:join', payload: { roomId: rid } });
      }
    };

    ws.onmessage = (evt) => {
      const raw = typeof evt.data === 'string' ? evt.data : String(evt.data);
      let msg: WsMsg | null = null;
      try {
        msg = JSON.parse(raw);
      } catch {
        msg = null;
      }
      if (!msg) return;
      for (const fn of this.handlers) fn(msg, raw);
    };

    ws.onerror = () => {
      // keep status; UI will show ws error via higher-level handlers if desired
    };

    ws.onclose = () => {
      this.ws = null;
      this.setStatus('closed');
    };
  }

  disconnect() {
    try { this.ws?.close(); } catch {}
    this.ws = null;
    this.setStatus('closed');
  }

  send(obj: any): boolean {
    const ws = this.ws;
    if (!ws || ws.readyState !== WebSocket.OPEN) return false;
    ws.send(JSON.stringify(obj));
    return true;
  }

  // Back-compat: joinRoom behaves like setActiveRoom (single-room presence).
  joinRoom(roomId: string) {
    this.setActiveRoom(roomId);
  }

  setActiveRoom(roomId: string) {
    const next = (roomId || '').trim();
    if (next === this.activeRoomId) return;

    const wsOpen = !!this.ws && this.ws.readyState === WebSocket.OPEN;
    const prev = this.activeRoomId;

    // leave previous
    if (prev) {
      this.joinedRooms.delete(prev);
      if (wsOpen) this.send({ type: 'presence:leave', payload: { roomId: prev } });
    }

    // join next
    this.activeRoomId = next;
    if (next) {
      this.joinedRooms.add(next);
      if (wsOpen) this.send({ type: 'presence:join', payload: { roomId: next } });
    }
  }

  leaveRoom(roomId: string) {
    const rid = (roomId || '').trim();
    if (!rid) return;

    const wsOpen = !!this.ws && this.ws.readyState === WebSocket.OPEN;
    this.joinedRooms.delete(rid);
    if (this.activeRoomId === rid) this.activeRoomId = '';

    if (wsOpen) this.send({ type: 'presence:leave', payload: { roomId: rid } });
  }

  clearRooms() {
    const rooms = Array.from(this.joinedRooms);
    for (const rid of rooms) this.leaveRoom(rid);
    this.joinedRooms.clear();
    this.activeRoomId = '';
  }
}

export const weeredWs = new WeeredWsClient();