"use client";

const __WEERED_CHAT_SELECTOR = '[data-weered-chat-input="1"]';

function __weered_getChatBody(fallback: any): string {
  try {
    const el = document.querySelector(__WEERED_CHAT_SELECTOR) as any;
    const v = (el && typeof el.value === "string") ? el.value : fallback;
    return String(v ?? "").trim();
  } catch {
    return String(fallback ?? "").trim();
  }
}

import { useState, useEffect, useRef, useMemo } from "react";
import RoomTools from './RoomTools'
// --- Chat cache (local) ---
type ChatMsg = {
  id: string;
  roomId: string;
  fromUserId: string;
  body: string;
  createdAt: string;
};

const CHAT_CACHE_MAX = 200;
function chatCacheKey(roomId: string) {
  return "weered:chat:" + roomId;
}
function loadChatCache(roomId: string): ChatMsg[] {
  try {
    const raw = localStorage.getItem(chatCacheKey(roomId));
    if (!raw) return [];
    const parsed = JSON.parse(raw);
    return Array.isArray(parsed) ? (parsed as ChatMsg[]).slice(-CHAT_CACHE_MAX) : [];
  } catch {
    return [];
  }
}
function saveChatCache(roomId: string, msgs: ChatMsg[]) {
  try {
    localStorage.setItem(chatCacheKey(roomId), JSON.stringify(msgs.slice(-CHAT_CACHE_MAX)));
  } catch {}
}

// -------------------- RANK_UI: helpers --------------------
type UserCard = {
  userId: string;
  displayName: string;
  globalRole?: string;
  subscriptionTier?: string;
  spaceRole?: string | null;
  pinRank?: number;
};

function rankEmoji(u: UserCard): string {
  // Unicode escapes avoid any console/codepage mojibake
  if (u.spaceRole === "owner") return "\u{1F451}";         // ðŸ‘‘
  const gr = String(u.globalRole ?? "user");
  if (gr === "god") return "\u{1F7E3}";                    // ðŸŸ£
  if (gr === "mod_supervisor") return "\u{1F6E1}\u{FE0F}";  // ðŸ›¡ï¸
  if (gr === "global_mod") return "\u{1F7E2}";             // ðŸŸ¢
  if (gr === "support") return "\u{1F9F0}";                // ðŸ§°
  const tier = String(u.subscriptionTier ?? "free");
  if (tier === "plus") return "\u{2795}";                  // âž•
  return "\u{2022}";                                       // â€¢
}
function rankColor(u: UserCard): string {
  if (u.spaceRole === "owner") return "#f5c542";
  const gr = String(u.globalRole ?? "user");
  if (gr === "god") return "#b36bff";
  if (gr === "mod_supervisor") return "#39c6b6";
  if (gr === "global_mod") return "#60d46b";
  if (gr === "support") return "#5aa7ff";
  const tier = String(u.subscriptionTier ?? "free");
  if (tier === "plus") return "#ffd36a";
  return "#9aa3b2";
}

function sortRoster(list: any[]): any[] {
  const arr = Array.isArray(list) ? list.slice() : [];
  arr.sort((a, b) => {
    const pa = Number(a?.pinRank ?? 0);
    const pb = Number(b?.pinRank ?? 0);
    if (pb !== pa) return pb - pa;
    const da = String(a?.displayName ?? "");
    const db = String(b?.displayName ?? "");
    return da.localeCompare(db);
  });
  return arr;
}


 // -------------------- ROSTER_UI: styles --------------------
function _hexWithAlpha(hex: string, alphaHex: string): string {
  if (typeof hex === "string" && /^#[0-9a-fA-F]{6}$/.test(hex)) return hex + alphaHex;
  return hex;
}

function rankLabel(u: UserCard): string {
  if (u.spaceRole === "owner") return "OWNER";
  const gr = String(u.globalRole ?? "user");
  if (gr === "god") return "GOD";
  if (gr === "mod_supervisor") return "MOD SUP";
  if (gr === "global_mod") return "MOD";
  if (gr === "support") return "SUPPORT";
  const tier = String(u.subscriptionTier ?? "free");
  if (tier === "plus") return "PLUS";
  return "";
}

function rankDetail(u: UserCard): string {
  const parts: string[] = [];
  if (u.spaceRole) parts.push(String(u.spaceRole));
  else if (u.globalRole) parts.push(String(u.globalRole));
  else parts.push("user");
  if (String(u.subscriptionTier ?? "free") === "plus") parts.push("plus");
  return parts.join(" - ");
}

function rosterRowStyle(u: UserCard): any {
  const c = rankColor(u);
  const label = rankLabel(u);
  let bg = "transparent";

  if (u.spaceRole === "owner") bg = _hexWithAlpha(c, "14");
  else if (label && label !== "PLUS") bg = _hexWithAlpha(c, "10");
  else if (label === "PLUS") bg = _hexWithAlpha(c, "0E");

  return {
    marginTop: 10,
    padding: "8px 10px",
    border: "1px solid #eee",
    borderLeft: "4px solid " + c,
    borderRadius: 12,
    background: bg
  };
}

function rosterPillStyle(u: UserCard): any {
  const c = rankColor(u);
  return {
    fontSize: 10,
    fontWeight: 700,
    letterSpacing: 0.5,
    padding: "2px 8px",
    borderRadius: 999,
    border: "1px solid " + c,
    color: c,
    background: _hexWithAlpha(c, "14"),
    textTransform: "uppercase",
    whiteSpace: "nowrap"
  };
}
