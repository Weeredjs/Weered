        setUsers((msg.payload?.users ?? []) as UserCard[]);
        return;
      }

      if (msg.type === "chat:new") {
        setLog(prev => [...prev, { fromUserId: msg.payload.fromUserId, body: msg.payload.body }]);
        return;
      }
    };

    ws.onerror = () => setWsStatus("WS error");
    ws.onclose = () => setWsStatus("closed");

    return () => {
