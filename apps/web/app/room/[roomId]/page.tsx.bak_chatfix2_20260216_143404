          if (typeof p.body !== "string") return;
          const createdAt = (typeof p.createdAt === "string") ? p.createdAt : new Date().toISOString();
          const fromUserId = (typeof p.fromUserId === "string") ? p.fromUserId : "unknown";
          const id = (typeof p.id === "string") ? p.id : (createdAt + "-" + Math.random().toString(16).slice(2));
          const nextMsg: ChatMsg = { id, roomId: p.roomId, fromUserId, body: p.body, createdAt };
          setMessages((prev) => {
