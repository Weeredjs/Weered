        if (ws.readyState === WebSocket.OPEN) {
          ws.send(JSON.stringify({ type: "presence:leave", payload: {} }));
        }
      } catch {}
      ws.close();
    };
  }, [roomId, token, wsUrl]);
  // --- Cached chat state ---
